<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AfficherRenewalRequest">
    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="Renewal Requests" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox spacing="8">
                <Button text="Add" onAction="#handleAdd"/>
                <Button text="Edit" onAction="#handleEdit"/>
                <Button text="Delete" onAction="#handleDelete"/>
                <Button text="Approve" onAction="#handleApprove"/>
                <Button text="Reject" onAction="#handleReject"/>
                <Button text="Refresh" onAction="#handleRefresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="requestTable">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="loanIdColumn" text="Loan ID" prefWidth="90"/>
                <TableColumn fx:id="memberIdColumn" text="Member ID" prefWidth="90"/>
                <TableColumn fx:id="requestedAtColumn" text="Requested At" prefWidth="150"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                <TableColumn fx:id="notesColumn" text="Notes" prefWidth="220"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
