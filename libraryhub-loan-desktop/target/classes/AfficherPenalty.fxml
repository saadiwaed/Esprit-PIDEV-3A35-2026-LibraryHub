<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AfficherPenalty">
    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="Penalties" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox spacing="8">
                <Button text="Add" onAction="#handleAdd"/>
                <Button text="Edit" onAction="#handleEdit"/>
                <Button text="Delete" onAction="#handleDelete"/>
                <Button text="Refresh" onAction="#handleRefresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="penaltyTable">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="loanIdColumn" text="Loan ID" prefWidth="90"/>
                <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100"/>
                <TableColumn fx:id="lateDaysColumn" text="Late Days" prefWidth="90"/>
                <TableColumn fx:id="reasonColumn" text="Reason" prefWidth="220"/>
                <TableColumn fx:id="issueDateColumn" text="Issue Date" prefWidth="110"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                <TableColumn fx:id="waivedColumn" text="Waived" prefWidth="80"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
