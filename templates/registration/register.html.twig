<!DOCTYPE html>
<html lang="en">
<head>
    <title>Register - LibraryHub</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    
    <!-- Favicon -->
    <link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">
    
    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap">
    
    <!-- Plugins CSS -->
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
    
    <!-- Theme CSS -->
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">
</head>

<body>
<main>
    <section class="p-0 d-flex align-items-center position-relative overflow-hidden">
        <div class="container-fluid">
            <div class="row">
                <!-- Left: Image -->
                <div class="col-12 col-lg-6 d-md-flex align-items-center justify-content-center bg-primary bg-opacity-10 vh-lg-100">
                    <div class="p-3 p-lg-5">
                        <!-- Title -->
                        <div class="text-center">
                            <h2 class="fw-bold">Welcome to LibraryHub</h2>
                            <p class="mb-0 h6 fw-light">Join our community of book lovers!</p>
                        </div>
                        <!-- SVG Image -->
                        <img src="{{ asset('assets/images/element/02.svg') }}" class="mt-5" alt="">
                        <!-- Info -->
                        <div class="d-sm-flex mt-5 align-items-center justify-content-center">
                            <ul class="avatar-group mb-2 mb-sm-0">
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar"></li>
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/02.jpg') }}" alt="avatar"></li>
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/03.jpg') }}" alt="avatar"></li>
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/04.jpg') }}" alt="avatar"></li>
                            </ul>
                            <p class="mb-0 h6 fw-light ms-0 ms-sm-3">4k+ members already joined</p>
                        </div>
                    </div>
                </div>

                <!-- Right: Register Form -->
                <div class="col-12 col-lg-6 m-auto">
                    <div class="row my-5">
                        <div class="col-sm-10 col-xl-8 m-auto">
                        <!-- Logo -->
                        <div class="text-center mb-4">
                            <a href="{{ path('app_frontoffice') }}" class="text-decoration-none">
                                <h1 class="fs-2">
                                    <i class="fas fa-book-open text-primary me-2"></i>
                                    LIBRARY<span class="text-warning">HUB</span>
                                </h1>
                            </a>
                        </div>

                        <!-- Flash messages -->
                            {% for label, messages in app.flashes %}
                                {% for message in messages %}
                                    <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                    </div>
                                {% endfor %}
                            {% endfor %}

                            <!-- Title -->
                            <h2 class="mb-2">Create an Account</h2>
                            <p class="mb-0">Already have an account? <a href="{{ path('app_login') }}">Sign in here</a></p>
                            
                            <!-- Back to home button -->
                            <div class="mt-2">
                                <a href="{{ path('app_frontoffice') }}" class="text-muted small">
                                    <i class="bi bi-arrow-left me-1"></i>Retour à l'accueil
                                </a>
                            </div>

                            <!-- Form START -->
                            {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate', 'class': 'mt-4'}}) }}
                                <!-- First Name -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.firstName) }}
                                </div>

                                <!-- Last Name -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.lastName) }}
                                </div>

                                <!-- Email -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.email) }}
                                </div>

                                <!-- Password -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.plainPassword.first) }}
                                </div>

                                <!-- Confirm Password -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.plainPassword.second) }}
                                </div>

                                <!-- Terms and Conditions -->
                                <div class="mb-3 form-check">
                                    {{ form_widget(registrationForm.agreeTerms) }}
                                    {{ form_label(registrationForm.agreeTerms) }}
                                    {{ form_errors(registrationForm.agreeTerms) }}
                                </div>

                                <!-- Button -->
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-person-plus me-2"></i>Register
                                    </button>
                                </div>

                                <!-- Divider -->
                                <div class="position-relative my-4">
                                    <hr>
                                    <p class="small bg-body position-absolute top-50 start-50 translate-middle px-2">Or</p>
                                </div>

                                <!-- Already have account -->
                                <div class="text-center">
                                    <p class="mb-0">Already have an account? <a href="{{ path('app_login') }}" class="text-primary-hover">Sign in</a></p>
                                </div>
                            {{ form_end(registrationForm) }}
                            <!-- Form END -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<!-- Bootstrap JS -->
<script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('assets/js/functions.js') }}"></script>
</body>
</html>
