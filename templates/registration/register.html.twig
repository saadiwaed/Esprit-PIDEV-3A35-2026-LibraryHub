<!DOCTYPE html>
<html lang="en">
<head>
    <title>Register - LibraryHub</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    
    <!-- Favicon -->
    <link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">
    
    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap">
    
    <!-- Plugins CSS -->
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
    
    <!-- Theme CSS -->
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}">
</head>

<body>
<main>
    <section class="p-0 d-flex align-items-center position-relative overflow-hidden">
        <div class="container-fluid">
            <div class="row">
                <!-- Left: Image -->
                <div class="col-12 col-lg-6 d-md-flex align-items-center justify-content-center bg-primary bg-opacity-10 vh-lg-100">
                    <div class="p-3 p-lg-5">
                        <!-- Title -->
                        <div class="text-center">
                            <h2 class="fw-bold">Welcome to LibraryHub</h2>
                            <p class="mb-0 h6 fw-light">Join our community of book lovers!</p>
                        </div>
                        <!-- SVG Image -->
                        <img src="{{ asset('assets/images/element/02.svg') }}" class="mt-5" alt="">
                        <!-- Info -->
                        <div class="d-sm-flex mt-5 align-items-center justify-content-center">
                            <ul class="avatar-group mb-2 mb-sm-0">
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar"></li>
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/02.jpg') }}" alt="avatar"></li>
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/03.jpg') }}" alt="avatar"></li>
                                <li class="avatar avatar-sm"><img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/04.jpg') }}" alt="avatar"></li>
                            </ul>
                            <p class="mb-0 h6 fw-light ms-0 ms-sm-3">4k+ members already joined</p>
                        </div>
                    </div>
                </div>

                <!-- Right: Register Form -->
                <div class="col-12 col-lg-6 m-auto">
                    <div class="row my-5">
                        <div class="col-sm-10 col-xl-8 m-auto">
                        <!-- Logo -->
                        <div class="text-center mb-4">
                            <a href="{{ path('app_frontoffice') }}" class="text-decoration-none">
                                <h1 class="fs-2">
                                    <i class="fas fa-book-open text-primary me-2"></i>
                                    LIBRARY<span class="text-warning">HUB</span>
                                </h1>
                            </a>
                        </div>

                        <!-- Flash messages -->
                            {% for label, messages in app.flashes %}
                                {% for message in messages %}
                                    <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                    </div>
                                {% endfor %}
                            {% endfor %}

                            <!-- Title -->
                            <h2 class="mb-2">Create an Account</h2>
                            <p class="mb-0">Already have an account? <a href="{{ path('app_login') }}">Sign in here</a></p>
                            
                            <!-- Back to home button -->
                            <div class="mt-2">
                                <a href="{{ path('app_frontoffice') }}" class="text-muted small">
                                    <i class="bi bi-arrow-left me-1"></i>Retour à l'accueil
                                </a>
                            </div>

                            <!-- Form START (contrôle de saisie: email format + password min 4, même logique que Sign In) -->
                            {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate', 'class': 'mt-4', 'id': 'registerForm'}}) }}
                                <!-- First Name -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.firstName) }}
                                    <div id="registerFirstNameError" class="invalid-feedback" style="display: none;"></div>
                                </div>

                                <!-- Last Name -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.lastName) }}
                                    <div id="registerLastNameError" class="invalid-feedback" style="display: none;"></div>
                                </div>

                                <!-- Email -->
                                <div class="mb-3" id="wrapEmail">
                                    {{ form_row(registrationForm.email) }}
                                    <div id="registerEmailError" class="invalid-feedback" style="display: none;"></div>
                                </div>

                                <!-- Password -->
                                <div class="mb-3" id="wrapPassword">
                                    {{ form_row(registrationForm.plainPassword.first) }}
                                    <div id="registerPasswordError" class="invalid-feedback" style="display: none;"></div>
                                </div>

                                <!-- Confirm Password -->
                                <div class="mb-3">
                                    {{ form_row(registrationForm.plainPassword.second) }}
                                    <div id="registerConfirmPasswordError" class="invalid-feedback" style="display: none;"></div>
                                </div>

                                <!-- Terms and Conditions -->
                                <div class="mb-3 form-check">
                                    {{ form_widget(registrationForm.agreeTerms) }}
                                    {{ form_label(registrationForm.agreeTerms) }}
                                    {{ form_errors(registrationForm.agreeTerms) }}
                                </div>

                                <!-- Button -->
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-person-plus me-2"></i>Register
                                    </button>
                                </div>

                                <!-- Divider -->
                                <div class="position-relative my-4">
                                    <hr>
                                    <p class="small bg-body position-absolute top-50 start-50 translate-middle px-2">Or</p>
                                </div>

                                <!-- Already have account -->
                                <div class="text-center">
                                    <p class="mb-0">Already have an account? <a href="{{ path('app_login') }}" class="text-primary-hover">Sign in</a></p>
                                </div>
                            {{ form_end(registrationForm) }}
                            <!-- Form END -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<!-- Bootstrap JS -->
<script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('assets/js/functions.js') }}"></script>
<!-- Contrôle de saisie Sign Up: First Name, Last Name, Email, Password min 4, Confirm Password required -->
<script>
(function() {
    var form = document.getElementById('registerForm');
    if (!form) return;
    var firstNameInput = form.querySelector('input[name*="[firstName]"]');
    var lastNameInput = form.querySelector('input[name*="[lastName]"]');
    var emailInput = form.querySelector('input[name*="[email]"]');
    var passwordInputs = form.querySelectorAll('input[type="password"]');
    var passwordInput = passwordInputs[0];
    var confirmPasswordInput = passwordInputs[1];
    var firstNameError = document.getElementById('registerFirstNameError');
    var lastNameError = document.getElementById('registerLastNameError');
    var emailError = document.getElementById('registerEmailError');
    var passwordError = document.getElementById('registerPasswordError');
    var confirmPasswordError = document.getElementById('registerConfirmPasswordError');

    if (!firstNameInput || !lastNameInput || !emailInput || !passwordInput || !confirmPasswordInput ||
        !firstNameError || !lastNameError || !emailError || !passwordError || !confirmPasswordError) return;

    function showError(inputEl, errorEl, message) {
        errorEl.textContent = message;
        errorEl.style.display = 'block';
        inputEl.classList.add('is-invalid');
    }
    function clearError(inputEl, errorEl) {
        errorEl.textContent = '';
        errorEl.style.display = 'none';
        inputEl.classList.remove('is-invalid');
    }

    function isEmailValid(value) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(value).trim());
    }

    form.addEventListener('submit', function(e) {
        var ok = true;
        clearError(firstNameInput, firstNameError);
        clearError(lastNameInput, lastNameError);
        clearError(emailInput, emailError);
        clearError(passwordInput, passwordError);
        clearError(confirmPasswordInput, confirmPasswordError);

        var firstName = (firstNameInput.value || '').trim();
        if (firstName === '') {
            showError(firstNameInput, firstNameError, 'Ce champ est obligatoire.');
            ok = false;
        }

        var lastName = (lastNameInput.value || '').trim();
        if (lastName === '') {
            showError(lastNameInput, lastNameError, 'Ce champ est obligatoire.');
            ok = false;
        }

        var email = (emailInput.value || '').trim();
        if (email === '') {
            showError(emailInput, emailError, 'Ce champ est obligatoire.');
            ok = false;
        } else if (!isEmailValid(email)) {
            showError(emailInput, emailError, 'Veuillez saisir une adresse e-mail valide (ex: utilisateur@exemple.com).');
            ok = false;
        }

        var password = (passwordInput.value || '');
        if (password === '') {
            showError(passwordInput, passwordError, 'Ce champ est obligatoire.');
            ok = false;
        } else if (password.length < 4) {
            showError(passwordInput, passwordError, 'Le mot de passe doit contenir au moins 4 caractères.');
            ok = false;
        }

        var confirmPassword = (confirmPasswordInput.value || '');
        if (confirmPassword === '') {
            showError(confirmPasswordInput, confirmPasswordError, 'Ce champ est obligatoire.');
            ok = false;
        } else if (password !== confirmPassword) {
            showError(confirmPasswordInput, confirmPasswordError, 'Les deux mots de passe ne correspondent pas.');
            ok = false;
        }

        if (!ok) e.preventDefault();
    });

    firstNameInput.addEventListener('input', function() { clearError(firstNameInput, firstNameError); });
    lastNameInput.addEventListener('input', function() { clearError(lastNameInput, lastNameError); });
    emailInput.addEventListener('input', function() { clearError(emailInput, emailError); });
    passwordInput.addEventListener('input', function() { clearError(passwordInput, passwordError); });
    confirmPasswordInput.addEventListener('input', function() { clearError(confirmPasswordInput, confirmPasswordError); });
})();
</script>
</body>
</html>
