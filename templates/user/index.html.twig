{% extends 'base.html.twig' %}

{% block title %}Users Management{% endblock %}

{% block body %}
<div class="container-fluid p-4">
        <!-- Title -->
        <div class="row mb-3">
            <div class="col-12 d-sm-flex justify-content-between align-items-center">
                <h1 class="h3 mb-2 mb-sm-0">Users Management</h1>
                <a href="{{ path('app_user_new') }}" class="btn btn-sm btn-primary mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Create New User
                </a>
            </div>
        </div>

    <!-- Flash messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Main content centered -->
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <!-- Search Bar -->
            <div class="card bg-transparent border mb-3">
                <div class="card-body">
                    <form method="get" action="{{ path('app_user_index') }}" class="row g-3 align-items-center">
                        <div class="col-md-10">
                            <div class="position-relative">
                                <input type="text" 
                                       name="search" 
                                       id="userSearch" 
                                       class="form-control" 
                                       placeholder="Search by name or email..." 
                                       value="{{ app.request.get('search') }}"
                                       autocomplete="off">
                                <div id="searchSuggestions" class="position-absolute w-100 bg-white border rounded shadow-sm" style="display: none; z-index: 1000; max-height: 300px; overflow-y: auto;"></div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-2"></i>Search
                            </button>
                            {% if app.request.get('search') %}
                                <a href="{{ path('app_user_index') }}" class="btn btn-secondary w-100 mt-2">
                                    <i class="bi bi-x-circle me-2"></i>Clear
                                </a>
                            {% endif %}
                        </div>
                    </form>
                </div>
            </div>

            <!-- Card START -->
            <div class="card bg-transparent border">
                <!-- Card body START -->
                <div class="card-body">
                    <!-- Table START -->
                    <div class="table-responsive border-0">
                    <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                        <thead>
                            <tr>
                                <th scope="col" class="border-0 rounded-start">Avatar</th>
                                <th scope="col" class="border-0">Full Name</th>
                                <th scope="col" class="border-0">Email</th>
                                <th scope="col" class="border-0">Status</th>
                                <th scope="col" class="border-0">Roles</th>
                                <th scope="col" class="border-0">Created At</th>
                                <th scope="col" class="border-0 rounded-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for user in users %}
                            <tr>
                                <td>
                                    <div class="avatar avatar-md">
                                        {% if user.avatar %}
                                            <img class="avatar-img rounded-circle" src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="{{ user.fullName }}">
                                        {% else %}
                                            <div class="avatar-img rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center">
                                                {{ user.firstName|first }}{{ user.lastName|first }}
                                            </div>
                                        {% endif %}
                                    </div>
                                </td>
                                <td>
                                    <h6 class="mb-0">{{ user.fullName }}</h6>
                                </td>
                                <td>{{ user.email }}</td>
                                <td>
                                    {% if user.status == 'ACTIVE' %}
                                        <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                                    {% elseif user.status == 'PENDING' %}
                                        <span class="badge bg-warning bg-opacity-10 text-warning">Pending</span>
                                    {% else %}
                                        <span class="badge bg-danger bg-opacity-10 text-danger">Inactive</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% for role in user.userRoles %}
                                        <span class="badge bg-info bg-opacity-10 text-info me-1">{{ role.name }}</span>
                                    {% else %}
                                        <span class="text-muted">No roles</span>
                                    {% endfor %}
                                </td>
                                <td>{{ user.createdAt|date('Y-m-d') }}</td>
                                <td>
                                    <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-sm btn-info-soft me-1 mb-1 mb-md-0" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-success-soft me-1 mb-1 mb-md-0" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger-soft mb-0" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#deleteModal{{ user.id }}"
                                            title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center">
                                    <div class="py-5">
                                        <i class="bi bi-people display-4 text-muted"></i>
                                        <p class="mt-3 text-muted">No users found</p>
                                        <a href="{{ path('app_user_new') }}" class="btn btn-primary">Create First User</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <!-- Table END -->

                <!-- Pagination -->
                {% if users is iterable and users.getItemNumberPerPage is defined %}
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 mt-3 pt-3 border-top">
                        <div class="text-muted small">
                            Showing {{ users.getItemNumberPerPage * (users.getCurrentPageNumber - 1) + 1 }}–{{ min(users.getItemNumberPerPage * users.getCurrentPageNumber, users.getTotalItemCount) }} of {{ users.getTotalItemCount }} users
                        </div>
                        <div class="nav-pagination">
                            {{ knp_pagination_render(users) }}
                        </div>
                    </div>
                {% endif %}
            </div>
            <!-- Card body END -->
        </div>
        <!-- Card END -->

        </div> {# end col-12 col-xl-10 #}
    </div> {# end row justify-content-center #}

    <!-- Delete Modals -->
        {% for user in users %}
            <div class="modal fade" id="deleteModal{{ user.id }}" tabindex="-1" aria-labelledby="deleteModalLabel{{ user.id }}" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="deleteModalLabel{{ user.id }}">Confirm Delete</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure you want to delete user <strong>{{ user.fullName }}</strong>?
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" style="display: inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('userSearch');
            const suggestionsDiv = document.getElementById('searchSuggestions');
            const filterForm = searchInput ? searchInput.closest('form') : null;
            let timeoutId;
            let fetchTimeoutId;

            // Dynamic autocomplete (fetch suggestions)
            searchInput.addEventListener('input', function() {
                clearTimeout(timeoutId);
                clearTimeout(fetchTimeoutId);
                const query = this.value.trim();

                if (query.length < 2) {
                    suggestionsDiv.style.display = 'none';
                    // Still submit form for live filtering when clearing (query empty)
                    if (filterForm && query.length === 0) {
                        fetchTimeoutId = setTimeout(function() { filterForm.submit(); }, 400);
                    }
                    return;
                }

                // Fetch autocomplete suggestions
                timeoutId = setTimeout(function() {
                    fetch('{{ path('app_user_search') }}?q=' + encodeURIComponent(query))
                        .then(response => response.json())
                        .then(data => {
                            if (data.length === 0) {
                                suggestionsDiv.innerHTML = '<div class="p-2 text-muted">No results found</div>';
                                suggestionsDiv.style.display = 'block';
                            } else {
                                const uploadsBase = '{{ asset('uploads/avatars/') }}';
                                suggestionsDiv.innerHTML = data.map(user => {
                                    const avatarHtml = user.avatar
                                        ? `<img class="avatar-img rounded-circle" src="${uploadsBase}${user.avatar}" alt="">`
                                        : `<div class="avatar-img rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center">${(user.initials || '').substring(0, 2)}</div>`;
                                    return `<div class="suggestion-item p-2 border-bottom" style="cursor: pointer;" data-name="${(user.fullName || '').replace(/"/g, '&quot;')}" data-email="${(user.email || '').replace(/"/g, '&quot;')}">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar avatar-xs me-2">${avatarHtml}</div>
                                            <div>
                                                <div class="fw-bold">${(user.fullName || '').replace(/</g, '&lt;')}</div>
                                                <small class="text-muted">${(user.email || '').replace(/</g, '&lt;')}</small>
                                            </div>
                                        </div>
                                    </div>`;
                                }).join('');
                                suggestionsDiv.style.display = 'block';

                                // Add click handlers to suggestions
                                document.querySelectorAll('.suggestion-item').forEach(item => {
                                    item.addEventListener('click', function() {
                                        searchInput.value = this.dataset.name || this.dataset.email || '';
                                        suggestionsDiv.style.display = 'none';
                                        if (filterForm) filterForm.submit();
                                    });
                                    
                                    item.addEventListener('mouseenter', function() {
                                        this.style.backgroundColor = '#f8f9fa';
                                    });
                                    
                                    item.addEventListener('mouseleave', function() {
                                        this.style.backgroundColor = '';
                                    });
                                });
                            }
                        })
                        .catch(error => {
                            console.error('Search error:', error);
                            suggestionsDiv.style.display = 'none';
                        });
                }, 300);

                // Live filter: auto-submit form after typing (debounced)
                fetchTimeoutId = setTimeout(function() {
                    if (filterForm && query.length >= 1) {
                        filterForm.submit();
                    }
                }, 600);
            });

            // Hide suggestions when clicking outside
            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !suggestionsDiv.contains(e.target)) {
                    suggestionsDiv.style.display = 'none';
                }
            });
        });
    </script>
{% endblock %}