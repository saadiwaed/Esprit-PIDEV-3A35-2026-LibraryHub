{% extends 'base.html.twig' %}

{% block title %}Edit User{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0">Edit User</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                            <li class="breadcrumb-item"><a href="{{ path('app_user_index') }}">Users</a></li>
                            <li class="breadcrumb-item active">Edit</li>
                        </ol>
                    </nav>
                </div>
                <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <!-- Form -->
    <div class="card">
        <div class="card-header bg-white">
            <h5 class="card-title mb-0">Edit: {{ user.fullName }}</h5>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'class': 'row g-3', 'novalidate': 'novalidate'}}) }}
            {# novalidate disables HTML5 browser validation so server-side errors display #}
                <div class="col-md-6">
                    {{ form_row(form.firstName) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.lastName) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.email) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.phone) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.plainPassword.first) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.plainPassword.second) }}
                </div>
                <div class="col-12">
                    {{ form_row(form.address) }}
                </div>
                <div class="col-md-6">
                    {% if user.avatar %}
                        <div class="mb-2">
                            <label class="form-label">Current Avatar</label>
                            <div>
                                <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" class="rounded" width="100" alt="Current avatar">
                            </div>
                        </div>
                    {% endif %}
                    {{ form_row(form.avatarFile) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.status) }}
                </div>
                <div class="col-12">
                    <label class="form-label">Roles</label>
                    <div class="d-flex flex-wrap gap-3">
                        {% for child in form.userRoles %}
                            <div class="form-check">
                                {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="col-12">
                    <hr>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>Update User
                    </button>
                    <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
