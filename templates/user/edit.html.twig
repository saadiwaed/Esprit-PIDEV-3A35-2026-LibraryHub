{% extends 'base.html.twig' %}

{% block title %}Edit User{% endblock %}

{% block body %}
<div class="page-content">
    <div class="page-content-wrapper border">
        <!-- Title -->
        <div class="row mb-3">
            <div class="col-12">
                <h1 class="h3 mb-2 mb-sm-0">Edit User: {{ user.fullName }}</h1>
            </div>
        </div>

        <!-- Card START -->
        <div class="card bg-transparent border">
            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="row g-4">
                        <!-- Personal Information -->
                        <div class="col-12">
                            <h5 class="mb-3">Personal Information</h5>
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.firstName) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.lastName) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.email) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.phone) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.address) }}
                        </div>

                        <!-- Change Password (Optional) -->
                        <div class="col-12">
                            <h5 class="mb-3 mt-3">Change Password (Optional)</h5>
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.plainPassword.first) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.plainPassword.second) }}
                        </div>

                        <!-- Account Settings -->
                        <div class="col-12">
                            <h5 class="mb-3 mt-3">Account Settings</h5>
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.status) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.avatarFile) }}
                            {% if user.avatar %}
                                <div class="mt-2">
                                    <small class="text-muted">Current avatar:</small><br>
                                    <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="{{ user.fullName }}" class="rounded" style="width: 80px; height: 80px; object-fit: cover;">
                                </div>
                            {% endif %}
                        </div>

                        <!-- Roles -->
                        <div class="col-12">
                            <h5 class="mb-3 mt-3">Assign Roles</h5>
                            {{ form_row(form.userRoles) }}
                        </div>

                        <!-- Submit Buttons -->
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Update User
                            </button>
                            <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
        <!-- Card END -->
    </div>
</div>
{% endblock %}
