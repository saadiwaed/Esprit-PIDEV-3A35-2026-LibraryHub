{% extends 'base.html.twig' %}

{% block title %}Modifier Club{% endblock %}

{% block body %}

<div class="container py-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">Modifier le Club</h2>
        <p class="text-muted">Mettre à jour les informations du club</p>
    </div>

    {{ include('club/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
</div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .card {
    background: #ffffff;
    transition: all 0.3s ease;
}

.card:hover {
    transform: translateY(-2px);
}

.form-control:focus,
.form-select:focus {
    border-color: #4e73df;
    box-shadow: 0 0 0 0.15rem rgba(78, 115, 223, 0.25);
}

.btn-primary {
    background: linear-gradient(135deg, #4e73df, #224abe);
    border: none;
}

.btn-primary:hover {
    opacity: 0.9;
}

.club-form label {
    margin-bottom: 6px;
}
    </style>
{% endblock %}
