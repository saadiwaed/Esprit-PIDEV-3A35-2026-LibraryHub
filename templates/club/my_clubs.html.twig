{% extends 'frontoffice/navbar.html.twig' %}

{% block body %}
<!-- Page Title START -->
<section class="pt-5 pb-0">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="bg-light p-4 rounded-3">
                    <div class="d-sm-flex align-items-center justify-content-between">
                        <h1 class="h3 mb-0">
                            <i class="bi bi-people-fill me-2"></i>Mes Clubs de Lecture
                        </h1>
                        <div class="mt-2 mt-sm-0">
                            <a href="{{ path('app_club_discover') }}" class="btn btn-primary btn-sm">
                                <i class="bi bi-search me-1"></i>Découvrir des clubs
                            </a>
                            <a href="{{ path('app_club_addformember') }}" class="btn btn-outline-primary btn-sm ms-2">
                                <i class="bi bi-plus-circle me-1"></i>Créer un club
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Page Title END -->

<!-- Clubs list START -->
<section class="pt-4">
    <div class="container">
        {% if clubs is empty %}
        <div class="row">
            <div class="col-12">
                <div class="text-center py-5">
                    <div class="display-1 text-muted mb-3">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3>Vous n'êtes membre d'aucun club</h3>
                    <p class="text-muted mb-4">Rejoignez un club de lecture pour partager vos passions et découvrir de nouveaux livres !</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <a href="{{ path('app_club_discover') }}" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>Découvrir les clubs
                        </a>
                        <a href="{{ path('app_club_addformember') }}" class="btn btn-outline-primary">
                            <i class="bi bi-plus-circle me-1"></i>Créer un club
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="row g-4">
            {% for club in clubs %}
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm hover-lift">
                        <!-- Club Status Banner -->
                        <div class="position-absolute top-0 start-0 m-3 z-index-1">
                            {% if club.status.value == 'active' %}
                                <span class="badge bg-success">Actif</span>
                            {% elseif club.status.value == 'paused' %}
                                <span class="badge bg-warning text-dark">En pause</span>
                            {% elseif club.status.value == 'inactive' %}
                                <span class="badge bg-secondary">Inactif</span>
                            {% elseif club.status.value == 'archived' %}
                                <span class="badge bg-dark">Archivé</span>
                            {% endif %}
                        </div>
                        
                        <!-- Club Cover Image -->
                        <div class="position-relative">
                            {% if club.image %}
                                <img src="{{ asset('uploads/clubs/' ~ club.image) }}" class="card-img-top" alt="{{ club.title }}" style="height: 200px; object-fit: cover;">
                            {% else %}
                                <div class="card-img-top bg-gradient-primary d-flex align-items-center justify-content-center" style="height: 200px; background: linear-gradient(45deg, #0d6efd, #0dcaf0);">
                                    <i class="bi bi-people-fill display-1 text-white"></i>
                                </div>
                            {% endif %}
                            
                            <!-- Founder Badge -->
                            {% if club.founder and club.founder == app.user %}
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-crown-fill me-1"></i>Fondateur
                                    </span>
                                </div>
                            {% else %}
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i>Membre
                                    </span>
                                </div>
                            {% endif %}
                            
                            <!-- Capacity Status -->
                            <div class="position-absolute bottom-0 end-0 m-3">
                                <span class="badge bg-dark bg-opacity-75">
                                    <i class="bi bi-people me-1"></i>
                                    {{ club.members|length }}/{{ club.capacity }}
                                </span>
                            </div>
                        </div>
                        
                        <!-- Card Body -->
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">
                                    <!-- ✅ FIX 1: Supprimé stretched-link qui écrasait tous les clics -->
                                    <a href="{{ path('app_showformember', {'id': club.id}) }}" class="text-decoration-none">
                                        {{ club.title }}
                                    </a>
                                </h5>
                            </div>
                            
                            <p class="card-text text-muted small">
                                {{ club.description|slice(0, 100) ~ '...' }}
                            </p>
                            
                            <!-- Club Info -->
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-tag me-1"></i>{{ club.category }}
                                </span>
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-calendar me-1"></i>{{ club.meetingDate|date('d/m/Y') }}
                                </span>
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-geo-alt me-1"></i>{{ club.meetingLocation|slice(0, 15) ~ '...' }}
                                </span>
                            </div>
                            
                            <!-- Next Event (if any) -->
                            {% set nextEvent = club.nextEvent %}
                            {% if nextEvent %}
                                <div class="mt-3 p-2 bg-primary bg-opacity-10 rounded">
                                    <small class="text-primary">
                                        <i class="bi bi-calendar-event me-1"></i>
                                        Prochain événement: {{ nextEvent.title }} ({{ nextEvent.startDateTime|date('d/m') }})
                                    </small>
                                </div>
                            {% endif %}
                        </div>
                        
                        <!-- Card Footer -->
                        <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                            <div class="d-flex gap-2">
                                <!-- ✅ FIX 2: Ce bouton fonctionne MAINTENANT ! -->
                                <a href="{{ path('app_showformember', {'id': club.id}) }}" class="btn btn-outline-primary btn-sm w-100">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Voir le club
                                </a>
                                {% if club.founder == app.user %}
                                    <a href="{{ path('app_club_edit', {'id': club.id}) }}" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="{{ path('app_club_event_create', {'id': club.id}) }}" class="btn btn-outline-success btn-sm">
                                        <i class="bi bi-calendar-plus"></i>
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>
<!-- Clubs list END -->

<!-- Back to top -->
<div class="back-top">
    <i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <!-- Bootstrap JS -->
    <script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>
    <!-- Vendors -->
    <script src="{{ asset('assets/vendor/tiny-slider/tiny-slider.js') }}"></script>
    <script src="{{ asset('assets/vendor/glightbox/js/glightbox.js') }}"></script>
    <!-- Template Functions -->
    <script src="{{ asset('assets/js/functions.js') }}"></script>
{% endblock %}