{% extends 'base.html.twig' %}

{% block title %}Clubs{% endblock %}

{% block body %}
<!-- =======================
Page Banner START -->
<section class="py-0">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="bg-light p-4 text-center rounded-3">
                    <!-- Header avec actions -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <h2 class="mb-0">Clubs ({{ clubs|length }})</h2>
                <p class="mb-0">Gérez vos clubs de lecture</p>
                
                <!-- Badges de statistiques -->
                <div class="d-flex flex-wrap gap-2 mt-2">
                    <a href="{{ path('app_club_index', app.request.query.all|merge({status: '', category: ''})) }}" 
                       class="badge {% if current_filters.status == '' and current_filters.category == '' %}bg-primary{% else %}bg-secondary{% endif %} text-decoration-none">
                        Tous ({{ clubs|length }})
                    </a>
                    {% for status in all_status %}
                    {% set count = stats[status.value] ?? 0 %}
                    {% if count > 0 %}
                    <a href="{{ path('app_club_index', app.request.query.all|merge({status: status.value})) }}" 
                       class="badge {% if current_filters.status == status.value %}bg-primary{% else %}bg-light text-dark border{% endif %} text-decoration-none">
                        {{ status.getLabel() }} ({{ count }})
                    </a>
                    {% endif %}
                    {% endfor %}
                </div>
            </div>
            <div class="col-md-6 d-md-flex justify-content-md-end">
                <div class="btn-group" role="group">
                    <a href="{{ path('app_club_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Nouveau
                    </a>
                </div>
            </div>
        </div>

                </div>
            </div>
        </div>
    </div>
</section>
<!-- =======================
Page content START -->
<section class="pt-5">
    <div class="container">
        
        <!-- Barre de recherche et filtres -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" action="{{ path('app_club_index') }}" class="row g-3">
                    <!-- Recherche -->
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text" 
                                   name="search" 
                                   class="form-control" 
                                   placeholder="Rechercher par titre, description, catégorie..." 
                                   value="{{ current_filters.search }}">
                        </div>
                    </div>
                    
                    <!-- Filtre par statut -->
                    <div class="col-md-2">
                        <select name="status" class="form-select">
                            <option value="">Tous les statuts</option>
                            {% for status in all_status %}
                            <option value="{{ status.value }}" 
                                    {% if current_filters.status == status.value %}selected{% endif %}>
                                {{ status.getLabel() }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <!-- Filtre par catégorie -->
                    <div class="col-md-2">
                        <select name="category" class="form-select">
                            <option value="">Toutes catégories</option>
                            {% for cat in categories %}
                            <option value="{{ cat }}" 
                                    {% if current_filters.category == cat %}selected{% endif %}>
                                {{ cat }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <!-- Tri -->
                    <div class="col-md-2">
                        <select name="sort" class="form-select">
                            <option value="createdDate" {% if current_filters.sort == 'createdDate' %}selected{% endif %}>
                                Date création
                            </option>
                            <option value="title" {% if current_filters.sort == 'title' %}selected{% endif %}>
                                Titre
                            </option>
                            <option value="meetingDate" {% if current_filters.sort == 'meetingDate' %}selected{% endif %}>
                                Prochaine réunion
                            </option>
                            <option value="capacity" {% if current_filters.sort == 'capacity' %}selected{% endif %}>
                                Capacité
                            </option>
                        </select>
                    </div>
                    
                    <!-- Ordre -->
                    <div class="col-md-2">
                        <select name="order" class="form-select">
                            <option value="desc" {% if current_filters.order == 'desc' %}selected{% endif %}>
                                Plus récent
                            </option>
                            <option value="asc" {% if current_filters.order == 'asc' %}selected{% endif %}>
                                Plus ancien
                            </option>
                        </select>
                    </div>
                    
                    <!-- Boutons -->
                    <div class="col-md-12">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-filter me-1"></i>Filtrer
                            </button>
                            <a href="{{ path('app_club_index') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-1"></i>Réinitialiser
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Liste de cartes -->
        <div class="card shadow">
            <div class="card-body p-0">
                {% if clubs|length > 0 %}
                {% for club in clubs %}
                <!-- Item START -->
                <div class="border-bottom p-4 {% if loop.last %}border-bottom-0{% endif %}">
                    <div class="row g-3 align-items-center">
                        <!-- Image -->
                        <div class="col-md-2">
                            <div class="ratio ratio-1x1 rounded-3 overflow-hidden">
                                {% if club.image %}
                                    <img src="{{ asset('uploads/clubs/' ~ club.image) }}" 
                                         class="img-fluid" 
                                         alt="{{ club.title }}"
                                         style="object-fit: cover;">
                                {% else %}
                                    <div class="bg-light d-flex align-items-center justify-content-center h-100">
                                        <i class="fas fa-users fa-2x text-muted"></i>
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <!-- Détails -->
                        <div class="col-md-6">
                            <h5 class="mb-1">
                                <a href="{{ path('app_club_show', {'id': club.id}) }}" class="text-reset">
                                    {{ club.title }}
                                </a>
                            </h5>
                            <p class="text-truncate-2 mb-2">{{ club.description|slice(0, 150) }}...</p>
                            
                            <!-- Infos -->
                            <div class="d-flex flex-wrap gap-3">
                                <span class="badge bg-info bg-opacity-10 text-info">
                                    <i class="fas fa-tag me-1"></i>{{ club.category }}
                                </span>
                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                    <i class="fas fa-users me-1"></i>{{ club.members|length }}/{{ club.capacity }} membres
                                </span>
                                <span class="badge bg-warning bg-opacity-10 text-warning">
                                    <i class="fas fa-calendar me-1"></i>
                                    {{ club.meetingDate ? club.meetingDate|date('d/m/Y H:i') : 'Date non définie' }}
                                </span>
                                {% if club.isPrivate %}
                                <span class="badge bg-danger bg-opacity-10 text-danger">
                                    <i class="fas fa-lock me-1"></i>Privé
                                </span>
                                {% endif %}
                            </div>
                        </div>

                        <!-- Statut et actions -->
                        <div class="col-md-4">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge 
                                        {% if club.status.value == 'active' %}bg-success
                                        {% elseif club.status.value == 'inactive' %}bg-secondary
                                        {% elseif club.status.value == 'paused' %}bg-warning
                                        {% else %}bg-dark{% endif %} mb-2">
                                        {{ club.status.getLabel() }}
                                    </span>
                                    
                                    <!-- Progression des membres -->
                                    <div class="mb-2">
                                        <small class="text-muted d-block">Membres</small>
                                        <div class="progress" style="height: 6px; width: 100px;">
                                            <div class="progress-bar 
                                                {% if club.members|length < club.capacity/2 %}bg-success
                                                {% elseif club.members|length < club.capacity %}bg-warning
                                                {% else %}bg-danger{% endif %}" 
                                                role="progressbar" 
                                                style="width: {{ (club.members|length / club.capacity * 100)|round }}%">
                                            </div>
                                        </div>
                                        <small class="text-muted">
                                            {{ club.members|length }}/{{ club.capacity }}
                                        </small>
                                    </div>
                                    
                                    <p class="small text-muted mb-0">
                                        Créé le {{ club.createdDate|date('d/m/Y') }}
                                    </p>
                                </div>
                                
                                <!-- Menu d'actions -->
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light rounded-circle" 
                                            type="button" 
                                            data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" 
                                               href="{{ path('app_club_show', {'id': club.id}) }}">
                                                <i class="fas fa-eye me-2"></i>Voir
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" 
                                               href="{{ path('app_club_edit', {'id': club.id}) }}">
                                                <i class="fas fa-edit me-2"></i>Modifier
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" 
                                                  action="{{ path('app_club_delete', {'id': club.id}) }}" 
                                                  onsubmit="return confirm('Supprimer ce club ?')"
                                                  class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ club.id) }}">
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="fas fa-trash me-2"></i>Supprimer
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Item END -->
                {% endfor %}
                {% else %}
                <!-- Aucun club -->
                <div class="text-center py-5">
                    <i class="fas fa-users fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Aucun club trouvé</h4>
                    <p class="text-muted mb-4">
                        {% if current_filters.search or current_filters.status or current_filters.category %}
                            Aucun résultat pour vos critères de recherche.
                            <a href="{{ path('app_club_index') }}" class="text-decoration-none">Afficher tous les clubs</a>
                        {% else %}
                            Commencez par créer votre premier club !
                        {% endif %}
                    </p>
                    <a href="{{ path('app_club_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Créer un club
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
<!-- =======================
Page content END -->
{% endblock %}