{% extends 'frontoffice/navbar.html.twig' %}

{% block title %}{{ club.title }} - Espace Membre{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_my_clubs') }}" class="text-decoration-none">Mes clubs</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ club.title }}</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <!-- Colonne principale -->
        <div class="col-lg-8">
            <!-- En-tête du club -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="h2 mb-2">{{ club.title }}</h1>
                            <div class="d-flex gap-3 text-muted mb-3">
                                <span><i class="bi bi-tag me-1"></i>{{ club.category }}</span>
                                <span><i class="bi bi-people me-1"></i>{{ club.members|length }} membres</span>
                                <span><i class="bi bi-calendar me-1"></i>Créé le {{ club.createdDate|date('d/m/Y') }}</span>
                            </div>
                        </div>
                        <span class="badge bg-{{ club.status.value == 'active' ? 'success' : 'warning' }} px-3 py-2">
                            {{ club.status.getLabel() }}
                        </span>
                    </div>
                    
                    <div class="mt-3">
                        <h6 class="fw-semibold">Description</h6>
                        <p class="text-muted">{{ club.description }}</p>
                    </div>

                    {# Afficher le bouton Modifier seulement pour le fondateur #}
                    {% if club.founder == app.user %}
                        <div class="mt-3 text-end">
                            <a href="{{ path('app_club_edit', {'id': club.id}) }}" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil me-1"></i>Modifier le club
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Informations de réunion -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-semibold mb-4">
                        <i class="bi bi-calendar-event text-primary me-2"></i>
                        Prochaine réunion
                    </h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-3 p-3 me-3">
                                    <i class="bi bi-clock fs-4 text-primary"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Date et heure</small>
                                    <strong>{{ club.meetingDate|date('d/m/Y H:i') }}</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-3 p-3 me-3">
                                    <i class="bi bi-geo-alt fs-4 text-primary"></i>
                                </div>
                                <div>
                                    <small class="text-muted d-block">Lieu</small>
                                    <strong>{{ club.meetingLocation }}</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Événements à venir -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title fw-semibold mb-0">
                            <i class="bi bi-calendar-check text-primary me-2"></i>
                            Événements à venir
                        </h5>
                        
                        {# BOUTON CRÉER - Visible SEULEMENT pour le fondateur #}
                        {% if club.founder == app.user %}
                            <a href="{{ path('app_event_addformember_club', {'clubId': club.id}) }}" class="btn btn-sm btn-primary">
                                <i class="bi bi-plus-circle me-1"></i>Créer un événement
                            </a>
                        {% endif %}
                    </div>
                    
                    {% set upcomingEvents = club.getUpcomingEvents() %}
                    {% if upcomingEvents|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for event in upcomingEvents %}
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">{{ event.title }}</h6>
                                            <small class="text-muted">
                                                <i class="bi bi-calendar me-1"></i>{{ event.startDateTime|date('d/m/Y H:i') }}
                                                <span class="mx-2">•</span>
                                                <i class="bi bi-geo-alt me-1"></i>{{ event.location }}
                                            </small>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-{{ event.status.color ?? 'secondary' }}">
                                                {{ event.status.label }}
                                            </span>
                                            
                                            {# BOUTON SUPPRIMER - Visible SEULEMENT pour le fondateur #}
                                            {% if club.founder == app.user %}
                                                <form method="post" 
                                                      action="{{ path('app_event_delete', {'id': event.id}) }}" 
                                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet événement ?');"
                                                      style="display: inline;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted text-center py-4 mb-0">
                            <i class="bi bi-calendar-x fs-4 d-block mb-2"></i>
                            Aucun événement prévu pour le moment
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Colonne latérale -->
        <div class="col-lg-4">
            <!-- Image du club -->
            {% if club.image %}
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <img src="{{ asset('uploads/clubs/' ~ club.image) }}" 
                         class="card-img-top rounded-top-4" 
                         alt="{{ club.title }}"
                         style="height: 200px; object-fit: cover;">
                </div>
            {% endif %}

            <!-- Fondateur -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-crown text-warning me-2"></i>
                        Fondateur
                    </h6>
                    <div class="d-flex align-items-center">
                        <div class="avatar me-3">
                            {% if club.founder.avatar %}
                                <img src="{{ asset('uploads/avatars/' ~ club.founder.avatar) }}" 
                                     class="rounded-circle" 
                                     width="48" height="48"
                                     style="object-fit: cover;">
                            {% else %}
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                     style="width: 48px; height: 48px;">
                                    {{ club.founder.firstName|slice(0, 1)|upper }}{{ club.founder.lastName|slice(0, 1)|upper }}
                                </div>
                            {% endif %}
                        </div>
                        <div>
                            <strong>{{ club.founder.fullName }}</strong>
                            <br>
                            <small class="text-muted">{{ club.founder.email }}</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Membres -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-people text-primary me-2"></i>
                        Membres ({{ club.members|length }}/{{ club.capacity }})
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        {% for member in club.members|slice(0, 5) %}
                            <div class="d-flex align-items-center">
                                <div class="avatar me-2">
                                    {% if member.avatar %}
                                        <img src="{{ asset('uploads/avatars/' ~ member.avatar) }}" 
                                             class="rounded-circle" 
                                             width="32" height="32"
                                             style="object-fit: cover;">
                                    {% else %}
                                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center"
                                             style="width: 32px; height: 32px; font-size: 12px;">
                                            {{ member.firstName|slice(0, 1)|upper }}{{ member.lastName|slice(0, 1)|upper }}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="flex-grow-1">
                                    <small class="fw-semibold">{{ member.fullName }}</small>
                                </div>
                                {% if member == club.founder %}
                                    <span class="badge bg-warning text-dark">Fondateur</span>
                                {% endif %}
                            </div>
                        {% else %}
                            <p class="text-muted text-center py-3 mb-0">Aucun membre</p>
                        {% endfor %}
                    </div>
                    {% if club.members|length > 5 %}
                        <div class="text-center mt-3">
                            <small class="text-muted">
                                Et {{ club.members|length - 5 }} autre(s) membre(s)
                            </small>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Actions rapides -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-lightning-charge text-primary me-2"></i>
                        Actions rapides
                    </h6>
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_my_clubs') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>
                            Retour à mes clubs
                        </a>
                        
                        {# BOUTONS FONDATEUR #}
                        {% if club.founder == app.user %}
                            <a href="{{ path('app_club_edit', {'id': club.id}) }}" class="btn btn-outline-primary">
                                <i class="bi bi-pencil me-2"></i>
                                Modifier le club
                            </a>
                            
                            {# 📚✅ BOUTON BIBLIOTHÈQUE - Page de recherche de livres #}
                            <a href="{{ path('books_search') }}" 
                               class="btn btn-outline-info mt-2">
                                <i class="bi bi-book-half me-2"></i>
                                Bibliothèque
                            </a>
                            
                            {# 📚✅ BOUTON RECHERCHE PAR CATÉGORIE #}
                            <a href="{{ path('books_search') }}?q={{ club.category|url_encode }}" 
                               class="btn btn-outline-secondary mt-1">
                                <i class="bi bi-tag me-2"></i>
                                Livres "{{ club.category }}"
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            {# 📚✅ CARTE BIBLIOTHÈQUE POUR TOUS LES MEMBRES #}
            {% if app.user and club.isMember(app.user) %}
            <div class="card border-0 shadow-sm rounded-4 mt-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-circle me-3">
                            <i class="bi bi-book-half text-primary fs-5"></i>
                        </div>
                        <h6 class="fw-semibold mb-0">Bibliothèque</h6>
                    </div>
                    
                    <p class="small text-muted mb-3">
                        Recherchez des livres pour votre club de lecture
                    </p>
                    
                    <div class="d-grid gap-2">
                        <a href="{{ path('books_search') }}" 
                           class="btn btn-outline-primary">
                            <i class="bi bi-search me-2"></i>
                            Rechercher un livre
                        </a>
                        
                        <a href="{{ path('books_search') }}?q={{ club.category|url_encode }}" 
                           class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-collection me-1"></i>
                            Explorer "{{ club.category }}"
                        </a>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
.bg-opacity-10 {
    --bs-bg-opacity: 0.1;
}
.avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
}
</style>
{% endblock %}