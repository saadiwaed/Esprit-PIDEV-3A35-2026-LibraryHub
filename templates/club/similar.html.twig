{% extends 'frontoffice/navbar.html.twig' %}

{% block title %}Clubs similaires à {{ club.title }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row mb-4">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_my_clubs') }}">Mes clubs</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_showformember', {'id': club.id}) }}">{{ club.title }}</a></li>
                    <li class="breadcrumb-item active">Clubs similaires</li>
                </ol>
            </nav>
            
            <h1 class="h2 mb-2">🔍 Clubs similaires à "{{ club.title }}"</h1>
            <p class="text-muted">
                Basé sur l'analyse sémantique des descriptions et catégories
            </p>
        </div>
    </div>

    <div class="row">
        {% if similar_clubs is empty %}
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Aucun club similaire trouvé pour le moment.
                </div>
            </div>
        {% else %}
            {% for item in similar_clubs %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title">{{ item.club.title }}</h5>
                                <span class="badge bg-info">{{ item.club.category }}</span>
                            </div>
                            
                            <p class="card-text text-muted small">
                                {{ item.club.description|slice(0, 100) }}...
                            </p>
                            
                            {# Barre de similarité #}
                            <div class="mt-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="text-muted">Similarité</small>
                                    <small class="fw-bold text-primary">{{ item.percentage }}%</small>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-success" 
                                         style="width: {{ item.percentage }}%"></div>
                                </div>
                            </div>
                            
                            <div class="d-flex justify-content-between mt-3 text-muted small">
                                <span><i class="bi bi-people me-1"></i>{{ item.club.members|length }} membres</span>
                                <span><i class="bi bi-calendar me-1"></i>{{ item.club.eventCount }} événements</span>
                            </div>
                        </div>
                        
                        <div class="card-footer bg-transparent">
                            <a href="{{ path('app_showformember', {'id': item.club.id}) }}" 
                               class="btn btn-outline-primary w-100">
                                <i class="bi bi-eye me-2"></i>Voir le club
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
    
    <div class="row mt-4">
        <div class="col text-center">
            <a href="{{ path('app_showformember', {'id': club.id}) }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-2"></i>Retour au club
            </a>
        </div>
    </div>
</div>
{% endblock %}