{% extends 'frontoffice/base_defi.html.twig' %}

{% block title %}💡 Conseil IA - {{ defi.titre }}{% endblock %}

{% block body %}
<!-- BANNER -->
<section class="position-relative py-5" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-20 rounded-3 p-3 me-4">
                            <i class="fas fa-robot fa-3x text-white"></i>
                        </div>
                        <div>
                            <h1 class="display-5 fw-bold text-white mb-2">💡 Conseil IA</h1>
                            <p class="text-white mb-0">Pour ton défi : "{{ defi.titre }}"</p>
                        </div>
                    </div>
                    <a href="{{ path('app_front_defi_show', {'id': defi.id}) }}" class="btn btn-light">
                        <i class="fas fa-arrow-left me-2"></i>Retour au défi
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-5">
                        
                        {% if conseils.succes %}
                            <div class="bg-light p-4 rounded-4">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="bg-warning bg-opacity-10 rounded-2 p-3 me-3">
                                        <i class="fas fa-lightbulb fa-3x text-warning"></i>
                                    </div>
                                    <div>
                                        <h3 class="h4 fw-bold mb-1">🤖 Ton coach personnel</h3>
                                        <p class="text-muted mb-0">Voici des conseils personnalisés</p>
                                    </div>
                                </div>
                                <div class="p-4 bg-white rounded-3">
                                    {{ conseils.contenu|nl2br }}
                                </div>
                            </div>
                        {% else %}
                            <div class="text-center py-5">
                                <p class="text-muted">{{ conseils.message }}</p>
                            </div>
                        {% endif %}
                        
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}