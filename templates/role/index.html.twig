{% extends 'base.html.twig' %}

{% block title %}Roles Management{% endblock %}

{% block body %}
<div class="container-fluid p-4">
        <!-- Title -->
        <div class="row mb-3">
            <div class="col-12 d-sm-flex justify-content-between align-items-center">
                <h1 class="h3 mb-2 mb-sm-0">Roles Management</h1>
                <a href="{{ path('app_role_new') }}" class="btn btn-sm btn-primary mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Create New Role
                </a>
            </div>
        </div>

    <!-- Flash messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Main content centered -->
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <!-- Search Bar -->
            <div class="card bg-transparent border mb-3">
                <div class="card-body">
                    <form method="get" action="{{ path('app_role_index') }}" class="row g-3 align-items-center">
                        <div class="col-md-10">
                            <div class="position-relative">
                                <input type="text" 
                                       name="search" 
                                       id="roleSearch" 
                                       class="form-control" 
                                       placeholder="Search by role name or description..." 
                                       value="{{ app.request.get('search') }}"
                                       autocomplete="off">
                                <div id="searchSuggestions" class="position-absolute w-100 bg-white border rounded shadow-sm" style="display: none; z-index: 1000; max-height: 300px; overflow-y: auto;"></div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-2"></i>Search
                            </button>
                            {% if app.request.get('search') %}
                                <a href="{{ path('app_role_index') }}" class="btn btn-secondary w-100 mt-2">
                                    <i class="bi bi-x-circle me-2"></i>Clear
                                </a>
                            {% endif %}
                        </div>
                    </form>
                </div>
            </div>

            <!-- Card START -->
            <div class="card bg-transparent border">
                <!-- Card body START -->
                <div class="card-body">
                    <!-- Table START -->
                    <div class="table-responsive border-0">
                    <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                        <thead>
                            <tr>
                                <th scope="col" class="border-0 rounded-start">ID</th>
                                <th scope="col" class="border-0">Role Name</th>
                                <th scope="col" class="border-0">Description</th>
                                <th scope="col" class="border-0">Users Count</th>
                                <th scope="col" class="border-0 rounded-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for role in roles %}
                            <tr>
                                <td>{{ role.id }}</td>
                                <td>
                                    <h6 class="mb-0">
                                        <span class="badge bg-primary bg-opacity-10 text-primary">{{ role.name }}</span>
                                    </h6>
                                </td>
                                <td>{{ role.description ?: 'No description' }}</td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info">
                                        {{ role.users|length }} user(s)
                                    </span>
                                </td>
                                <td>
                                    <a href="{{ path('app_role_show', {'id': role.id}) }}" class="btn btn-sm btn-info-soft me-1 mb-1 mb-md-0" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_role_edit', {'id': role.id}) }}" class="btn btn-sm btn-success-soft me-1 mb-1 mb-md-0" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger-soft mb-0" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#deleteModal{{ role.id }}"
                                            title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center">
                                    <div class="py-5">
                                        <i class="bi bi-folder2-open display-4 text-muted"></i>
                                        <p class="mt-3 text-muted">No roles found</p>
                                        <a href="{{ path('app_role_new') }}" class="btn btn-primary">Create First Role</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <!-- Table END -->
            </div>
            <!-- Card body END -->
            
            <!-- Pagination START -->
            {% if totalRoles is defined %}
            <div class="card-footer bg-transparent border-top">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <div class="mb-2 mb-md-0">
                        <small class="text-muted">
                            {% if totalPages is defined and totalPages > 1 %}
                                Showing {{ ((currentPage - 1) * limit) + 1 }} to {{ min(currentPage * limit, totalRoles) }} of {{ totalRoles }} roles
                            {% else %}
                                Total: {{ totalRoles }} role(s)
                            {% endif %}
                        </small>
                    </div>
                    {% if totalPages is defined and totalPages > 1 %}
                    <nav aria-label="Role pagination">
                        <ul class="pagination pagination-sm mb-0">
                            {# Previous button #}
                            <li class="page-item {% if currentPage == 1 %}disabled{% endif %}">
                                {% if currentPage > 1 %}
                                    <a class="page-link" href="{{ path('app_role_index', {'page': currentPage - 1, 'search': search|default('')}) }}" aria-label="Previous">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                {% else %}
                                    <span class="page-link" aria-label="Previous">
                                        <span aria-hidden="true">&laquo;</span>
                                    </span>
                                {% endif %}
                            </li>
                            
                            {# Page numbers #}
                            {% set startPage = max(1, currentPage - 2) %}
                            {% set endPage = min(totalPages, currentPage + 2) %}
                            
                            {% if startPage > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('app_role_index', {'page': 1, 'search': search|default('')}) }}">1</a>
                                </li>
                                {% if startPage > 2 %}
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                {% endif %}
                            {% endif %}
                            
                            {% for page in startPage..endPage %}
                                <li class="page-item {% if page == currentPage %}active{% endif %}">
                                    <a class="page-link" href="{{ path('app_role_index', {'page': page, 'search': search|default('')}) }}">{{ page }}</a>
                                </li>
                            {% endfor %}
                            
                            {% if endPage < totalPages %}
                                {% if endPage < totalPages - 1 %}
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                {% endif %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('app_role_index', {'page': totalPages, 'search': search|default('')}) }}">{{ totalPages }}</a>
                                </li>
                            {% endif %}
                            
                            {# Next button #}
                            <li class="page-item {% if currentPage == totalPages %}disabled{% endif %}">
                                {% if currentPage < totalPages %}
                                    <a class="page-link" href="{{ path('app_role_index', {'page': currentPage + 1, 'search': search|default('')}) }}" aria-label="Next">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                {% else %}
                                    <span class="page-link" aria-label="Next">
                                        <span aria-hidden="true">&raquo;</span>
                                    </span>
                                {% endif %}
                            </li>
                        </ul>
                    </nav>
                    {% endif %}
                </div>
            </div>
            {% endif %}
            <!-- Pagination END -->
        </div>
        <!-- Card END -->

        </div> {# end col-12 col-xl-10 #}
    </div> {# end row justify-content-center #}

    <!-- Delete Modals -->
        {% for role in roles %}
            <div class="modal fade" id="deleteModal{{ role.id }}" tabindex="-1" aria-labelledby="deleteModalLabel{{ role.id }}" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="deleteModalLabel{{ role.id }}">Confirm Delete</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure you want to delete the role <strong>{{ role.name }}</strong>?
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <form method="post" action="{{ path('app_role_delete', {'id': role.id}) }}" style="display: inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ role.id) }}">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('roleSearch');
            const suggestionsDiv = document.getElementById('searchSuggestions');
            let timeoutId;

            searchInput.addEventListener('input', function() {
                clearTimeout(timeoutId);
                const query = this.value.trim();

                if (query.length < 2) {
                    suggestionsDiv.style.display = 'none';
                    return;
                }

                timeoutId = setTimeout(function() {
                    fetch('{{ path('app_role_search') }}?q=' + encodeURIComponent(query))
                        .then(response => response.json())
                        .then(data => {
                            if (data.length === 0) {
                                suggestionsDiv.innerHTML = '<div class="p-2 text-muted">No results found</div>';
                                suggestionsDiv.style.display = 'block';
                            } else {
                                suggestionsDiv.innerHTML = data.map(role => `
                                    <div class="suggestion-item p-2 border-bottom" style="cursor: pointer;" data-name="${role.name}">
                                        <div>
                                            <div class="fw-bold">
                                                <span class="badge bg-primary bg-opacity-10 text-primary">${role.name}</span>
                                            </div>
                                            <small class="text-muted">${role.description || 'No description'} - ${role.usersCount} user(s)</small>
                                        </div>
                                    </div>
                                `).join('');
                                suggestionsDiv.style.display = 'block';

                                document.querySelectorAll('.suggestion-item').forEach(item => {
                                    item.addEventListener('click', function() {
                                        searchInput.value = this.dataset.name;
                                        suggestionsDiv.style.display = 'none';
                                        searchInput.form.submit();
                                    });
                                    
                                    item.addEventListener('mouseenter', function() {
                                        this.style.backgroundColor = '#f8f9fa';
                                    });
                                    
                                    item.addEventListener('mouseleave', function() {
                                        this.style.backgroundColor = '';
                                    });
                                });
                            }
                        })
                        .catch(error => {
                            console.error('Search error:', error);
                            suggestionsDiv.style.display = 'none';
                        });
                }, 300);
            });

            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !suggestionsDiv.contains(e.target)) {
                    suggestionsDiv.style.display = 'none';
                }
            });
        });
    </script>
{% endblock %}
