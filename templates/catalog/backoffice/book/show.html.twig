{% extends 'base.html.twig' %}
{% block title %}{{ book.title }} – Livre{% endblock %}

{% block body %}

<style>

    :root{
        --primary:#3b82f6;
        --bg-soft:#f3f6fb;
        --text-muted:#6b7280;
        --glass:rgba(255,255,255,.65);
    }

    body{
        background:var(--bg-soft);
    }

    /* HERO HEADER */
    .book-hero{
        border-radius:22px;
        background:linear-gradient(135deg,#eef4ff,#f8fbff);
        padding:30px;
        box-shadow:0 20px 45px rgba(0,0,0,.06);
        margin-bottom:30px;
    }

    .book-cover{
        width:260px;
        height:380px;
        object-fit:cover;
        border-radius:18px;
        box-shadow:0 18px 40px rgba(0,0,0,.18);
    }

    /* TITLE AREA */
    .book-title{
        font-size:32px;
        font-weight:700;
        line-height:1.2;
    }

    .book-author{
        font-size:18px;
        color:var(--text-muted);
        margin-top:6px;
    }

    .meta-chip{
        background:white;
        border-radius:12px;
        padding:10px 14px;
        font-weight:600;
        font-size:14px;
        box-shadow:0 6px 18px rgba(0,0,0,.05);
    }

    /* STATUS */
    .status{
        padding:10px 18px;
        border-radius:999px;
        font-weight:600;
        font-size:14px;
    }

    .available{background:#dcfce7;color:#15803d;}
    .borrowed{background:#fee2e2;color:#b91c1c;}
    .reserved{background:#fef3c7;color:#92400e;}
    .maintenance{background:#e5e7eb;color:#374151;}

    /* INFO PANEL */
    .info-panel{
        background:var(--glass);
        backdrop-filter:blur(10px);
        border-radius:20px;
        padding:24px;
        box-shadow:0 12px 30px rgba(0,0,0,.08);
    }

    .info-row{
        display:flex;
        justify-content:space-between;
        padding:12px 0;
        border-bottom:1px solid #eef1f4;
        font-size:15px;
    }

    .info-row:last-child{
        border:none;
    }

    .info-label{
        color:var(--text-muted);
        font-weight:600;
    }

    .info-value{
        font-weight:700;
        color:#111827;
    }

    /* DESCRIPTION */
    .description{
        background:white;
        border-radius:20px;
        padding:28px;
        box-shadow:0 12px 30px rgba(0,0,0,.06);
        line-height:1.8;
        font-size:16px;
    }

    /* QR PANEL */
    .qr-panel{
        position:sticky;
        top:100px;
        border-radius:20px;
        background:white;
        padding:22px;
        text-align:center;
        box-shadow:0 12px 35px rgba(0,0,0,.12);
    }

    .qr-panel img{
        width:190px;
    }

    .action-btn{
        border-radius:999px;
        padding:10px 18px;
        font-weight:600;
    }

</style>

<div class="container py-4">

    <!-- BREADCRUMB -->
    <nav class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path(area ~ '_book_index') }}">Livres</a>
            </li>
            <li class="breadcrumb-item active">
                {{ book.title }}
            </li>
        </ol>
    </nav>

    <!-- HERO -->
    <div class="book-hero">

        <div class="row align-items-center">

            <div class="col-lg-3 text-center">
                {% if book.coverImage %}
                    <img src="{{ asset(book.coverImage) }}" class="book-cover">
                {% else %}
                    <div class="book-cover d-flex align-items-center justify-content-center bg-white">
                        <i class="bi bi-journal-bookmark display-1 text-secondary"></i>
                    </div>
                {% endif %}
            </div>

            <div class="col-lg-9">

                <div class="book-title">{{ book.title }}</div>

                <div class="book-author">
                    <i class="bi bi-person"></i>
                    <a href="{{ path(area ~ '_author_show', { id: book.author.id }) }}" class="text-decoration-none">
                        {{ book.author.fullName }}
                    </a>
                </div>

                <div class="d-flex flex-wrap gap-3 mt-3">

                    <div class="meta-chip">{{ book.category.name }}</div>
                    <div class="meta-chip">{{ book.language|default('—') }}</div>
                    <div class="meta-chip">{{ book.pageCount|default('—') }} pages</div>

                    {% if book.status == 'available' %}
                        <span class="status available">Disponible</span>
                    {% elseif book.status == 'borrowed' %}
                        <span class="status borrowed">Emprunté</span>
                    {% elseif book.status == 'reserved' %}
                        <span class="status reserved">Réservé</span>
                    {% else %}
                        <span class="status maintenance">Maintenance</span>
                    {% endif %}

                </div>

                <div class="mt-4 d-flex gap-3">
                    <a href="{{ path(area ~ '_book_edit', { id: book.id }) }}" class="btn btn-primary action-btn">
                        Modifier
                    </a>
                    {{ include('catalog/backoffice/book/_delete_form.html.twig') }}
                </div>

            </div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="row g-4">

        <!-- DETAILS -->
        <div class="col-lg-8">

            <div class="info-panel mb-4">

                <div class="info-row">
                    <span class="info-label">Éditeur</span>
                    <span class="info-value">{{ book.publisher|default('—') }}</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Année</span>
                    <span class="info-value">{{ book.publicationYear|default('—') }}</span>
                </div>

                <div class="info-row">
                    <span class="info-label">Date d’ajout</span>
                    <span class="info-value">{{ book.createdAt|date('d/m/Y') }}</span>
                </div>

            </div>

            {% if book.description %}
            <div class="description">
                <h4 class="fw-bold mb-3">Description</h4>
                {{ book.description|nl2br }}
            </div>
            {% endif %}

        </div>

        <!-- QR CODE -->
        <div class="col-lg-4">

            <div class="qr-panel">

                <h5 class="fw-bold mb-2">QR Code du livre</h5>

                <img src="{{ qr }}" class="mb-3">

                <div class="text-muted small">
                    Scannez ce code pour afficher les informations du livre directement sur votre téléphone.
                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}
