{{ form_start(form, { attr: { novalidate: 'novalidate', class:'book-form' } }) }}

<style>

    .book-form-card{
        background:white;
        border-radius:24px;
        padding:32px;
        box-shadow:0 18px 55px rgba(0,0,0,.08);
    }

    .section-title{
        font-weight:700;
        font-size:18px;
        margin-bottom:18px;
        color:#111827;
    }

    .form-floating > .form-control,
    .form-floating > .form-select{
        border-radius:12px;
        border:1px solid #e5e7eb;
    }

    .form-control:focus, .form-select:focus{
        border-color:#3b82f6;
        box-shadow:0 0 0 3px rgba(59,130,246,.15);
    }

    .form-error{
        font-size:13px;
        color:#dc2626;
        margin-top:6px;
    }

    /* COVER */
    .cover-box{
        border:2px dashed #d1d5db;
        border-radius:18px;
        padding:24px;
        text-align:center;
        background:#f9fafb;
        transition:.25s;
    }

    .cover-box:hover{
        border-color:#3b82f6;
        background:#f1f5ff;
    }

    .cover-preview{
        width:200px;
        height:280px;
        object-fit:cover;
        border-radius:16px;
        margin-bottom:12px;
        box-shadow:0 12px 30px rgba(0,0,0,.18);
    }

    .status-select{
        font-weight:600;
    }

    .submit-bar{
        border-top:1px solid #eef1f4;
        margin-top:30px;
        padding-top:18px;
        display:flex;
        justify-content:space-between;
        align-items:center;
    }

</style>

<div class="container py-4">

    <div class="book-form-card">

        <!-- ================= COVER + BASIC ================= -->
        <div class="row g-4 mb-4">

            <!-- COVER -->
            <div class="col-lg-4">

                <div class="cover-box">

                    {% if book is defined and book.coverImage %}
                        <img src="{{ asset(book.coverImage) }}" class="cover-preview" id="coverPreview">
                    {% else %}
                        <img src="https://cdn-icons-png.flaticon.com/512/29/29302.png" class="cover-preview" id="coverPreview">
                    {% endif %}

                    <div class="fw-semibold">Couverture du livre</div>
                    <small class="text-muted d-block mb-3">
                        JPG ou PNG recommandé 500x700
                    </small>

                    {{ form_widget(form.coverImageFile, {'attr':{'class':'form-control','onchange':'previewCover(event)'}}) }}
                    <div class="form-error">{{ form_errors(form.coverImageFile) }}</div>

                </div>

            </div>

            <!-- BASIC INFO -->
            <div class="col-lg-8">

                <div class="section-title">Informations générales</div>

                <div class="row g-3">

                    <div class="col-md-6">
                        <div class="form-floating">
                            {{ form_widget(form.category, {'attr':{'class':'form-select'}}) }}
                            {{ form_label(form.category) }}
                        </div>
                        <div class="form-error">{{ form_errors(form.category) }}</div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">
                            {{ form_widget(form.author, {'attr':{'class':'form-select'}}) }}
                            {{ form_label(form.author) }}
                        </div>
                        <div class="form-error">{{ form_errors(form.author) }}</div>
                    </div>

                    <div class="col-12">
                        <div class="form-floating">
                            {{ form_widget(form.title, {'attr':{'class':'form-control','placeholder':'Titre'}}) }}
                            {{ form_label(form.title) }}
                        </div>
                        <div class="form-error">{{ form_errors(form.title) }}</div>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Description</label>
                        {{ form_widget(form.description, {'attr':{'class':'form-control','rows':5}}) }}
                        <div class="form-error">{{ form_errors(form.description) }}</div>
                    </div>

                </div>

            </div>
        </div>

        <!-- ================= PUBLISHING ================= -->
        <div class="section-title">Informations d’édition</div>

        <div class="row g-3 mb-4">

            <div class="col-md-6">
                <div class="form-floating">
                    {{ form_widget(form.publisher, {'attr':{'class':'form-control','placeholder':'Éditeur'}}) }}
                    {{ form_label(form.publisher) }}
                </div>
                <div class="form-error">{{ form_errors(form.publisher) }}</div>
            </div>

            <div class="col-md-3">
                <div class="form-floating">
                    {{ form_widget(form.publicationYear, {'attr':{'class':'form-control','placeholder':'Année'}}) }}
                    {{ form_label(form.publicationYear) }}
                </div>
                <div class="form-error">{{ form_errors(form.publicationYear) }}</div>
            </div>

            <div class="col-md-3">
                <div class="form-floating">
                    {{ form_widget(form.pageCount, {'attr':{'class':'form-control','placeholder':'Pages'}}) }}
                    {{ form_label(form.pageCount) }}
                </div>
                <div class="form-error">{{ form_errors(form.pageCount) }}</div>
            </div>

        </div>

        <!-- ================= AVAILABILITY ================= -->
        <div class="section-title">Disponibilité</div>

        <div class="row g-3 mb-4">

            <div class="col-md-6">
                <div class="form-floating">
                    {{ form_widget(form.language, {'attr':{'class':'form-control','placeholder':'Langue'}}) }}
                    {{ form_label(form.language) }}
                </div>
                <div class="form-error">{{ form_errors(form.language) }}</div>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    {{ form_widget(form.status, {'attr':{'class':'form-select status-select'}}) }}
                    {{ form_label(form.status) }}
                </div>
                <div class="form-error">{{ form_errors(form.status) }}</div>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Date d’ajout</label>
                {{ form_widget(form.createdAt, {'attr':{'class':'form-control'}}) }}
                <div class="form-error">{{ form_errors(form.createdAt) }}</div>
            </div>

        </div>

        <!-- SUBMIT -->
        <div class="submit-bar">
            <div class="text-muted small">
                Vérifiez les informations avant d’enregistrer le livre.
            </div>

            <button class="btn btn-primary px-4 py-2 rounded-pill">
                <i class="bi bi-check-circle"></i>
                {{ button_label|default('Enregistrer le livre') }}
            </button>
        </div>

    </div>

</div>

<script>
function previewCover(event){
    const reader = new FileReader();
    reader.onload = function(){
        document.getElementById('coverPreview').src = reader.result;
    }
    reader.readAsDataURL(event.target.files[0]);
}
</script>

{{ form_end(form) }}
