{% extends 'base.html.twig' %}

{% block title %}
{% if area == 'admin' %}Admin{% else %}Bibliothécaire{% endif %} – Catalogue
{% endblock %}

{% block body %}
<style>

:root{
    --brand:#136da5;
    --brand-soft:#e8f2f8;
    --success-soft:#e9f7ef;
    --info-soft:#eef6ff;
}

/* PAGE */
.dashboard-title{
    font-weight:700;
    letter-spacing:.3px;
}

.subtitle{
    color:#6c757d;
    font-size:.95rem;
}

/* KPI CARD */
.kpi-card{
    border-radius:18px;
    transition:.25s ease;
    background:#fff;
    position:relative;
    overflow:hidden;
}

.kpi-card:hover{
    transform:translateY(-6px);
    box-shadow:0 18px 40px rgba(0,0,0,.08) !important;
}

/* ICON BOX */
.icon-box{
    width:64px;
    height:64px;
    display:flex;
    align-items:center;
    justify-content:center;
    border-radius:16px;
    font-size:1.7rem;
}

/* numbers */
.kpi-number{
    font-size:1.8rem;
    font-weight:700;
}

/* manage link */
.manage-link{
    font-weight:500;
    text-decoration:none;
}

.manage-link i{
    transition:.2s;
}

.manage-link:hover i{
    transform:translateX(4px);
}

/* role badge */
.role-badge{
    font-size:.75rem;
    padding:.35rem .7rem;
    border-radius:999px;
}

</style>

<div class="container-fluid py-4 px-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="dashboard-title mb-1">
                <i class="bi bi-collection me-2 text-primary"></i>
                Catalogue
            </h1>

            <div class="subtitle">
                Gestion des ressources de la bibliothèque
            </div>
        </div>

        <!-- ROLE -->
        <div>
            {% if area == 'admin' %}
                <span class="badge bg-danger-subtle text-danger role-badge">
                    <i class="bi bi-shield-lock me-1"></i> Administrateur
                </span>
            {% else %}
                <span class="badge bg-success-subtle text-success role-badge">
                    <i class="bi bi-person-check me-1"></i> Bibliothécaire
                </span>
            {% endif %}
        </div>

    </div>


    <!-- ALERTS -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}


    <!-- KPI CARDS -->
    <div class="row g-4">

        <!-- CATEGORIES -->
        <div class="col-lg-4 col-md-6">
            <div class="card kpi-card shadow-sm border-0 h-100">
                <div class="card-body d-flex align-items-center">

                    <div class="icon-box bg-primary-subtle text-primary me-3">
                        <i class="bi bi-tags"></i>
                    </div>

                    <div class="flex-grow-1">
                        <div class="text-muted small">Catégories</div>

                        <div class="kpi-number text-primary">
                            {{ categories_count }}
                        </div>

                        <a href="{{ path(area ~ '_category_index') }}" class="manage-link text-primary">
                            Gérer
                            <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>


        <!-- AUTEURS -->
        <div class="col-lg-4 col-md-6">
            <div class="card kpi-card shadow-sm border-0 h-100">
                <div class="card-body d-flex align-items-center">

                    <div class="icon-box bg-success-subtle text-success me-3">
                        <i class="bi bi-person-badge"></i>
                    </div>

                    <div class="flex-grow-1">
                        <div class="text-muted small">Auteurs</div>

                        <div class="kpi-number text-success">
                            {{ authors_count }}
                        </div>

                        <a href="{{ path(area ~ '_author_index') }}" class="manage-link text-success">
                            Gérer
                            <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>


        <!-- LIVRES -->
        <div class="col-lg-4 col-md-6">
            <div class="card kpi-card shadow-sm border-0 h-100">
                <div class="card-body d-flex align-items-center">

                    <div class="icon-box bg-info-subtle text-info me-3">
                        <i class="bi bi-book"></i>
                    </div>

                    <div class="flex-grow-1">
                        <div class="text-muted small">Livres</div>

                        <div class="kpi-number text-info">
                            {{ books_count }}
                        </div>

                        <a href="{{ path(area ~ '_book_index') }}" class="manage-link text-info">
                            Gérer
                            <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>

    </div>

</div>

{% endblock %}
