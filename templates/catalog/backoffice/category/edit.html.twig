{% extends 'base.html.twig' %}
{% block title %}Modifier {{ category.name }}{% endblock %}
{% block body %}
<div class="container-fluid p-4">
    <h1 class="h3 mb-4">Modifier la catégorie</h1>
    <div class="card border-0 shadow-sm" style="max-width: 600px;">
        <div class="card-body">
            {{ include('catalog/backoffice/category/_form.html.twig', { button_label: 'Enregistrer' }) }}
            <a href="{{ path(area ~ '_category_index') }}" class="btn btn-link text-muted mt-2">Retour à la liste</a>
        </div>
    </div>
</div>
{% endblock %}
