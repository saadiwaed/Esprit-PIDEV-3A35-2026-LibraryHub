{% extends 'base.html.twig' %}

{% block title %}Gestion des amendes{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        <!-- Page Header START -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h2><i class="bi bi-exclamation-triangle"></i> Gestion des amendes</h2>
                    <a href="{{ path('penalty_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Nouvelle amende
                    </a>
                </div>
            </div>
        </div>
        <!-- Page Header END -->

        <!-- Flash Messages START -->
        {% if app.flashes %}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'success' ? 'success' : 'warning' }} alert-dismissible fade show" role="alert">
                        {% if type == 'success' %}
                            <i class="bi bi-check-circle"></i>
                        {% else %}
                            <i class="bi bi-exclamation-circle"></i>
                        {% endif %}
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        {% endif %}
        <!-- Flash Messages END -->

        <!-- Penalties Table START -->
        <div class="card shadow-sm">
            <div class="card-body">
                {% set queryParams = app.request.query.all %}
                <form method="get" action="{{ path('penalty_index') }}" class="mb-4">
                    {% for key, value in queryParams %}
                        {% if key not in ['page', 'sortBy'] %}
                            <input type="hidden" name="{{ key }}" value="{{ value }}">
                        {% endif %}
                    {% endfor %}
                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-md-5">
                            <label class="form-label" for="penalty-sort-by">Trier par</label>
                            <select id="penalty-sort-by" name="sortBy" class="form-select">
                                <option value="">-- Ordre par défaut --</option>
                                <option value="member_name_asc" {{ app.request.query.get('sortBy') == 'member_name_asc' ? 'selected' : '' }}>Adhérent (A ↑)</option>
                                <option value="amount_desc" {{ app.request.query.get('sortBy') == 'amount_desc' ? 'selected' : '' }}>Montant (élevé ↓)</option>
                                <option value="issue_desc" {{ app.request.query.get('sortBy') == 'issue_desc' ? 'selected' : '' }}>Date émission (récent ↓)</option>
                                <option value="status_priority" {{ app.request.query.get('sortBy') == 'status_priority' ? 'selected' : '' }}>Statut (impayée > partielle > payée)</option>
                                <option value="waived_last" {{ app.request.query.get('sortBy') == 'waived_last' ? 'selected' : '' }}>Exonérée (en dernier)</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Trier</button>
                        </div>
                    </div>
                </form>
                {% if penalties|length > 0 %}
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="text-muted">
                            Total résultats : {{ totalResults }}
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    {% set dir = sort == 'id' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'id', 'direction': dir})) }}">ID</a></th>
                                    {% set dir = sort == 'loan' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'loan', 'direction': dir})) }}">Emprunt #</a></th>
                                    {% set dir = sort == 'member' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'member', 'direction': dir})) }}">Adhérent</a></th>
                                    {% set dir = sort == 'amount' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'amount', 'direction': dir})) }}">Montant</a></th>
                                    {% set dir = sort == 'reason' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'reason', 'direction': dir})) }}">Raison</a></th>
                                    {% set dir = sort == 'issueDate' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'issueDate', 'direction': dir})) }}">Date émission</a></th>
                                    {% set dir = sort == 'status' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'status', 'direction': dir})) }}">Statut</a></th>
                                    {% set dir = sort == 'waived' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('penalty_index', queryParams|merge({'sort': 'waived', 'direction': dir})) }}">Exonéré</a></th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for penalty in penalties %}
                                    <tr>
                                        <td><strong>#{{ penalty.id }}</strong></td>
                                        <td>
                                            <a href="{{ path('loan_show', {'id': penalty.loan.id}) }}" class="badge bg-secondary">
                                                Emprunt #{{ penalty.loan.id }}
                                            </a>
                                        </td>
                                        <td>{{ penalty.loan.member.fullName }}</td>
                                        <td>
                                            <span class="badge bg-info">{{ penalty.amount|number_format(2, ',', ' ') }} €</span>
                                        </td>
                                        <td>{{ penalty.reason }}</td>
                                        <td>{{ penalty.issueDate ? penalty.issueDate|date('d/m/Y') : '-' }}</td>
                                        <td>
                                            {% if penalty.status.value == 'unpaid' %}
                                                <span class="badge bg-danger">Impayée</span>
                                            {% elseif penalty.status.value == 'paid' %}
                                                <span class="badge bg-success">Payée</span>
                                            {% else %}
                                                <span class="badge bg-warning text-dark">Partielle</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if penalty.waived %}
                                                <i class="bi bi-check-circle-fill text-success"></i> Oui
                                            {% else %}
                                                <i class="bi bi-x-circle-fill text-danger"></i> Non
                                            {% endif %}
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('penalty_show', {'id': penalty.id}) }}" class="btn btn-outline-info" title="View">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a href="{{ path('penalty_edit', {'id': penalty.id}) }}" class="btn btn-outline-warning" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form method="post" action="{{ path('penalty_delete', {'id': penalty.id}) }}" style="display: inline;" onsubmit="return confirm('Supprimer cette amende ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ penalty.id) }}">
                                                    <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% if maxPage > 1 %}
                        <nav aria-label="Page navigation" class="mt-4">
                            <ul class="pagination justify-content-center">
                                {% if currentPage > 1 %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('penalty_index', queryParams|merge({'page': 1})) }}">Première</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('penalty_index', queryParams|merge({'page': currentPage - 1})) }}">Précédente</a>
                                    </li>
                                {% endif %}

                                {% for page in 1..maxPage %}
                                    {% if page == currentPage %}
                                        <li class="page-item active">
                                            <span class="page-link">{{ page }}</span>
                                        </li>
                                    {% else %}
                                        <li class="page-item">
                                            <a class="page-link" href="{{ path('penalty_index', queryParams|merge({'page': page})) }}">{{ page }}</a>
                                        </li>
                                    {% endif %}
                                {% endfor %}

                                {% if currentPage < maxPage %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('penalty_index', queryParams|merge({'page': currentPage + 1})) }}">Suivante</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('penalty_index', queryParams|merge({'page': maxPage})) }}">Dernière</a>
                                    </li>
                                {% endif %}
                            </ul>
                        </nav>
                    {% endif %}
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="text-muted mt-3">Aucune amende trouvée. <a href="{{ path('penalty_new') }}">Créer une amende</a></p>
                    </div>
                {% endif %}
            </div>
        </div>
        <!-- Penalties Table END -->
    </div>
{% endblock %}
