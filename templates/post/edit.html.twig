{% extends 'base.html.twig' %}

{% block title %}Administration - Modifier post{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <div class="mb-4">
        <h1 class="h3 mb-1">Modifier {{ post.title }}</h1>
        <p class="text-muted mb-0">Mettez a jour le contenu et les options du post.</p>
    </div>

    {{ include('post/_form.html.twig', {form: form}) }}

    {% if post.attachments|length > 0 %}
        <div class="card shadow-sm mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="h6 mb-0">Pieces jointes existantes</h2>
                <span class="badge bg-secondary">{{ post.attachments|length }}</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    {% for attachment in post.attachments %}
                        <div class="col-md-4 col-lg-3">
                            <div class="border rounded p-3 h-100 text-center">
                                <p class="small mb-2 text-break">{{ attachment.getDisplayName() }}</p>
                                <a href="{{ asset('uploads/attachments/' ~ attachment.filePath) }}" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-primary mb-2">Ouvrir</a>
                                <form method="post" action="{{ path('app_attachment_delete', {'postId': post.id, 'attachmentId': attachment.id}) }}" onsubmit="return confirm('Supprimer cette piece jointe ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_attachment' ~ attachment.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    <div class="d-flex justify-content-between align-items-center mt-4">
        <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-light">Retour au detail</a>
        {{ include('post/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
