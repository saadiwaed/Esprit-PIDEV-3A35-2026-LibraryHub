{% extends 'base.html.twig' %}

{% block title %}Modifier le Post{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Modifier : {{ post.title }}</h1>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}

        <table class="table table-bordered">
            <tr>
                <td>{{ form_label(form.title) }}</td>
                <td>{{ form_widget(form.title) }}</td>
                <td>{{ form_errors(form.title) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.content) }}</td>
                <td>{{ form_widget(form.content) }}</td>
                <td>{{ form_errors(form.content) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.community) }}</td>
                <td>{{ form_widget(form.community) }}</td>
                <td>{{ form_errors(form.community) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.status) }}</td>
                <td>{{ form_widget(form.status) }}</td>
                <td>{{ form_errors(form.status) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.externalUrl) }}</td>
                <td>{{ form_widget(form.externalUrl) }}</td>
                <td>{{ form_errors(form.externalUrl) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.attachmentFiles, 'Ajouter des fichiers') }}</td>
                <td>{{ form_widget(form.attachmentFiles) }}</td>
                <td>{{ form_errors(form.attachmentFiles) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.spoilerWarning) }}</td>
                <td>{{ form_widget(form.spoilerWarning) }}</td>
                <td>{{ form_errors(form.spoilerWarning) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.isPinned) }}</td>
                <td>{{ form_widget(form.isPinned) }}</td>
                <td>{{ form_errors(form.isPinned) }}</td>
            </tr>
            <tr>
                <td>{{ form_label(form.allowComments) }}</td>
                <td>{{ form_widget(form.allowComments) }}</td>
                <td>{{ form_errors(form.allowComments) }}</td>
            </tr>
        </table>

        {# ─── Existing Attachments Section ─────────────────── #}
        {% if post.attachments|length > 0 %}
            <h4 class="mt-4">Pièces jointes existantes ({{ post.attachments|length }})</h4>
            <div class="row">
                {% for attachment in post.attachments %}
                    <div class="col-md-3 mb-3">
                        <div class="card">
                            <div class="card-body text-center">
                                {% if attachment.isImage() %}
                                    <img src="{{ asset('uploads/attachments/' ~ attachment.filePath) }}"
                                         class="img-fluid rounded mb-2"
                                         alt="{{ attachment.getDisplayName() }}"
                                         style="max-height: 120px; object-fit: cover;">
                                {% elseif attachment.isPdf() %}
                                    <i class="fas fa-file-pdf fa-3x text-danger mb-2"></i>
                                {% else %}
                                    <i class="fas fa-file fa-3x text-secondary mb-2"></i>
                                {% endif %}

                                <p class="card-text small text-truncate" title="{{ attachment.getDisplayName() }}">
                                    {{ attachment.getDisplayName() }}
                                </p>

                                {# Delete individual attachment #}
                                <form method="post"
                                      action="{{ path('app_attachment_delete', {'postId': post.id, 'attachmentId': attachment.id}) }}"
                                      onsubmit="return confirm('Supprimer cette pièce jointe ?');"
                                      style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_attachment' ~ attachment.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i> Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="mt-3">
            {{ form_widget(form.save) }}
            <a href="{{ path('app_post_index') }}" class="btn btn-secondary">Retour à la liste</a>
        </div>

        {{ form_end(form) }}

        <hr>

        {{ include('post/_delete_form.html.twig') }}
    </div>

    <style>
        table { width: 100%; border-collapse: collapse; }
        td { padding: 10px; border: 1px solid #ddd; vertical-align: top; }
        td:first-child { width: 200px; font-weight: bold; background-color: #f8f9fa; }
        .form-control, .form-select { width: 100%; padding: 8px; border: 1px solid #ced4da; border-radius: 4px; }
        .form-check-input { margin-top: 5px; }
        li { color: #dc3545; font-size: 0.9em; list-style: none; }
    </style>
{% endblock %}