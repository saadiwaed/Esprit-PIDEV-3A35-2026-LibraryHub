{% extends 'base.html.twig' %}

{% block title %}Administration - Posts{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Posts</h1>
            <p class="text-muted mb-0">Gestion des discussions de toutes les communautes.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_post_moderation_queue') }}" class="btn btn-outline-danger">
                <i class="fas fa-flag me-1"></i> Moderation
            </a>
            <a href="{{ path('app_post_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Nouveau post
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <form method="get" action="{{ path('app_post_index') }}" class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-7">
                    <label for="post-search" class="form-label mb-1">Recherche</label>
                    <input
                        id="post-search"
                        name="q"
                        type="search"
                        class="form-control"
                        placeholder="Titre, contenu ou communaute"
                        value="{{ filters.q }}"
                    >
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <label for="post-sort" class="form-label mb-1">Tri</label>
                    <select id="post-sort" name="sort" class="form-select">
                        <option value="newest" {{ filters.sort == 'newest' ? 'selected' : '' }}>Plus recents</option>
                        <option value="oldest" {{ filters.sort == 'oldest' ? 'selected' : '' }}>Plus anciens</option>
                        <option value="most_commented" {{ filters.sort == 'most_commented' ? 'selected' : '' }}>Plus commentes</option>
                        <option value="most_liked" {{ filters.sort == 'most_liked' ? 'selected' : '' }}>Plus de likes</option>
                        <option value="best_score" {{ filters.sort == 'best_score' ? 'selected' : '' }}>Meilleur score (likes - dislikes)</option>
                        <option value="title_asc" {{ filters.sort == 'title_asc' ? 'selected' : '' }}>Titre A-Z</option>
                        <option value="title_desc" {{ filters.sort == 'title_desc' ? 'selected' : '' }}>Titre Z-A</option>
                    </select>
                </div>
                <div class="col-12 col-md-6 col-lg-2 d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Appliquer</button>
                    {% if filters.q or filters.sort != 'newest' %}
                        <a href="{{ path('app_post_index') }}" class="btn btn-outline-secondary">Reinitialiser</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Auteur</th>
                            <th>Communaute</th>
                            <th>Statut</th>
                            <th>Pinned</th>
                            <th>Commentaires</th>
                            <th>Likes</th>
                            <th>Dislikes</th>
                            <th>Fichiers</th>
                            <th>Creation</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for post in posts %}
                        <tr>
                            <td>#{{ post.id }}</td>
                            <td>
                                <div class="fw-semibold">{{ post.title }}</div>
                                {% if post.spoilerWarning %}
                                    <small class="text-warning">Spoiler</small>
                                {% endif %}
                            </td>
                            <td>{{ post.createdBy ? post.createdBy.fullName : '-' }}</td>
                            <td>
                                {% if post.community %}
                                    <a href="{{ path('app_community_show', {'id': post.community.id}) }}">{{ post.community.name }}</a>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td><span class="badge {{ post.status.getBadgeClass() }}">{{ post.status.getLabel() }}</span></td>
                            <td>{{ post.isPinned ? 'Oui' : 'Non' }}</td>
                            <td>{{ post.commentCount }}</td>
                            <td>{{ post.likeCount }}</td>
                            <td>{{ post.dislikeCount }}</td>
                            <td>{{ post.hasAttachments() ? post.getAttachmentCount() : 0 }}</td>
                            <td>{{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : '-' }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="12" class="text-center text-muted py-4">Aucun post trouve.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
