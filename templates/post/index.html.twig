{% extends 'base.html.twig' %}

{% block title %}Administration - Posts{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Posts</h1>
            <p class="text-muted mb-0">Gestion des discussions de toutes les communautes.</p>
        </div>
        <a href="{{ path('app_post_new') }}" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Nouveau post
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Communaute</th>
                            <th>Statut</th>
                            <th>Pinned</th>
                            <th>Commentaires</th>
                            <th>Fichiers</th>
                            <th>Creation</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for post in posts %}
                        <tr>
                            <td>#{{ post.id }}</td>
                            <td>
                                <div class="fw-semibold">{{ post.title }}</div>
                                {% if post.spoilerWarning %}
                                    <small class="text-warning">Spoiler</small>
                                {% endif %}
                            </td>
                            <td>
                                {% if post.community %}
                                    <a href="{{ path('app_community_show', {'id': post.community.id}) }}">{{ post.community.name }}</a>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td><span class="badge {{ post.status.getBadgeClass() }}">{{ post.status.getLabel() }}</span></td>
                            <td>{{ post.isPinned ? 'Oui' : 'Non' }}</td>
                            <td>{{ post.commentCount }}</td>
                            <td>{{ post.hasAttachments() ? post.getAttachmentCount() : 0 }}</td>
                            <td>{{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : '-' }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">Aucun post trouve.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
