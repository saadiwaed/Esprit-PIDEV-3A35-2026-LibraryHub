{% extends 'base.html.twig' %}

{% block title %}Liste des Posts{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Liste des Posts</h1>
            <a href="{{ path('app_post_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Nouveau Post
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Communauté</th>
                    <th>Statut</th>
                    <th>Épinglé</th>
                    <th>Commentaires</th>
                    <th>Fichiers</th>
                    <th>Créé le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for post in posts %}
                <tr>
                    <td>{{ post.id }}</td>
                    <td>
                        <strong>{{ post.title }}</strong>
                        {% if post.spoilerWarning %}
                            <span class="badge bg-warning text-dark ms-1">⚠ Spoiler</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if post.community %}
                            <a href="{{ path('app_community_show', {'id': post.community.id}) }}">
                                {{ post.community.name }}
                            </a>
                        {% else %}
                            <em class="text-muted">—</em>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge {{ post.status.getBadgeClass() }}">
                            {{ post.status.getLabel() }}
                        </span>
                    </td>
                    <td>{{ post.isPinned ? '📌' : '—' }}</td>
                    <td>{{ post.commentCount }}</td>
                    <td>
                        {% if post.hasAttachments() %}
                            <span class="badge bg-info">{{ post.getAttachmentCount() }}</span>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td>{{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : '' }}</td>
                    <td>
                        <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-sm btn-info">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="9" class="text-center text-muted">Aucun post trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}