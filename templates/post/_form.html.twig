{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
<div class="card shadow-sm">
    <div class="card-body">
        <div
            class="alert alert-info py-2 mb-3"
            data-forum-ai-post
            data-endpoint="{{ path('app_forum_ai_post_draft') }}"
            data-title-id="{{ form.title.vars.id }}"
            data-content-id="{{ form.content.vars.id }}"
            data-community-id="{{ form.community is defined ? form.community.vars.id : '' }}"
        >
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <span><i class="bi bi-stars me-1"></i>Assistant IA: ameliorer le titre et structurer le contenu du post.</span>
                <button type="button" class="btn btn-sm btn-outline-primary" data-ai-action="post-generate">
                    Ameliorer avec IA
                </button>
            </div>
            <div class="small mt-2 text-muted" data-ai-status></div>
        </div>
        <div class="row g-3">
            <div class="col-lg-8">{{ form_row(form.title) }}</div>
            {% if form.community is defined %}
                <div class="col-lg-4">{{ form_row(form.community) }}</div>
            {% endif %}

            <div class="col-12">{{ form_row(form.content) }}</div>

            <div class="col-md-4">{{ form_row(form.status) }}</div>
            <div class="col-md-8">{{ form_row(form.externalUrl) }}</div>

            <div class="col-12">{{ form_row(form.attachmentFiles) }}</div>

            <div class="col-md-4">{{ form_row(form.spoilerWarning) }}</div>
            <div class="col-md-4">{{ form_row(form.isPinned) }}</div>
            <div class="col-md-4">{{ form_row(form.allowComments) }}</div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <a href="{{ path('app_post_index') }}" class="btn btn-light">Annuler</a>
        {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary'}}) }}
    </div>
</div>
{{ form_end(form) }}
