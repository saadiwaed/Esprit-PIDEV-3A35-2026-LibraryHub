{% extends 'frontoffice/base.html.twig' %}

{% block title %}Abonnement - LibraryHub{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                {# Un seul message d'erreur si la redirection Stripe a échoué #}
                {% for type, messages in app.flashes %}
                    {% if type == 'error' and messages|length > 0 %}
                        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                            {{ messages[0] }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                        </div>
                    {% endif %}
                {% endfor %}

                {# Titre #}
                <h1 class="text-center mb-4">S'abonner à LibraryHub</h1>

                {# Carte valeur (accès illimité) #}
                <div class="card border-0 shadow-sm overflow-hidden mb-4 rounded-3">
                    <div class="card-body p-4 p-md-5 position-relative" style="background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 50%, #084298 100%); min-height: 140px;">
                        <div class="position-absolute top-0 end-0 opacity-25 me-4 mt-2">
                            <i class="bi bi-journal-bookmark-fill display-4 text-white"></i>
                        </div>
                        <h2 class="h4 text-white mb-2">Accès illimité à plus d'1 million de livres</h2>
                        <p class="text-white mb-0 opacity-90">Lisez partout, à tout moment, sur tous vos appareils.</p>
                    </div>
                </div>

                {# Choix du parcours #}
                <h3 class="h5 fw-bold mb-2">Choisissez votre parcours de lecture</h3>
                <p class="text-muted small mb-4">Sélectionnez l'offre qui correspond à votre style de vie.</p>

                {# Plans (Mensuel / Annuel) #}
                <div class="mb-4">
                    <div class="form-check card border rounded-3 p-3 mb-3 membership-plan-card" data-plan="monthly">
                        <div class="form-check-label w-100 cursor-pointer d-flex align-items-center justify-content-between" style="cursor: pointer;">
                            <div class="d-flex align-items-center">
                                <input class="form-check-input me-3" type="radio" name="plan" id="planMonthly" value="monthly" autocomplete="off">
                                <div>
                                    <span class="badge bg-secondary bg-opacity-25 text-dark mb-1">FLEXIBLE</span>
                                    <h4 class="h6 mb-0 fw-bold">Offre Mensuelle</h4>
                                    <span class="text-primary fw-semibold">9,99 €/mois</span>
                                </div>
                            </div>
                            <i class="bi bi-journal-plus text-muted fs-4"></i>
                        </div>
                    </div>

                    <div class="form-check card border border-primary rounded-3 p-3 mb-3 membership-plan-card bg-primary bg-opacity-5" data-plan="annual">
                        <div class="form-check-label w-100 cursor-pointer d-flex align-items-center justify-content-between" style="cursor: pointer;">
                            <div class="d-flex align-items-center">
                                <input class="form-check-input me-3" type="radio" name="plan" id="planAnnual" value="annual" checked autocomplete="off">
                                <div>
                                    <span class="badge bg-primary mb-1">MEILLEURE OFFRE – ÉCONOMISEZ 25 %</span>
                                    <h4 class="h6 mb-0 fw-bold">Offre Annuelle</h4>
                                    <span class="text-primary fw-semibold">89,99 €/an</span>
                                </div>
                            </div>
                            <i class="bi bi-journal-stack text-primary fs-4"></i>
                        </div>
                    </div>
                </div>

                {# Récapitulatif sélection #}
                <div class="d-flex align-items-center justify-content-between py-3 px-3 bg-light rounded-3 mb-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-cart3 text-primary me-2 fs-5"></i>
                        <div>
                            <span class="small text-muted d-block">Plan sélectionné</span>
                            <strong id="selectedPlanLabel">Offre Annuelle : 89,99 €/an</strong>
                        </div>
                    </div>
                    <span class="badge bg-primary" id="selectedBadge">SÉLECTIONNÉ</span>
                </div>

                {# Bouton CTA : redirection Stripe Checkout (connexion requise) #}
                <div class="text-center mb-3">
                    {% if app.user %}
                        <a href="{{ path('app_membership_checkout', { plan: 'annual' }) }}" class="btn btn-primary btn-lg rounded-3 px-5" id="btnSubscribe" data-checkout-base="{{ path('app_membership_checkout', { plan: 'monthly' }) }}">
                            Continuer vers le paiement
                        </a>
                        <p class="small text-muted mt-2 mb-0">Vous serez redirigé vers Stripe pour payer en toute sécurité.</p>
                    {% else %}
                        <a href="{{ path('app_login', {_target_path: path('app_membership_index')}) }}" class="btn btn-primary btn-lg rounded-3 px-5">
                            Se connecter pour s'abonner
                        </a>
                    {% endif %}
                </div>
                <p class="text-center small text-muted mb-4">
                    L'abonnement se renouvelle automatiquement sauf annulation au moins 24 h avant la fin de la période en cours.
                </p>

                {# Confiance / Sécurité #}
                <div class="text-center small text-muted mb-4">
                    <i class="bi bi-shield-lock me-2"></i>
                    <i class="bi bi-credit-card me-2"></i>
                    <i class="bi bi-check2-circle me-2"></i>
                    <span>Paiement sécurisé. Annulez à tout moment.</span>
                </div>

                {# Liens footer #}
                <div class="text-center">
                    <a href="#" class="small text-muted text-decoration-none me-3">Restaurer un achat</a>
                    <a href="#" class="small text-muted text-decoration-none me-3">Conditions d'utilisation</a>
                    <a href="#" class="small text-muted text-decoration-none">Politique de confidentialité</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var planMonthly = document.getElementById('planMonthly');
    var planAnnual = document.getElementById('planAnnual');
    var selectedPlanLabel = document.getElementById('selectedPlanLabel');
    var cards = document.querySelectorAll('.membership-plan-card');

    function updateSelection() {
        var isAnnual = planAnnual.checked;
        selectedPlanLabel.textContent = isAnnual ? 'Offre Annuelle : 89,99 €/an' : 'Offre Mensuelle : 9,99 €/mois';
        cards.forEach(function(card) {
            var selected = (isAnnual && card.dataset.plan === 'annual') || (!isAnnual && card.dataset.plan === 'monthly');
            card.classList.toggle('border-primary', selected);
            card.classList.toggle('bg-primary', selected);
            card.classList.toggle('bg-opacity-10', selected);
        });
    }

    planMonthly.addEventListener('change', updateSelection);
    planAnnual.addEventListener('change', updateSelection);
    cards.forEach(function(card) {
        card.addEventListener('click', function(e) {
            if (!e.target.closest('input')) {
                var radio = card.querySelector('input[type="radio"]');
                if (radio) { radio.checked = true; updateSelection(); }
            }
        });
    });

    var btnSubscribe = document.getElementById('btnSubscribe');
    if (btnSubscribe) {
        var fullHref = btnSubscribe.getAttribute('data-checkout-base') || btnSubscribe.getAttribute('href') || '';
        var baseUrl = fullHref.replace(/\/(monthly|annual)\s*$/, '/');
        function updateCheckoutHref() {
            var plan = planAnnual && planAnnual.checked ? 'annual' : 'monthly';
            btnSubscribe.setAttribute('href', baseUrl + plan);
        }
        if (baseUrl) {
            planMonthly.addEventListener('change', updateCheckoutHref);
            planAnnual.addEventListener('change', updateCheckoutHref);
            updateCheckoutHref();
        }
    }
});
</script>
{% endblock %}
