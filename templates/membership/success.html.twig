{% extends 'frontoffice/base.html.twig' %}

{% block title %}Merci pour votre abonnement - LibraryHub{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success display-1"></i>
                </div>
                <h1 class="mb-3">Merci pour votre abonnement</h1>
                <p class="lead text-muted mb-4">
                    Votre abonnement <strong>{{ plan_label }}</strong> est confirmé. Votre compte est maintenant <strong>premium</strong> : vous avez accès complet à LibraryHub.
                </p>
                <a href="{{ path('app_frontoffice') }}" class="btn btn-primary btn-lg rounded-3">Retour à l'accueil</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
