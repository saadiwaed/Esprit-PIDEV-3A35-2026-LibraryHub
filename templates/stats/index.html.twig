{% extends 'base.html.twig' %}

{% block title %}Statistiques{% endblock %}

{% block body %}
    {% form_theme filterForm 'bootstrap_5_layout.html.twig' %}

    <div class="container-fluid p-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
            <div>
                <h2 class="mb-1"><i class="bi bi-graph-up"></i> Statistiques Globales</h2>
                <div class="text-muted">Derniere mise Ã  jour : {{ lastUpdate|date('d/m/Y H:i') }}</div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body py-2">
                    {{ form_start(filterForm, { method: 'GET', action: path('app_stats_index') }) }}
                    <div class="d-flex flex-wrap gap-2 align-items-end">
                        <div>
                            {{ form_row(filterForm.dateFrom) }}
                        </div>
                        <div>
                            {{ form_row(filterForm.dateTo) }}
                        </div>
                        <div>
                            <button class="btn btn-primary">Filtrer</button>
                        </div>
                        <div>
                            <a href="{{ path('app_stats_index') }}" class="btn btn-outline-secondary">Reinitialiser</a>
                        </div>
                    </div>
                    {{ form_end(filterForm) }}
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-muted">Total des prets</div>
                            <i class="bi bi-book fs-4 text-primary"></i>
                        </div>
                        <div class="display-6 fw-semibold">{{ loanCounts.total }}</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-muted">Prets actifs</div>
                            <i class="bi bi-hourglass-split fs-4 text-primary"></i>
                        </div>
                        <div class="display-6 fw-semibold">{{ loanCounts.active }}</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-muted">Prets en retard</div>
                            <i class="bi bi-exclamation-triangle fs-4 text-warning"></i>
                        </div>
                        <div class="display-6 fw-semibold">{{ loanCounts.overdue }}</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-muted">Prets rendus</div>
                            <i class="bi bi-check-circle fs-4 text-success"></i>
                        </div>
                        <div class="display-6 fw-semibold">{{ loanCounts.returned }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-pie-chart me-2"></i>Repartition des prets</h5>
                        <div class="chart-box">
                            <canvas id="chart-loans-status"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-bar-chart me-2"></i>Prets par mois</h5>
                        <div class="chart-box">
                            <canvas id="chart-loans-monthly"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-arrow-repeat me-2"></i>Renouvellements</h5>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-muted">Total</div>
                                <div class="fs-4 fw-semibold">{{ totalRenewals }}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted">Ce mois / periode</div>
                                <div class="fs-4 fw-semibold">{{ renewalsThisPeriod }}</div>
                            </div>
                            <div class="col-12">
                                <div class="text-muted">Moyenne par prÃªt</div>
                                <div class="fs-4 fw-semibold">{{ averageRenewals|number_format(2, ',', ' ') }}</div>
                            </div>
                            <div class="col-12">
                                <div class="text-muted">PrÃªt le plus renouvele</div>
                                {% if mostRenewedLoan %}
                                    <div class="fw-semibold">
                                        #{{ mostRenewedLoan.id }} - {{ mostRenewedLoan.member.fullName }} ({{ mostRenewedLoan.renewalCount }} renouv.)
                                    </div>
                                {% else %}
                                    <div class="text-muted">Aucun prÃªt renouvele.</div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-currency-dollar me-2"></i>Amendes</h5>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-muted">Total amendes</div>
                                <div class="fs-4 fw-semibold">{{ totalPenalties }}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted">Ce mois / periode</div>
                                <div class="fs-4 fw-semibold">{{ penaltiesThisPeriod }}</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted">Montant impaye</div>
                                <div class="fs-4 fw-semibold">{{ totalDue|number_format(2, ',', ' ') }} â‚¬</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted">Montant paye</div>
                                <div class="fs-4 fw-semibold">{{ totalPaid|number_format(2, ',', ' ') }} â‚¬</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted">Montant annule</div>
                                <div class="fs-4 fw-semibold">{{ totalWaived|number_format(2, ',', ' ') }} â‚¬</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted">Montant moyen</div>
                                <div class="fs-4 fw-semibold">{{ averagePenalty|number_format(2, ',', ' ') }} â‚¬</div>
                            </div>
                        </div>
                        <div class="mt-3 chart-box">
                            <canvas id="chart-penalty-amounts"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12 col-lg-7">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-graph-up-arrow me-2"></i>Evolution des amendes</h5>
                        <div class="chart-box">
                            <canvas id="chart-penalties-monthly"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-info-circle me-2"></i>Indicateurs prets</h5>
                        <div class="mb-3">
                            <div class="text-muted">{{ periodLabel }}</div>
                            <div class="fs-4 fw-semibold">{{ periodCount }}</div>
                        </div>
                        <div class="mb-3">
                            <div class="text-muted">Duree moyenne (jours)</div>
                            <div class="fs-4 fw-semibold">{{ averageDuration|number_format(1, ',', ' ') }}</div>
                        </div>
                        <div class="mb-3">
                            <div class="text-muted">Livre le plus emprunte</div>
                            {% if mostBorrowed %}
                                <div class="fw-semibold">Exemplaire #{{ mostBorrowed.bookCopyId }} ({{ mostBorrowed.loanCount }} prets)</div>
                            {% else %}
                                <div class="text-muted">Aucune donnee disponible.</div>
                            {% endif %}
                        </div>
                        <div>
                            <div class="text-muted">Top 5 membres</div>
                            {% if topMembers is not empty %}
                                <ul class="list-group list-group-flush">
                                    {% for member in topMembers %}
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <span>{{ member.firstName }} {{ member.lastName }}</span>
                                            <span class="badge bg-primary rounded-pill">{{ member.loanCount }}</span>
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <div class="text-muted">Aucune donnee disponible.</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const chartLoansStatusData = {{ chartLoansStatusData|json_encode|raw }};
        const chartLoansMonthlyData = {{ chartLoansMonthlyData|json_encode|raw }};
        const chartPenaltiesMonthlyData = {{ chartPenaltiesMonthlyData|json_encode|raw }};
        const chartPenaltyAmountsData = {{ chartPenaltyAmountsData|json_encode|raw }};

        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false
        };

        const ctxLoansStatus = document.getElementById('chart-loans-status');
        if (ctxLoansStatus) {
            new Chart(ctxLoansStatus, {
                type: 'pie',
                data: chartLoansStatusData,
                options: commonOptions
            });
        }

        const ctxLoansMonthly = document.getElementById('chart-loans-monthly');
        if (ctxLoansMonthly) {
            new Chart(ctxLoansMonthly, {
                type: 'bar',
                data: chartLoansMonthlyData,
                options: commonOptions
            });
        }

        const ctxPenaltiesMonthly = document.getElementById('chart-penalties-monthly');
        if (ctxPenaltiesMonthly) {
            new Chart(ctxPenaltiesMonthly, {
                type: 'line',
                data: chartPenaltiesMonthlyData,
                options: commonOptions
            });
        }

        const ctxPenaltyAmounts = document.getElementById('chart-penalty-amounts');
        if (ctxPenaltyAmounts) {
            new Chart(ctxPenaltyAmounts, {
                type: 'doughnut',
                data: chartPenaltyAmountsData,
                options: commonOptions
            });
        }
    </script>

    <style>
        .chart-box {
            height: 140px;
            max-height: 140px;
        }

        @media (min-width: 992px) {
            .chart-box {
                height: 160px;
                max-height: 160px;
            }
        }
    </style>
{% endblock %}

