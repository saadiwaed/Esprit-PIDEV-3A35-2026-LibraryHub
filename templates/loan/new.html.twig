{% extends 'base.html.twig' %}

{% block title %}Create Loan{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        <!-- Page header START -->
        <div class="row mb-4">
            <div class="col-12">
                <h2><i class="bi bi-plus-circle"></i> Create New Loan</h2>
            </div>
        </div>
        <!-- Page header END -->

        <!-- Form card START -->
        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        {% include 'loan/_form.html.twig' with {'button_label': 'Create Loan'} %}
                    </div>
                </div>

                <!-- Back button -->
                <div class="mt-3">
                    <a href="{{ path('loan_index') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
        <!-- Form card END -->
    </div>
{% endblock %}
