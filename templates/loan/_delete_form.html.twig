<div class="card card-danger">
    <div class="card-header bg-danger">
        <h3 class="card-title text-white">
            <i class="bi bi-exclamation-triangle"></i> Danger Zone
        </h3>
    </div>

    <form method="post" action="{{ path('loan_delete', {'id': loan.id}) }}" onsubmit="return confirm('Are you absolutely sure you want to delete this loan? This action cannot be undone.');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ loan.id) }}">

        <div class="card-body">
            <p class="text-muted">
                Deleting this loan will remove it permanently from the system.
            </p>
        </div>

        <div class="card-footer">
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete Loan
            </button>
        </div>
    </form>
</div>
