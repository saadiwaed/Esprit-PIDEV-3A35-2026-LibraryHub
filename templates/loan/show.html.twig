{% extends 'base.html.twig' %}

{% block title %}Loan #{{ loan.id }}{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h2><i class="bi bi-book"></i> Loan #{{ loan.id }}</h2>
                    <div class="btn-group">
                        {% if loan.returnDate is null and loan.status.value != 'returned' %}
                            <form method="post" action="{{ path('loan_return', {'id': loan.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('return' ~ loan.id) }}">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check2-circle"></i> Marquer comme retourne
                                </button>
                            </form>
                        {% endif %}
                        {% if is_granted('ROLE_LIBRARIAN') and loan.status == constant('App\\Enum\\LoanStatus::OVERDUE') and loan.penalties is empty and latePenaltyForm %}
                            <button
                                type="button"
                                class="btn btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#latePenaltyModal"
                            >
                                <i class="bi bi-exclamation-triangle"></i> Ajouter pénalité ({{ daysLate }} jours de retard)
                            </button>
                        {% elseif loan.penalties is not empty %}
                            <span class="badge bg-info text-dark align-self-center">
                                Pénalité déjà enregistrée ({{ loan.penalties|length }})
                            </span>
                        {% endif %}
                        {% if loan.status.value == 'active' or loan.status.value == 'overdue' %}
                            <a href="{{ path('loan_renew', {'id': loan.id}) }}" class="btn btn-info">
                                <i class="bi bi-arrow-repeat"></i> Renew
                            </a>
                        {% endif %}
                        <a href="{{ path('loan_edit', {'id': loan.id}) }}" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a href="{{ path('loan_index') }}" class="btn btn-secondary">
                            <i class="bi bi-list"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                {% if loan.hasUnpaidPenalty() %}
                    <div class="alert alert-danger">
                        <strong>Penalite impayee :</strong>
                        {{ loan.totalUnpaidPenalty|number_format(2, ',', ' ') }} TND
                    </div>
                {% elseif loan.overdueDays > 0 %}
                    <div class="alert alert-warning">
                        Retard en cours : {{ loan.overdueDays }} jour(s).
                    </div>
                {% endif %}

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">Loan Information</h5>
                            {% if is_granted('ROLE_LIBRARIAN') and loan.status == constant('App\\Enum\\LoanStatus::OVERDUE') and loan.penalties is empty and latePenaltyForm %}
                                <button
                                    type="button"
                                    class="btn btn-warning btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#latePenaltyModal"
                                >
                                    Ajouter pénalité ({{ daysLate }} jours de retard)
                                </button>
                            {% elseif loan.penalties is not empty %}
                                <span class="badge bg-info text-dark">
                                    Pénalité déjà enregistrée ({{ loan.penalties|length }})
                                </span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><strong>Status</strong></label>
                                <p>
                                    {% if loan.status.value == 'active' %}
                                        <span class="badge bg-success p-2">Active</span>
                                    {% elseif loan.status.value == 'returned' %}
                                        <span class="badge bg-secondary p-2">Returned</span>
                                    {% elseif loan.status.value == 'overdue' %}
                                        <span class="badge bg-danger p-2">Overdue</span>
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label"><strong>Nombre de renouvellements</strong></label>
                                <p><span class="badge bg-info">{{ loan.renewalCount }}</span> fois</p>
                                {% if loan.renewalCount > 0 and loan.renewals|last %}
                                    <small class="text-muted">Dernier renouvellement : {{ loan.renewals|last.renewedAt|date('d/m/Y') }}</small>
                                {% endif %}
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><strong>Checkout Time</strong></label>
                            <p>{{ loan.checkoutTime ? loan.checkoutTime|date('d/m/Y H:i:s') : '-' }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label"><strong>Due Date</strong></label>
                                <p>{{ loan.dueDate ? loan.dueDate|date('d/m/Y') : '-' }}</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><strong>Return Date</strong></label>
                                <p>
                                    {% if loan.returnDate %}
                                        {{ loan.returnDate|date('d/m/Y H:i') }}
                                        <span class="badge bg-success ms-2">Retourne</span>
                                    {% else %}
                                        <span class="text-muted">Non retourne</span>
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label"><strong>Retard</strong></label>
                                <p>
                                    {% if loan.isLate %}
                                        <span class="badge bg-warning text-dark">{{ loan.daysLate }} jour(s)</span>
                                    {% else %}
                                        <span class="text-muted">Aucun retard</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>

                        {% if loan.notes %}
                            <div class="mb-3">
                                <label class="form-label"><strong>Notes</strong></label>
                                <div class="bg-light p-3 rounded">{{ loan.notes|nl2br }}</div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0">Member Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label"><strong>Name</strong></label>
                            <p>{{ loan.member.firstName }} {{ loan.member.lastName }}</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label"><strong>Email</strong></label>
                            <p><a href="mailto:{{ loan.member.email }}">{{ loan.member.email }}</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if is_granted('ROLE_LIBRARIAN') and loan.status == constant('App\\Enum\\LoanStatus::OVERDUE') and loan.penalties is empty and latePenaltyForm %}
        <div class="modal fade" id="latePenaltyModal" tabindex="-1" aria-labelledby="latePenaltyModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="latePenaltyModalLabel">Ajouter une pénalité pour retard</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-warning mb-3">
                            <strong>Emprunt #{{ loan.id }}</strong><br>
                            Retard de {{ daysLate }} jour(s).
                        </div>

                        <div class="mb-3 small text-muted">
                            <div><strong>Raison :</strong> {{ latePenaltyReason }}</div>
                            <div><strong>Date d'émission :</strong> {{ latePenaltyIssueDate|date('d/m/Y') }}</div>
                            <div><strong>Statut :</strong> {{ latePenaltyStatus.value|upper }}</div>
                        </div>

                        {{ form_start(latePenaltyForm) }}
                            <input type="hidden" name="loan_id" value="{{ loan.id }}">
                            <input type="hidden" name="reason" value="{{ latePenaltyReason }}">
                            <input type="hidden" name="issue_date" value="{{ latePenaltyIssueDate|date('Y-m-d') }}">
                            <input type="hidden" name="status" value="{{ latePenaltyStatus.value }}">

                            {{ form_row(latePenaltyForm.amount) }}
                            {{ form_row(latePenaltyForm.notes) }}

                            <div class="d-flex gap-2 mt-3">
                                <button type="submit" class="btn btn-danger">
                                    Enregistrer la pénalité
                                </button>
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    Annuler
                                </button>
                            </div>
                        {{ form_end(latePenaltyForm) }}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
