{% extends 'base.html.twig' %}

{% block title %}Loans Management{% endblock %}

{% block body %}
    {% form_theme form 'bootstrap_5_layout.html.twig' %}

    <div class="container-fluid p-4">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h2><i class="bi bi-book"></i> Loans Management</h2>
                    <div class="d-flex gap-2">
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_LIBRARIAN') %}
                            <a href="{{ path('admin_loans_export_pdf', app.request.query.all) }}" class="btn btn-outline-danger">
                                <i class="bi bi-filetype-pdf"></i> Exporter en PDF
                            </a>
                        {% endif %}
                        <a href="{{ path('loan_new') }}" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> New Loan
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {% if app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {% for message in app.flashes('success') %}
                    {{ message }}
                {% endfor %}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}

        {% if app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {% for message in app.flashes('error') %}
                    {{ message }}
                {% endfor %}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                {{ form_start(form, { action: path('loan_index'), method: 'GET' }) }}
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-4">
                        {{ form_row(form.search) }}
                    </div>
                    <div class="col-12 col-md-3">
                        {{ form_row(form.filterType) }}
                    </div>
                    <div class="col-12 col-md-5" id="member-search-field">
                        {{ form_row(form.memberSearch) }}
                    </div>
                    <div class="col-12 col-md-3" id="date-from-field">
                        {{ form_row(form.dateFrom) }}
                    </div>
                    <div class="col-12 col-md-3" id="date-to-field">
                        {{ form_row(form.dateTo) }}
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label" for="loan-sort-by">Trier par</label>
                        <select id="loan-sort-by" name="sortBy" class="form-select">
                            <option value="">-- Ordre par défaut --</option>
                            <option value="member_name_asc" {{ app.request.query.get('sortBy') == 'member_name_asc' ? 'selected' : '' }}>Adhérent (A ↑)</option>
                            <option value="checkout_desc" {{ app.request.query.get('sortBy') == 'checkout_desc' ? 'selected' : '' }}>Date de sortie (récent ↓)</option>
                            <option value="due_asc" {{ app.request.query.get('sortBy') == 'due_asc' ? 'selected' : '' }}>Date limite (proche ↑)</option>
                            <option value="return_desc" {{ app.request.query.get('sortBy') == 'return_desc' ? 'selected' : '' }}>Date de retour (récent ↓)</option>
                            <option value="status_priority" {{ app.request.query.get('sortBy') == 'status_priority' ? 'selected' : '' }}>Statut (retard > actif > rendu)</option>
                            <option value="id_desc" {{ app.request.query.get('sortBy') == 'id_desc' ? 'selected' : '' }}>ID (plus récent ↓)</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-2 d-flex gap-2">
                        {{ form_widget(form.submit, { attr: { class: 'btn btn-primary w-100' } }) }}
                    </div>
                    <div class="col-12 col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-outline-primary w-100">Trier</button>
                    </div>
                    <div class="col-12 col-md-2 d-flex gap-2">
                        <a href="{{ path('loan_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                {% set queryParams = app.request.query.all %}
                {% if loans|length > 0 %}
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="text-muted">
                            Total results: {{ totalResults }}
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    {% set dir = sort == 'id' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('loan_index', queryParams|merge({'sort': 'id', 'direction': dir})) }}">ID</a></th>
                                    {% set dir = sort == 'bookCopy' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('loan_index', queryParams|merge({'sort': 'bookCopy', 'direction': dir})) }}">Exemplaire</a></th>
                                    {% set dir = sort == 'member' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('loan_index', queryParams|merge({'sort': 'member', 'direction': dir})) }}">Adhérent</a></th>
                                    {% set dir = sort == 'checkout' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('loan_index', queryParams|merge({'sort': 'checkout', 'direction': dir})) }}">Date de sortie</a></th>
                                    {% set dir = sort == 'due' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('loan_index', queryParams|merge({'sort': 'due', 'direction': dir})) }}">Date limite</a></th>
                                    {% set dir = sort == 'return' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('loan_index', queryParams|merge({'sort': 'return', 'direction': dir})) }}">Date de retour</a></th>
                                    {% set dir = sort == 'status' and direction == 'asc' ? 'desc' : 'asc' %}
                                    <th><a href="{{ path('loan_index', queryParams|merge({'sort': 'status', 'direction': dir})) }}">Statut</a></th>
                                    <th>Renouvellements</th>
                                    <th>Penalite</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for loan in loans %}
                                    <tr class="{% if loan.status.value == 'overdue' %}table-danger{% endif %}">
                                        <td><strong>#{{ loan.id }}</strong></td>
                                        <td>
                                            <span class="badge bg-info">Copy #{{ loan.bookCopy.id }}</span>
                                        </td>
                                        <td>
                                            {{ loan.member.fullName }}
                                            <br>
                                            <small class="text-muted">{{ loan.member.email }}</small>
                                        </td>
                                        <td>{{ loan.checkoutTime ? loan.checkoutTime|date('d/m/Y H:i') : '-' }}</td>
                                        <td>
                                            <span class="{% if loan.dueDate and loan.dueDate < 'now'|date %}text-danger fw-bold{% endif %}">
                                                {{ loan.dueDate ? loan.dueDate|date('d/m/Y') : '-' }}
                                            </span>
                                        </td>
                                        <td>{{ loan.returnDate ? loan.returnDate|date('d/m/Y H:i') : '-' }}</td>
                                        <td>
                                            {% if loan.status.value == 'returned' %}
                                                <span class="badge bg-success">Rendu</span>
                                            {% elseif loan.status.value == 'overdue' %}
                                                <span class="badge bg-danger">En retard</span>
                                            {% else %}
                                                <span class="badge bg-primary">Actif</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <span class="badge bg-info">{{ loan.renewalCount }} fois</span>
                                        </td>
                                        <td>
                                            {% if loan.hasUnpaidPenalty() %}
                                                <span class="badge bg-danger">{{ loan.totalUnpaidPenalty|number_format(2, ',', ' ') }} TND</span>
                                            {% elseif loan.overdueDays > 0 %}
                                                <span class="badge bg-warning text-dark">Retard: {{ loan.overdueDays }}j</span>
                                            {% else %}
                                                -
                                            {% endif %}
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('loan_show', {'id': loan.id}) }}" class="btn btn-outline-info" title="View">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                {% if loan.status.value == 'active' or loan.status.value == 'overdue' %}
                                                    <a href="{{ path('loan_renew', {'id': loan.id}) }}" class="btn btn-outline-success" title="Renew">
                                                        <i class="bi bi-arrow-repeat"></i>
                                                    </a>
                                                {% endif %}
                                                <a href="{{ path('loan_edit', {'id': loan.id}) }}" class="btn btn-outline-warning" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form method="post" action="{{ path('loan_delete', {'id': loan.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ loan.id) }}">
                                                    <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% if maxPage > 1 %}
                        <nav aria-label="Page navigation" class="mt-4">
                            <ul class="pagination justify-content-center">
                                {% if currentPage > 1 %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('loan_index', queryParams|merge({'page': 1})) }}">Première</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('loan_index', queryParams|merge({'page': currentPage - 1})) }}">Précédente</a>
                                    </li>
                                {% endif %}

                                {% for page in 1..maxPage %}
                                    {% if page == currentPage %}
                                        <li class="page-item active">
                                            <span class="page-link">{{ page }}</span>
                                        </li>
                                    {% else %}
                                        <li class="page-item">
                                            <a class="page-link" href="{{ path('loan_index', queryParams|merge({'page': page})) }}">{{ page }}</a>
                                        </li>
                                    {% endif %}
                                {% endfor %}

                                {% if currentPage < maxPage %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('loan_index', queryParams|merge({'page': currentPage + 1})) }}">Suivante</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('loan_index', queryParams|merge({'page': maxPage})) }}">Dernière</a>
                                    </li>
                                {% endif %}
                            </ul>
                        </nav>
                    {% endif %}
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="text-muted mt-3">No loans found. <a href="{{ path('loan_new') }}">Create one</a></p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filterType = document.getElementById('{{ form.filterType.vars.id }}');
            const memberField = document.getElementById('member-search-field');
            const dateFromField = document.getElementById('date-from-field');
            const dateToField = document.getElementById('date-to-field');

            function toggleFields() {
                const value = filterType ? filterType.value : '';
                const showMember = value === 'member';
                const showDates = value === 'checkout' || value === 'return';

                if (memberField) {
                    memberField.style.display = showMember ? '' : 'none';
                }
                if (dateFromField) {
                    dateFromField.style.display = showDates ? '' : 'none';
                }
                if (dateToField) {
                    dateToField.style.display = showDates ? '' : 'none';
                }
            }

            if (filterType) {
                filterType.addEventListener('change', toggleFields);
                toggleFields();
            }
        });
    </script>
{% endblock %}
