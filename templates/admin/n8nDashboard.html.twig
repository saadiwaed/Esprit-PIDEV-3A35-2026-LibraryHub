{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block body %}
<style>
    .dashboard-container {
        padding: 20px;
        max-width: 1400px;
        margin: 0 auto;
    }
    
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding: 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 10px;
    }
    
    .refresh-info {
        display: flex;
        align-items: center;
        gap: 15px;
        background: rgba(255,255,255,0.2);
        padding: 10px 20px;
        border-radius: 50px;
    }
    
    .refresh-btn {
        background: white;
        color: #667eea;
        border: none;
        padding: 8px 20px;
        border-radius: 50px;
        cursor: pointer;
        font-weight: 600;
        transition: transform 0.2s;
    }
    
    .refresh-btn:hover {
        transform: scale(1.05);
    }
    
    .auto-refresh-badge {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .spinner {
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255,255,255,0.3);
        border-top: 3px solid white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    .report-frame {
        background: white;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        overflow: hidden;
        min-height: 600px;
    }
    
    .report-content {
        padding: 20px;
        background: white;
    }
    
    .last-update {
        text-align: right;
        color: #666;
        font-size: 0.9em;
        margin-top: 10px;
        font-style: italic;
    }
</style>

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>📊 Dashboard Administrateur</h1>
        <div class="refresh-info">
            <div class="auto-refresh-badge">
                <span>🔄 Mise à jour automatique</span>
                <span class="spinner" id="spinner" style="display: none;"></span>
            </div>
            <button class="refresh-btn" onclick="refreshReport()">
                Actualiser maintenant
            </button>
        </div>
    </div>
    
    <div class="report-frame">
        <div class="report-content" id="report-container">
            <div style="text-align: center; padding: 100px;">
                <div class="spinner" style="border-top-color: #667eea; margin: 0 auto 20px;"></div>
                <p>Chargement du rapport...</p>
            </div>
        </div>
    </div>
    
    <div class="last-update" id="last-update">
        Dernière mise à jour: --
    </div>
</div>

<script>
// Fonction pour charger le rapport
function loadReport() {
    const container = document.getElementById('report-container');
    const spinner = document.getElementById('spinner');
    const lastUpdate = document.getElementById('last-update');
    
    spinner.style.display = 'inline-block';
    
    fetch('/api/get-latest-report')
        .then(response => response.json())
        .then(data => {
            container.innerHTML = data.html;
            spinner.style.display = 'none';
            lastUpdate.innerHTML = 'Dernière mise à jour: ' + new Date().toLocaleString('fr-FR');
        })
        .catch(error => {
            console.error('Erreur:', error);
            container.innerHTML = '<div class="alert alert-danger">Erreur lors du chargement du rapport</div>';
            spinner.style.display = 'none';
        });
}

// Fonction pour rafraîchir manuellement
function refreshReport() {
    loadReport();
}

// Auto-refresh toutes les 60 secondes
setInterval(loadReport, 60000);

// Charger au démarrage
document.addEventListener('DOMContentLoaded', loadReport);
</script>
{% endblock %}