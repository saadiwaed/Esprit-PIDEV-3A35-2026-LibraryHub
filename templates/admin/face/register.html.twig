{% extends 'frontoffice/base.html.twig' %}

{% block title %}Enregistrer mon visage - Admin{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/face-api.js@0.22.2/dist/face-api.min.js" defer></script>
    <script src="{{ asset('js/admin-face-register.js') }}" defer></script>
{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <h1 class="h3 mb-2">Sécurité biométrique administrateur</h1>
                {% if app.user and app.user.faceDescriptor %}
                    <div class="alert alert-success mb-3" role="alert">
                        Votre visage est déjà enregistré pour ce compte administrateur.
                        Vous pouvez enregistrer à nouveau si besoin.
                    </div>
                {% else %}
                    <p class="text-muted mb-3">
                        Enregistrez votre visage pour activer la connexion par reconnaissance faciale.
                        Aucune image n'est stockée, uniquement un descripteur numérique.
                    </p>
                {% endif %}

                <div id="face-alert" class="alert d-none" role="alert"></div>

                <div class="mb-3">
                    <button class="btn btn-outline-primary me-2" id="btn-start-webcam">
                        <i class="bi bi-camera-video me-1"></i> Activer la webcam
                    </button>
                    <button class="btn btn-success" id="btn-save-face" disabled>
                        <i class="bi bi-person-bounding-box me-1"></i> Enregistrer mon visage
                    </button>
                </div>

                <div class="border rounded-3 p-3 bg-light">
                    <div class="position-relative mx-auto" style="max-width: 480px;">
                        <video id="face-video" autoplay muted playsinline class="w-100 rounded-3 border"></video>
                        <canvas id="face-canvas" class="position-absolute top-0 start-0"></canvas>
                    </div>
                    <p class="small text-muted mt-3 mb-0">
                        Conseil : placez-vous face à la caméra, dans un environnement bien éclairé, puis regardez droit devant vous
                        avant de cliquer sur <strong>Enregistrer mon visage</strong>.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

