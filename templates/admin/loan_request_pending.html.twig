{% extends 'base.html.twig' %}

{% block title %}Demandes d'emprunt en attente{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}

        <div class="row mb-4">
            <div class="col-12">
                <h1 class="h3 mb-1">Demandes d'emprunt en attente</h1>
                <p class="text-muted mb-0">Validez ou refusez les demandes des membres.</p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Membre</th>
                                <th>Livre</th>
                                <th>Date</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if loanRequests is empty %}
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        Aucune demande en attente.
                                    </td>
                                </tr>
                            {% endif %}

                            {% for loanRequest in loanRequests %}
                                <tr>
                                    <td>#{{ loanRequest.id }}</td>
                                    <td>{{ loanRequest.member ? loanRequest.member.fullName : '-' }}</td>
                                    <td>Livre #{{ loanRequest.book.id }}</td>
                                    <td>{{ loanRequest.requestedAt|date('d/m/Y H:i') }}</td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2">
                                            <form method="post" action="{{ path('admin_loan_request_approve', {id: loanRequest.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ loanRequest.id) }}">
                                                <button type="submit" class="btn btn-sm btn-success">Accepter</button>
                                            </form>
                                            <form method="post" action="{{ path('admin_loan_request_reject', {id: loanRequest.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ loanRequest.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Refuser</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
