{% extends 'base.html.twig' %}

{% block title %}Demandes de renouvellement{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
            <div>
                <h2 class="mb-1"><i class="bi bi-arrow-repeat me-2"></i>Demandes de renouvellement</h2>
                <p class="text-muted mb-0">Validez ou refusez les demandes de renouvellement des membres.</p>
            </div>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label" for="statusFilter">Statut</label>
                        <select id="statusFilter" name="status" class="form-select" onchange="this.form.submit()">
                            {% for key, label in statuses %}
                                <option value="{{ key }}" {% if status == key %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Membre</th>
                                <th>Emprunt</th>
                                <th>Demandée le</th>
                                <th>Statut</th>
                                <th>Suggestion IA</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% if requests is empty %}
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">Aucune demande trouvée.</td>
                            </tr>
                        {% else %}
                            {% for rr in requests %}
                                {% set s = rr.status %}
                                <tr>
                                    <td class="fw-semibold">#{{ rr.id }}</td>
                                    <td>
                                        <div class="fw-semibold">
                                            {{ rr.member ? (rr.member.fullName ?? (rr.member.firstName ~ ' ' ~ rr.member.lastName)) : '—' }}
                                        </div>
                                        <div class="text-muted small">{{ rr.member ? rr.member.email : '' }}</div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold">Emprunt #{{ rr.loan ? rr.loan.id : '—' }}</div>
                                        <div class="text-muted small">
                                            Exemplaire #{{ rr.loan and rr.loan.bookCopy ? rr.loan.bookCopy.id : '—' }}
                                            · Renouvellements : {{ rr.loan ? rr.loan.renewalCount : '—' }}
                                        </div>
                                    </td>
                                    <td>{{ rr.requestedAt ? rr.requestedAt|date('d/m/Y H:i') : '-' }}</td>
                                    <td>
                                        {% if s == 'PENDING' %}
                                            <span class="badge bg-warning text-dark">En attente</span>
                                        {% elseif s == 'APPROVED' %}
                                            <span class="badge bg-success">Approuvée</span>
                                        {% else %}
                                            <span class="badge bg-danger">Refusée</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if s == 'PENDING' %}
                                            {% set ai = aiSuggestions[rr.id] ?? {'recommendation': 'unknown', 'reason': 'Suggestion IA indisponible (erreur interne).', 'confidence': 0} %}

                                            {% if ai.recommendation == 'approve' %}
                                                <span class="badge bg-success" data-bs-toggle="tooltip" data-bs-placement="top" title="{{ ai.reason }}">
                                                    Suggestion IA : Accepter
                                                </span>
                                            {% elseif ai.recommendation == 'refuse' %}
                                                <span class="badge bg-danger" data-bs-toggle="tooltip" data-bs-placement="top" title="{{ ai.reason }}">
                                                    Suggestion IA : Refuser
                                                </span>
                                            {% else %}
                                                <span class="badge bg-secondary" data-bs-toggle="tooltip" data-bs-placement="top" title="{{ ai.reason }}">
                                                    Suggestion IA indisponible
                                                </span>
                                            {% endif %}
                                        {% else %}
                                            <span class="text-muted small">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% if s == 'PENDING' %}
                                            <form method="post" action="{{ path('admin_renewal_request_approve', {'id': rr.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('approve_renewal_request_' ~ rr.id) }}">
                                                <button type="submit" class="btn btn-success btn-sm">Approuver</button>
                                            </form>
                                            <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#rejectModal-{{ rr.id }}">
                                                Refuser
                                            </button>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 d-flex justify-content-center">
                    {{ knp_pagination_render(requests) }}
                </div>
            </div>
        </div>

        {% for rr in requests %}
            {% if rr.status == 'PENDING' %}
                <div class="modal fade" id="rejectModal-{{ rr.id }}" tabindex="-1" aria-labelledby="rejectModalLabel-{{ rr.id }}" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="rejectModalLabel-{{ rr.id }}">Refuser la demande</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                            </div>
                            <form method="post" action="{{ path('admin_renewal_request_reject', {'id': rr.id}) }}">
                                <div class="modal-body">
                                    <p class="mb-3">
                                        Demande #{{ rr.id }} — Emprunt #{{ rr.loan ? rr.loan.id : '—' }}
                                    </p>
                                    <label for="rejectReason-{{ rr.id }}" class="form-label">Motif du refus (optionnel)</label>
                                    <textarea id="rejectReason-{{ rr.id }}" name="reason" class="form-control" rows="4" placeholder="Expliquez brièvement la raison..."></textarea>
                                </div>
                                <div class="modal-footer">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reject_renewal_request_' ~ rr.id) }}">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                                    <button type="submit" class="btn btn-danger">Confirmer le refus</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    </div>
{% endblock %}
