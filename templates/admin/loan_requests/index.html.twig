{% extends 'base.html.twig' %}

{% block title %}Demandes d'emprunt{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
            <div>
                <h2 class="mb-1"><i class="bi bi-hourglass-split me-2"></i>Demandes d'emprunt</h2>
                <p class="text-muted mb-0">Validez ou refusez les demandes d'emprunt des membres.</p>
            </div>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label" for="statusFilter">Statut</label>
                        <select id="statusFilter" name="status" class="form-select" onchange="this.form.submit()">
                            {% for key, label in statuses %}
                                <option value="{{ key }}" {% if status == key %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Membre</th>
                                <th>Livre</th>
                                <th>Date demandée</th>
                                <th>Retour souhaité</th>
                                <th>Date de la demande</th>
                                <th>Statut</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% if requests is empty %}
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">Aucune demande trouvée.</td>
                            </tr>
                        {% else %}
                            {% for lr in requests %}
                                {% set s = lr.status %}
                                <tr>
                                    <td class="fw-semibold">#{{ lr.id }}</td>
                                    <td>
                                        <div class="fw-semibold">
                                            {{ lr.member ? (lr.member.fullName ?? (lr.member.firstName ~ ' ' ~ lr.member.lastName)) : '—' }}
                                        </div>
                                        <div class="text-muted small">{{ lr.member ? lr.member.email : '' }}</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">ID {{ lr.bookId }}</span>
                                    </td>
                                    <td>{{ lr.desiredLoanDate ? lr.desiredLoanDate|date('d/m/Y') : '-' }}</td>
                                    <td>{{ lr.desiredReturnDate ? lr.desiredReturnDate|date('d/m/Y') : '-' }}</td>
                                    <td>{{ lr.requestedAt ? lr.requestedAt|date('d/m/Y H:i') : '-' }}</td>
                                    <td>
                                        {% if s == 'PENDING' %}
                                            <span class="badge bg-warning text-dark">En attente</span>
                                        {% elseif s == 'APPROVED' %}
                                            <span class="badge bg-success">Approuvée</span>
                                        {% else %}
                                            <span class="badge bg-danger">Refusée</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% if s == 'PENDING' %}
                                            <form method="post" action="{{ path('admin_loan_request_approve', {'id': lr.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('approve_loan_request_' ~ lr.id) }}">
                                                <button type="submit" class="btn btn-success btn-sm">
                                                    Approuver
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#rejectModal-{{ lr.id }}">
                                                Refuser
                                            </button>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 d-flex justify-content-center">
                    {{ knp_pagination_render(requests) }}
                </div>
            </div>
        </div>

        {# Modales de refus (avec motif optionnel) #}
        {% for lr in requests %}
            {% if lr.status == 'PENDING' %}
                <div class="modal fade" id="rejectModal-{{ lr.id }}" tabindex="-1" aria-labelledby="rejectModalLabel-{{ lr.id }}" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="rejectModalLabel-{{ lr.id }}">Refuser la demande</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                            </div>
                            <form method="post" action="{{ path('admin_loan_request_reject', {'id': lr.id}) }}">
                                <div class="modal-body">
                                    <p class="mb-3">
                                        Demande #{{ lr.id }} — Membre: <strong>{{ lr.member ? (lr.member.fullName ?? (lr.member.firstName ~ ' ' ~ lr.member.lastName)) : '—' }}</strong>
                                    </p>
                                    <label for="rejectReason-{{ lr.id }}" class="form-label">Motif du refus (optionnel)</label>
                                    <textarea id="rejectReason-{{ lr.id }}" name="reason" class="form-control" rows="4" placeholder="Expliquez brièvement la raison..."></textarea>
                                </div>
                                <div class="modal-footer">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reject_loan_request_' ~ lr.id) }}">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                                    <button type="submit" class="btn btn-danger">Confirmer le refus</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    </div>
{% endblock %}

