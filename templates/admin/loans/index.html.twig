{% extends 'base.html.twig' %}

{% block title %}Emprunts{% endblock %}

{% block body %}
    {% form_theme form 'bootstrap_5_layout.html.twig' %}

    <div class="container-fluid p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
            <div>
                <h2 class="mb-1"><i class="bi bi-journal-check me-2"></i>Emprunts</h2>
                <p class="text-muted mb-0">Liste des emprunts (filtres, tri et export PDF).</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('admin_loans_export_pdf', app.request.query.all) }}" class="btn btn-outline-danger">
                    <i class="bi bi-filetype-pdf"></i> Exporter en PDF
                </a>
            </div>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                {{ form_start(form, { action: path('admin_loans'), method: 'GET' }) }}
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-4">
                        {{ form_row(form.search, { label: 'Mot-clé', attr: { placeholder: 'Nom, email…' } }) }}
                    </div>
                    <div class="col-12 col-md-3">
                        {{ form_row(form.filterType, { label: 'Filtrer par' }) }}
                    </div>
                    <div class="col-12 col-md-5" id="member-search-field">
                        {{ form_row(form.memberSearch, { label: 'Membre', attr: { placeholder: 'Nom du membre…' } }) }}
                    </div>
                    <div class="col-12 col-md-3" id="date-from-field">
                        {{ form_row(form.dateFrom, { label: 'Du' }) }}
                    </div>
                    <div class="col-12 col-md-3" id="date-to-field">
                        {{ form_row(form.dateTo, { label: 'Au' }) }}
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label" for="loan-sort-by">Trier par</label>
                        <select id="loan-sort-by" name="sortBy" class="form-select">
                            <option value="">— Ordre par défaut —</option>
                            <option value="member_name_asc" {{ app.request.query.get('sortBy') == 'member_name_asc' ? 'selected' : '' }}>Membre (A → Z)</option>
                            <option value="checkout_desc" {{ app.request.query.get('sortBy') == 'checkout_desc' ? 'selected' : '' }}>Emprunté le (récent)</option>
                            <option value="due_asc" {{ app.request.query.get('sortBy') == 'due_asc' ? 'selected' : '' }}>Date limite (proche)</option>
                            <option value="return_desc" {{ app.request.query.get('sortBy') == 'return_desc' ? 'selected' : '' }}>Retour (récent)</option>
                            <option value="status_priority" {{ app.request.query.get('sortBy') == 'status_priority' ? 'selected' : '' }}>Statut (retard > actif > rendu)</option>
                            <option value="id_desc" {{ app.request.query.get('sortBy') == 'id_desc' ? 'selected' : '' }}>ID (plus récent)</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-2 d-flex gap-2">
                        {{ form_widget(form.submit, { attr: { class: 'btn btn-primary w-100' }, label: 'Rechercher' }) }}
                    </div>
                    <div class="col-12 col-md-2">
                        <button type="submit" class="btn btn-outline-primary w-100">Appliquer</button>
                    </div>
                    <div class="col-12 col-md-2">
                        <a href="{{ path('admin_loans') }}" class="btn btn-outline-secondary w-100">Réinitialiser</a>
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                {% set queryParams = app.request.query.all %}

                {% if loans|length > 0 %}
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="text-muted">
                            Total : {{ totalResults }}
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Membre</th>
                                <th>Livre</th>
                                <th>Emprunté le</th>
                                <th>Limite</th>
                                <th>Statut</th>
                                <th>Retard</th>
                                <th>Pénalités</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for loan in loans %}
                                {% set isOverdue = loan.status.value == 'overdue' %}
                                <tr class="{% if isOverdue %}table-danger{% endif %}">
                                    <td class="fw-semibold">#{{ loan.id }}</td>
                                    <td>
                                        <div class="fw-semibold">{{ loan.member ? (loan.member.fullName ?? '–') : '–' }}</div>
                                        <div class="text-muted small">{{ loan.member ? (loan.member.email ?? '') : '' }}</div>
                                    </td>
                                    <td>
                                        {% if loan.bookCopy %}
                                            Exemplaire #{{ loan.bookCopy.id }}
                                        {% else %}
                                            –
                                        {% endif %}
                                    </td>
                                    <td>{{ loan.checkoutTime ? loan.checkoutTime|date('d/m/Y') : '–' }}</td>
                                    <td>
                                        <span class="{% if loan.dueDate and loan.dueDate < 'now'|date %}text-danger fw-semibold{% endif %}">
                                            {{ loan.dueDate ? loan.dueDate|date('d/m/Y') : '–' }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if loan.status.value == 'returned' %}
                                            <span class="badge bg-success">Rendu</span>
                                        {% elseif loan.status.value == 'overdue' %}
                                            <span class="badge bg-danger">En retard</span>
                                        {% else %}
                                            <span class="badge bg-primary">Actif</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if loan.daysLate > 0 %}
                                            <span class="badge bg-warning text-dark">{{ loan.daysLate }} j</span>
                                        {% else %}
                                            0 j
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if loan.totalUnpaidPenalty > 0 %}
                                            <span class="badge bg-danger">{{ loan.totalUnpaidPenalty|number_format(2, ',', ' ') }} TND</span>
                                        {% else %}
                                            –
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% if maxPage > 1 %}
                        <nav aria-label="Pagination" class="mt-4">
                            <ul class="pagination justify-content-center">
                                {% if currentPage > 1 %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('admin_loans', queryParams|merge({'page': 1})) }}">Première</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('admin_loans', queryParams|merge({'page': currentPage - 1})) }}">Précédente</a>
                                    </li>
                                {% endif %}

                                {% for page in 1..maxPage %}
                                    {% if page == currentPage %}
                                        <li class="page-item active">
                                            <span class="page-link">{{ page }}</span>
                                        </li>
                                    {% else %}
                                        <li class="page-item">
                                            <a class="page-link" href="{{ path('admin_loans', queryParams|merge({'page': page})) }}">{{ page }}</a>
                                        </li>
                                    {% endif %}
                                {% endfor %}

                                {% if currentPage < maxPage %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('admin_loans', queryParams|merge({'page': currentPage + 1})) }}">Suivante</a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('admin_loans', queryParams|merge({'page': maxPage})) }}">Dernière</a>
                                    </li>
                                {% endif %}
                            </ul>
                        </nav>
                    {% endif %}
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="text-muted mt-3">Aucun emprunt trouvé.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filterType = document.getElementById('{{ form.filterType.vars.id }}');
            const memberField = document.getElementById('member-search-field');
            const dateFromField = document.getElementById('date-from-field');
            const dateToField = document.getElementById('date-to-field');

            function toggleFields() {
                const value = filterType ? filterType.value : '';
                const showMember = value === 'member';
                const showDates = value === 'checkout' || value === 'return';

                if (memberField) memberField.style.display = showMember ? '' : 'none';
                if (dateFromField) dateFromField.style.display = showDates ? '' : 'none';
                if (dateToField) dateToField.style.display = showDates ? '' : 'none';
            }

            if (filterType) {
                filterType.addEventListener('change', toggleFields);
                toggleFields();
            }
        });
    </script>
{% endblock %}

