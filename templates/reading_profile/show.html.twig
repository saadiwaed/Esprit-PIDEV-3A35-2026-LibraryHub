{% extends 'base.html.twig' %}

{% block title %}Reading Profile Details{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0">Reading Profile</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Dashboard</a></li>
                            <li class="breadcrumb-item"><a href="{{ path('app_reading_profile_index') }}">Reading Profiles</a></li>
                            <li class="breadcrumb-item active">{{ reading_profile.user.fullName }}</li>
                        </ol>
                    </nav>
                </div>
                <div>
                    <a href="{{ path('app_reading_profile_edit', {'id': reading_profile.id}) }}" class="btn btn-primary">
                        <i class="bi bi-pencil me-2"></i>Edit
                    </a>
                    <a href="{{ path('app_reading_profile_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Stats Cards -->
        <div class="col-md-4 mb-4">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <i class="bi bi-book fs-1 mb-2"></i>
                    <h2>{{ reading_profile.totalBooksRead }}</h2>
                    <p class="mb-0">Books Read</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <i class="bi bi-calendar-check fs-1 mb-2"></i>
                    <h2>{{ reading_profile.readingGoalPerMonth ?? '-' }}</h2>
                    <p class="mb-0">Monthly Goal</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <i class="bi bi-star-fill fs-1 mb-2"></i>
                    <h2>{{ reading_profile.averageRating ?? '-' }}</h2>
                    <p class="mb-0">Average Rating</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- User Info -->
        <div class="col-lg-4 mb-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">User</h5>
                </div>
                <div class="card-body text-center">
                    {% if reading_profile.user.avatar %}
                        <img src="{{ asset('uploads/avatars/' ~ reading_profile.user.avatar) }}" class="rounded-circle mb-3" width="80" height="80" alt="Avatar">
                    {% else %}
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px; font-size: 1.5rem;">
                            {{ reading_profile.user.firstName|first|upper }}{{ reading_profile.user.lastName|first|upper }}
                        </div>
                    {% endif %}
                    <h5>{{ reading_profile.user.fullName }}</h5>
                    <p class="text-muted mb-2">{{ reading_profile.user.email }}</p>
                    <a href="{{ path('app_user_show', {'id': reading_profile.user.id}) }}" class="btn btn-sm btn-outline-primary">
                        View User Profile
                    </a>
                </div>
            </div>
        </div>

        <!-- Preferences -->
        <div class="col-lg-8 mb-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Reading Preferences</h5>
                </div>
                <div class="card-body">
                    <h6 class="text-muted mb-3">Favorite Genres</h6>
                    <div class="mb-4">
                        {% if reading_profile.favoriteGenres %}
                            {% for genre in reading_profile.favoriteGenres %}
                                <span class="badge bg-info me-1 mb-1 fs-6">{{ genre }}</span>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted">No favorite genres selected</p>
                        {% endif %}
                    </div>

                    <h6 class="text-muted mb-3">Preferred Languages</h6>
                    <div>
                        {% if reading_profile.preferredLanguages %}
                            {% for language in reading_profile.preferredLanguages %}
                                <span class="badge bg-secondary me-1 mb-1 fs-6">{{ language }}</span>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted">No preferred languages selected</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
