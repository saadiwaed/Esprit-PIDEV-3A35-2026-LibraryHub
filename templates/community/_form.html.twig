{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
{% set cancelPath = cancel_path|default(path('app_community_index')) %}
<div class="card shadow-sm">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>
            <div class="col-md-6">{{ form_row(form.contactEmail) }}</div>
            <div class="col-12">{{ form_row(form.description) }}</div>
            <div class="col-12">{{ form_row(form.purpose) }}</div>
            <div class="col-md-6">
                {% set iconGenres = [
                    'General',
                    'Fantasy',
                    'Science-fiction',
                    'Policier',
                    'Romance',
                    'Histoire',
                    'Science',
                    'Poesie',
                    'Jeunesse',
                    'Voyage',
                    'Developpement personnel',
                    'Discussions',
                    'Academique',
                    'Aventure',
                    'Horreur',
                    'Mythologie',
                    'Classiques',
                    'Manga',
                    'Bande dessinee',
                    'Biographie',
                    'Philosophie',
                    'Religion',
                    'Politique',
                    'Economie',
                    'Histoire antique',
                    'Informatique',
                    'Programmation',
                    'Cybersecurite',
                    'Intelligence artificielle',
                    'Mathematiques',
                    'Physique',
                    'Chimie',
                    'Astronomie',
                    'Medecine',
                    'Psychologie',
                    'Droit',
                    'Art',
                    'Musique',
                    'Cinema',
                    'Theatre',
                    'Photographie',
                    'Cuisine',
                    'Nature'
                ] %}
                {% set iconInputId = form.icon.vars.id %}
                {% set iconPreviewId = iconInputId ~ '_preview' %}
                {% set iconCodeId = iconInputId ~ '_preview_code' %}
                {{ form_label(form.icon) }}
                {{ form_widget(form.icon) }}
                {{ form_help(form.icon) }}
                {{ form_errors(form.icon) }}

                <datalist id="community_icon_suggestions">
                    {% for genre in iconGenres %}
                        <option value="{{ genre }}"></option>
                    {% endfor %}
                </datalist>

                <div class="d-flex flex-wrap gap-2 mt-2">
                    {% for genre in iconGenres %}
                        <button type="button" class="btn btn-sm btn-outline-secondary icon-suggestion" data-icon="{{ genre }}">{{ genre }}</button>
                    {% endfor %}
                </div>

                {% set currentIcon = form.vars.data ? form.vars.data.iconClass : 'fas fa-users' %}
                <small class="text-muted d-block mt-1">
                    Apercu: <i id="{{ iconPreviewId }}" class="{{ currentIcon }} me-1"></i><code id="{{ iconCodeId }}">{{ currentIcon }}</code>
                </small>
            </div>
            {% if form.status is defined %}
                <div class="col-md-6">{{ form_row(form.status) }}</div>
            {% endif %}
            <div class="col-12">{{ form_row(form.rules) }}</div>
            <div class="col-12">{{ form_row(form.welcomeMessage) }}</div>
            <div class="col-12">{{ form_row(form.isPublic) }}</div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <a href="{{ cancelPath }}" class="btn btn-light">Annuler</a>
        {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary'}}) }}
    </div>
</div>
{{ form_end(form) }}
<script>
(() => {
    const input = document.getElementById('{{ form.icon.vars.id }}');
    const iconPreview = document.getElementById('{{ form.icon.vars.id }}_preview');
    const iconCode = document.getElementById('{{ form.icon.vars.id }}_preview_code');
    const suggestionButtons = document.querySelectorAll('.icon-suggestion');

    if (!input || !iconPreview || !iconCode) {
        return;
    }

    const normalizeIconClass = (value) => {
        let raw = (value || '').trim();
        if (!raw) {
            return 'fas fa-users';
        }

        const genreToIcon = {
            'general': 'fa-book',
            'fantasy': 'fa-hat-wizard',
            'science-fiction': 'fa-robot',
            'sci-fi': 'fa-robot',
            'policier': 'fa-user-secret',
            'thriller': 'fa-user-secret',
            'romance': 'fa-heart',
            'histoire': 'fa-landmark',
            'science': 'fa-flask',
            'poesie': 'fa-feather-alt',
            'jeunesse': 'fa-child',
            'voyage': 'fa-globe',
            'developpement personnel': 'fa-seedling',
            'discussions': 'fa-comments',
            'academique': 'fa-graduation-cap',
            'aventure': 'fa-map',
            'horreur': 'fa-ghost',
            'mythologie': 'fa-dragon',
            'classiques': 'fa-book-open',
            'manga': 'fa-book-open',
            'bande dessinee': 'fa-book-open',
            'biographie': 'fa-user',
            'philosophie': 'fa-brain',
            'religion': 'fa-praying-hands',
            'politique': 'fa-landmark',
            'economie': 'fa-chart-line',
            'histoire antique': 'fa-monument',
            'informatique': 'fa-laptop-code',
            'programmation': 'fa-code',
            'cybersecurite': 'fa-shield-alt',
            'intelligence artificielle': 'fa-microchip',
            'mathematiques': 'fa-square-root-alt',
            'physique': 'fa-atom',
            'chimie': 'fa-vial',
            'astronomie': 'fa-star',
            'medecine': 'fa-stethoscope',
            'psychologie': 'fa-brain',
            'droit': 'fa-gavel',
            'art': 'fa-palette',
            'musique': 'fa-music',
            'cinema': 'fa-film',
            'theatre': 'fa-theater-masks',
            'photographie': 'fa-camera',
            'cuisine': 'fa-utensils',
            'nature': 'fa-leaf'
        };

        const normalizedGenre = genreToIcon[raw.toLowerCase()];
        if (normalizedGenre) {
            raw = normalizedGenre;
        }

        if (!raw.includes(' ')) {
            if (raw.startsWith('fa-')) {
                return 'fas ' + raw;
            }

            if (raw.startsWith('bi-')) {
                return 'bi ' + raw;
            }
        }

        return raw;
    };

    const updatePreview = () => {
        const normalized = normalizeIconClass(input.value);
        iconPreview.className = normalized + ' me-1';
        iconCode.textContent = normalized;
    };

    suggestionButtons.forEach((button) => {
        button.addEventListener('click', () => {
            input.value = button.dataset.icon || '';
            updatePreview();
            input.focus();
        });
    });

    input.addEventListener('input', updatePreview);
    updatePreview();
})();
</script>
