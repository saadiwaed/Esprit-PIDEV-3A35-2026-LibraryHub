{% extends 'base.html.twig' %}

{% block title %}Liste des Communautés{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Liste des Communautés</h1>
            <a href="{{ path('app_community_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Nouvelle Communauté
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Statut</th>
                    <th>Publique</th>
                    <th>Posts</th>
                    <th>Créée le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for community in communities %}
                <tr>
                    <td>{{ community.id }}</td>
                    <td><strong>{{ community.name }}</strong></td>
                    <td>{{ community.description|length > 50 ? community.description|slice(0, 50) ~ '...' : community.description }}</td>
                    <td>
                        <span class="badge {{ community.status.getBadgeClass() }}">
                            {{ community.status.getLabel() }}
                        </span>
                    </td>
                    <td>{{ community.isPublic ? 'Oui' : 'Non' }}</td>
                    <td>{{ community.postCount }}</td>
                    <td>{{ community.createdAt ? community.createdAt|date('d/m/Y H:i') : '' }}</td>
                    <td>
                        <a href="{{ path('app_community_show', {'id': community.id}) }}" class="btn btn-sm btn-info">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="{{ path('app_community_edit', {'id': community.id}) }}" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="text-center text-muted">Aucune communauté trouvée</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}