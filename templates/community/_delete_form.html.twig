<form method="post" action="{{ path('app_community_delete', {'id': community.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette communauté ?');" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ community.id) }}">
    <button class="btn btn-danger">
        <i class="fas fa-trash me-1"></i> Supprimer
    </button>
</form>