{% use "form_div_layout.html.twig" %}

{% block form_errors %}
    {% if errors|length > 0 %}
        <ul class="form-errors text-danger mb-0 mt-1">
            {% for error in errors %}
                <li class="form-error-message">{{ error.message }}</li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
