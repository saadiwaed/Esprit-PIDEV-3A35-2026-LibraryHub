{% extends 'base.html.twig' %}

{% block title %}Loan Renewals Management{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        <!-- Page header START -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h2><i class="bi bi-arrow-repeat"></i> Loan Renewals Management</h2>
                    <a href="{{ path('loan_index') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Loans
                    </a>
                </div>
            </div>
        </div>
        <!-- Page header END -->

        <!-- Renewals table START -->
        <div class="card shadow-sm">
            <div class="card-body">
                {% if renewals|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Renewal #</th>
                                    <th>Loan ID</th>
                                    <th>Member</th>
                                    <th>Book Copy</th>
                                    <th>Previous Due Date</th>
                                    <th>New Due Date</th>
                                    <th>Renewed At</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for renewal in renewals %}
                                    <tr>
                                        <td><strong>#{{ renewal.renewalNumber }}</strong></td>
                                        <td>
                                            <a href="{{ path('loan_show', {'id': renewal.loan.id}) }}" class="badge bg-primary text-white">
                                                Loan #{{ renewal.loan.id }}
                                            </a>
                                        </td>
                                        <td>
                                            {{ renewal.loan.member.firstName }} {{ renewal.loan.member.lastName }}
                                            <br>
                                            <small class="text-muted">{{ renewal.loan.member.email }}</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-info">Copy #{{ renewal.loan.bookCopy.id }}</span>
                                        </td>
                                        <td>{{ renewal.previousDueDate|date('d/m/Y') }}</td>
                                        <td>
                                            <strong class="text-success">{{ renewal.newDueDate|date('d/m/Y') }}</strong>
                                        </td>
                                        <td>{{ renewal.renewedAt|date('d/m/Y H:i') }}</td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('loan_show', {'id': renewal.loan.id}) }}" class="btn btn-outline-info" title="View Loan">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle"></i> No renewals found.
                    </div>
                {% endif %}
            </div>
        </div>
        <!-- Renewals table END -->
    </div>
{% endblock %}
