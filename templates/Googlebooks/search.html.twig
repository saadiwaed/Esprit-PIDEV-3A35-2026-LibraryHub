{% extends 'frontoffice/navbar.html.twig' %}

{% block title %}Recherche de livres{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="mb-4">📚 Recherche de livres</h1>
    
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('books_search') }}" class="row g-3">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" 
                               name="q" 
                               class="form-control" 
                               placeholder="Titre, auteur, ISBN, mot-clé..."
                               value="{{ query|default('') }}"
                               required>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        Rechercher
                    </button>
                </div>
            </form>
            
            {# CORRECTION ICI : vérifier si error existe #}
            {% if error is defined and error %}
                <div class="alert alert-danger mt-3">{{ error }}</div>
            {% endif %}
        </div>
    </div>
    
    {% if books is defined and books|length > 0 %}
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            {{ books|length }} livre(s) trouvé(s) pour "{{ query }}"
        </div>
        
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for book in books %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="row g-0 h-100">
                        {% if book.image %}
                        <div class="col-md-4 d-flex align-items-center p-3">
                            <img src="{{ book.image }}" 
                                 class="img-fluid rounded-start" 
                                 alt="{{ book.title }}"
                                 style="max-height: 200px; object-fit: contain;">
                        </div>
                        <div class="col-md-8">
                        {% else %}
                        <div class="col-md-12">
                        {% endif %}
                            <div class="card-body">
                                <h5 class="card-title">{{ book.title }}</h5>
                                {% if book.subtitle %}
                                    <h6 class="card-subtitle mb-2 text-muted">{{ book.subtitle }}</h6>
                                {% endif %}
                                
                                <p class="card-text">
                                    <small class="text-muted">
                                        <strong>Auteur(s):</strong> {{ book.authors|join(', ') }}
                                    </small>
                                </p>
                                
                                <p class="card-text">
                                    {{ book.description|slice(0, 150) }}...
                                </p>
                                
                                <div class="mt-3">
                                    {% for category in book.categories|slice(0, 2) %}
                                        <span class="badge bg-secondary me-1">{{ category }}</span>
                                    {% endfor %}
                                    
                                    {% if book.pageCount > 0 %}
                                        <span class="badge bg-info">{{ book.pageCount }} pages</span>
                                    {% endif %}
                                    
                                    {% if book.rating > 0 %}
                                        <span class="badge bg-warning">
                                            ⭐ {{ book.rating }}/5 ({{ book.ratingsCount }})
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="card-footer bg-transparent">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">
                                        {{ book.publishedDate|default('Date inconnue') }}
                                    </small>
                                    <div>
                                        {% if book.isbn %}
                                            <button class="btn btn-sm btn-outline-primary"
                                                    onclick="selectBook('{{ book.isbn|escape('js') }}')">
                                                <i class="fas fa-plus"></i> Sélectionner
                                            </button>
                                        {% endif %}
                                        
                                        {% if book.previewLink %}
                                            <a href="{{ book.previewLink }}" 
                                               target="_blank" 
                                               class="btn btn-sm btn-outline-info ms-1">
                                                <i class="fas fa-external-link-alt"></i> Prévisualiser
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    
    {% elseif query|default('') != '' %}
        {# Si on a fait une recherche mais pas de résultats #}
        <div class="alert alert-warning text-center py-5">
            <i class="fas fa-book-open fa-3x mb-3"></i>
            <h4>Aucun livre trouvé pour "{{ query }}"</h4>
            <p>Essayez avec d'autres termes de recherche.</p>
        </div>
    
    {% else %}
        {# Page d'accueil sans recherche #}
        <div class="text-center py-5 text-muted">
            <i class="fas fa-search fa-4x mb-4"></i>
            <h3>Recherchez un livre</h3>
            <p class="mb-4">Entrez un titre, un auteur, un ISBN ou un mot-clé</p>
            
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Exemples de recherche :</h5>
                            <ul class="list-unstyled">
                                <li><code>Harry Potter</code></li>
                                <li><code>Stephen King</code></li>
                                <li><code>9782070360022</code> (ISBN)</li>
                                <li><code>science fiction</code></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<script>
function selectBook(isbn) {
    if (!confirm('Ajouter ce livre à votre club ?')) {
        return;
    }
    
    fetch('/club/add-book', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ isbn: isbn })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Livre ajouté avec succès !');
        } else {
            alert('Erreur: ' + data.error);
        }
    })
    .catch(error => {
        alert('Erreur de connexion');
        console.error(error);
    });
}
</script>
{% endblock %}