{% extends 'forum_front/layout.html.twig' %}

{% block title %}Nouveau post - {{ community.name }}{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">
                <a href="{{ path('app_front_community_show', {'id': community.id}) }}" class="text-decoration-none small">&larr; Retour a {{ community.name }}</a>
                <h1 class="h3 mt-2 mb-1">Creer un post</h1>
                <p class="text-muted mb-4">Vous publiez dans la communaute <strong>{{ community.name }}</strong>.</p>

                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                <div class="card border shadow-sm">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12">{{ form_row(form.title) }}</div>
                            <div class="col-12">{{ form_row(form.content) }}</div>
                            <div class="col-12">{{ form_row(form.externalUrl) }}</div>
                            <div class="col-12">{{ form_row(form.attachmentFiles) }}</div>
                            <div class="col-md-6">{{ form_row(form.spoilerWarning) }}</div>
                            <div class="col-md-6">{{ form_row(form.allowComments) }}</div>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <a href="{{ path('app_front_community_show', {'id': community.id}) }}" class="btn btn-light">Annuler</a>
                        {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary'}}) }}
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>
{% endblock %}
