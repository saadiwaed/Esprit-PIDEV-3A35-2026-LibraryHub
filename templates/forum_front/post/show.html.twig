{% extends 'forum_front/layout.html.twig' %}

{% block title %}{{ post.title }} - Forum{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        {% for label in ['success', 'warning', 'error'] %}
            {% for message in app.flashes(label) %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">
                <a href="{{ path('app_front_community_show', {'id': post.community.id}) }}" class="text-decoration-none small">&larr; Retour a {{ post.community.name }}</a>

                <article class="card border shadow-sm mt-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h1 class="h3 mb-0">{{ post.title }}</h1>
                            {% if post.spoilerWarning %}
                                <span class="badge bg-warning text-dark">Spoiler</span>
                            {% endif %}
                        </div>

                        <div class="small text-muted mb-3">
                            Publie le {{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : '-' }}
                            par {{ post.createdBy ? post.createdBy.fullName : 'Utilisateur inconnu' }}
                        </div>

                        <div class="mb-4">{{ post.content|nl2br }}</div>

                        {% if post.externalUrl %}
                            <p class="mb-4">
                                <a href="{{ post.externalUrl }}" target="_blank" rel="noreferrer">Lien complementaire</a>
                            </p>
                        {% endif %}

                        <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
                            <form method="post" action="{{ path('app_front_post_react', {'id': post.id, 'type': 'like'}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('react_post_' ~ post.id) }}">
                                <button type="submit" class="btn btn-sm {{ currentPostReaction and currentPostReaction.value == 'like' ? 'btn-primary' : 'btn-outline-primary' }}" {{ isMember ? '' : 'disabled' }}>
                                    <i class="bi bi-hand-thumbs-up me-1"></i>Like ({{ post.likeCount }})
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_front_post_react', {'id': post.id, 'type': 'dislike'}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('react_post_' ~ post.id) }}">
                                <button type="submit" class="btn btn-sm {{ currentPostReaction and currentPostReaction.value == 'dislike' ? 'btn-danger' : 'btn-outline-danger' }}" {{ isMember ? '' : 'disabled' }}>
                                    <i class="bi bi-hand-thumbs-down me-1"></i>Dislike ({{ post.dislikeCount }})
                                </button>
                            </form>
                            <span class="badge bg-light text-dark border">Score: {{ post.score }}</span>
                        </div>

                        <h2 class="h6">Pieces jointes</h2>
                        {% if post.hasAttachments() %}
                            <ul class="list-group list-group-flush">
                                {% for attachment in post.attachments %}
                                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                        <span>{{ attachment.getDisplayName() }}</span>
                                        <a href="{{ asset('uploads/attachments/' ~ attachment.filePath) }}" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-primary">Ouvrir</a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="text-muted mb-0">Aucune piece jointe.</p>
                        {% endif %}
                    </div>
                </article>

                <section class="card border shadow-sm mt-4">
                    <div class="card-header bg-white">
                        <h2 class="h5 mb-0">Commentaires ({{ post.commentCount }})</h2>
                    </div>
                    <div class="card-body">
                        {% if isMember and post.allowComments %}
                            {{ form_start(commentForm, {'attr': {'novalidate': 'novalidate'}}) }}
                                <div class="mb-3">
                                    {{ form_row(commentForm.content) }}
                                </div>
                                {{ form_widget(commentForm.save, {'attr': {'class': 'btn btn-primary'}}) }}
                            {{ form_end(commentForm) }}
                        {% elseif app.user and not isMember %}
                            <div class="alert alert-warning mb-3">Rejoignez la communaute pour commenter ou reagir.</div>
                        {% elseif app.user and isMember and not post.allowComments %}
                            <div class="alert alert-secondary mb-3">Les commentaires sont desactives pour ce post.</div>
                        {% else %}
                            <div class="alert alert-info mb-3">Connectez-vous et rejoignez la communaute pour commenter.</div>
                        {% endif %}

                        {% for comment in comments %}
                            <article class="border rounded p-3 mt-3">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">{{ comment.createdBy ? comment.createdBy.fullName : 'Utilisateur inconnu' }}</div>
                                        <div class="small text-muted">{{ comment.createdAt ? comment.createdAt|date('d/m/Y H:i') : '-' }}</div>
                                    </div>
                                    <span class="badge bg-light text-dark border">Score: {{ comment.score }}</span>
                                </div>
                                <p class="mb-2 mt-2">{{ comment.content|nl2br }}</p>
                                {% set commentReaction = commentReactionMap[comment.id] ?? null %}
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <form method="post" action="{{ path('app_front_comment_react', {'postId': post.id, 'commentId': comment.id, 'type': 'like'}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('react_comment_' ~ comment.id) }}">
                                        <button type="submit" class="btn btn-sm {{ commentReaction and commentReaction.value == 'like' ? 'btn-primary' : 'btn-outline-primary' }}" {{ isMember ? '' : 'disabled' }}>
                                            <i class="bi bi-hand-thumbs-up me-1"></i>Like ({{ comment.likeCount }})
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_front_comment_react', {'postId': post.id, 'commentId': comment.id, 'type': 'dislike'}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('react_comment_' ~ comment.id) }}">
                                        <button type="submit" class="btn btn-sm {{ commentReaction and commentReaction.value == 'dislike' ? 'btn-danger' : 'btn-outline-danger' }}" {{ isMember ? '' : 'disabled' }}>
                                            <i class="bi bi-hand-thumbs-down me-1"></i>Dislike ({{ comment.dislikeCount }})
                                        </button>
                                    </form>
                                </div>
                            </article>
                        {% else %}
                            <p class="text-muted mt-3 mb-0">Aucun commentaire pour le moment.</p>
                        {% endfor %}
                    </div>
                </section>
            </div>
        </div>
    </div>
</section>
{% endblock %}
