{% extends 'forum_front/layout.html.twig' %}

{% block title %}{{ post.title }} - Forum{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">
                <a href="{{ path('app_front_community_show', {'id': post.community.id}) }}" class="text-decoration-none small">&larr; Retour a {{ post.community.name }}</a>

                <article class="card border shadow-sm mt-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h1 class="h3 mb-0">{{ post.title }}</h1>
                            {% if post.spoilerWarning %}
                                <span class="badge bg-warning text-dark">Spoiler</span>
                            {% endif %}
                        </div>

                        <div class="small text-muted mb-3">
                            Publie le {{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : '-' }}
                            par {{ post.createdBy ? post.createdBy.fullName : 'Utilisateur inconnu' }}
                        </div>

                        <div class="mb-4">{{ post.content|nl2br }}</div>

                        {% if post.externalUrl %}
                            <p class="mb-4">
                                <a href="{{ post.externalUrl }}" target="_blank" rel="noreferrer">Lien complementaire</a>
                            </p>
                        {% endif %}

                        <h2 class="h6">Pieces jointes</h2>
                        {% if post.hasAttachments() %}
                            <ul class="list-group list-group-flush">
                                {% for attachment in post.attachments %}
                                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                        <span>{{ attachment.getDisplayName() }}</span>
                                        <a href="{{ asset('uploads/attachments/' ~ attachment.filePath) }}" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-primary">Ouvrir</a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="text-muted mb-0">Aucune piece jointe.</p>
                        {% endif %}
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>
{% endblock %}
