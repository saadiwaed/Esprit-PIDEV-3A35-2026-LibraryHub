{% extends 'forum_front/layout.html.twig' %}

{% block title %}Forum - Communautes{% endblock %}

{% block body %}
<section class="forum-ui-page">
    <div class="container forum-ui-section">
        <div class="forum-ui-hero mb-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <h1 class="forum-ui-title h2 mb-2">Forum et discussions</h1>
                    <p class="forum-ui-subtitle">Choisissez une communaute et explorez ses posts.</p>
                    <div class="forum-ui-chip-row mt-3">
                        <span class="forum-ui-chip"><i class="bi bi-collection"></i>{{ communities|length }} communautes visibles</span>
                        <span class="forum-ui-chip"><i class="bi bi-chat-left-text"></i>Partage de lectures et idees</span>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    {% if is_granted('ROLE_MEMBER') %}
                        <a href="{{ path('app_front_community_new') }}" class="btn btn-light forum-ui-btn">
                            <i class="fas fa-plus me-1"></i> Creer une communaute
                        </a>
                    {% elseif not app.user %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-light forum-ui-btn">
                            <i class="fas fa-sign-in-alt me-1"></i> Se connecter pour creer
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>

        {% for label in ['success', 'warning', 'error'] %}
            {% for message in app.flashes(label) %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <form method="get" action="{{ path('app_front_community_index') }}" class="forum-ui-filter forum-ui-surface mb-4">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-7">
                    <label for="front-community-search" class="form-label mb-1">Rechercher une communaute</label>
                    <input
                        id="front-community-search"
                        name="q"
                        type="search"
                        class="form-control"
                        placeholder="Nom, description ou objectif"
                        value="{{ filters.q }}"
                    >
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <label for="front-community-sort" class="form-label mb-1">Trier par</label>
                    <select id="front-community-sort" name="sort" class="form-select">
                        <option value="newest" {{ filters.sort == 'newest' ? 'selected' : '' }}>Plus recentes</option>
                        <option value="oldest" {{ filters.sort == 'oldest' ? 'selected' : '' }}>Plus anciennes</option>
                        <option value="name_asc" {{ filters.sort == 'name_asc' ? 'selected' : '' }}>Nom A-Z</option>
                        <option value="name_desc" {{ filters.sort == 'name_desc' ? 'selected' : '' }}>Nom Z-A</option>
                        <option value="most_posts" {{ filters.sort == 'most_posts' ? 'selected' : '' }}>Plus de posts</option>
                        <option value="most_members" {{ filters.sort == 'most_members' ? 'selected' : '' }}>Plus de membres</option>
                    </select>
                </div>
                <div class="col-12 col-md-6 col-lg-2 d-grid gap-2">
                    <button type="submit" class="btn btn-primary forum-ui-btn">Appliquer</button>
                    {% if filters.q or filters.sort != 'newest' %}
                        <a href="{{ path('app_front_community_index') }}" class="btn btn-light forum-ui-btn">Reinitialiser</a>
                    {% endif %}
                </div>
            </div>
        </form>

        <div class="row g-4">
            {% for community in communities %}
                <div class="col-md-6 col-xl-4">
                    <article class="forum-ui-card h-100 p-3 d-flex flex-column">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="forum-ui-chip bg-white"><i class="{{ community.iconClass }}"></i></span>
                            <h2 class="h5 mb-0 forum-ui-title">{{ community.name }}</h2>
                        </div>
                        <p class="text-muted mb-3">{{ community.description|length > 130 ? community.description|slice(0, 130) ~ '...' : community.description }}</p>
                        <div class="forum-ui-chip-row mb-3">
                            <span class="forum-ui-chip"><i class="bi bi-people"></i>{{ community.memberCount }} membres</span>
                            <span class="forum-ui-chip"><i class="bi bi-chat-square-text"></i>{{ community.postCount }} posts</span>
                        </div>
                        <a href="{{ path('app_front_community_show', {'id': community.id}) }}" class="btn btn-primary forum-ui-btn mt-auto">Voir la communaute</a>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <p class="forum-ui-empty">Aucune communaute publique n'est disponible pour le moment.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
