{% extends 'forum_front/layout.html.twig' %}

{% block title %}Nouvelle communaute - Forum{% endblock %}

{% block body %}
<section class="forum-ui-page">
    <div class="container forum-ui-section">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="forum-ui-hero mb-4">
                    <a href="{{ path('app_front_community_index') }}" class="forum-ui-back-link mb-2"><i class="bi bi-arrow-left"></i> Retour aux communautes</a>
                    <h1 class="forum-ui-title h3 mb-2">Creer une communaute</h1>
                    <p class="forum-ui-subtitle">Votre communaute sera visible apres validation par un administrateur ou un bibliothecaire.</p>
                    <div class="forum-ui-chip-row mt-3">
                        <span class="forum-ui-chip"><i class="bi bi-shield-check"></i>Moderation active</span>
                        <span class="forum-ui-chip"><i class="bi bi-megaphone"></i>Description claire recommandee</span>
                    </div>
                </div>

                <div class="row g-4 align-items-start">
                    <div class="col-lg-8">
                        <div class="forum-ui-surface forum-ui-form-shell">
                            {{ include('community/_form.html.twig', {
                                form: form,
                                cancel_path: path('app_front_community_index')
                            }) }}
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <aside class="forum-ui-card p-3">
                            <h2 class="h5 forum-ui-title mb-3">Conseils rapides</h2>
                            <ul class="list-unstyled mb-0 text-muted">
                                <li class="mb-2"><i class="bi bi-check2-circle text-primary me-1"></i>Choisissez un nom court et explicite.</li>
                                <li class="mb-2"><i class="bi bi-check2-circle text-primary me-1"></i>Definissez des regles claires et bienveillantes.</li>
                                <li class="mb-2"><i class="bi bi-check2-circle text-primary me-1"></i>Ajoutez un objectif utile pour les membres.</li>
                                <li class="mb-0"><i class="bi bi-check2-circle text-primary me-1"></i>Utilisez une icone representative du theme.</li>
                            </ul>
                        </aside>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/forum-ai-assistant.js') }}?v=20260223-5"></script>
{% endblock %}
