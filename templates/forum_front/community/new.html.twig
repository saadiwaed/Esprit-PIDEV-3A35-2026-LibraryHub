{% extends 'forum_front/layout.html.twig' %}

{% block title %}Nouvelle communaute - Forum{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-9">
                <a href="{{ path('app_front_community_index') }}" class="text-decoration-none small">&larr; Retour aux communautes</a>
                <h1 class="h3 mt-2 mb-1">Creer une communaute</h1>
                <p class="text-muted mb-4">Votre communaute sera visible apres validation par un administrateur ou un bibliothecaire.</p>

                {{ include('community/_form.html.twig', {
                    form: form,
                    cancel_path: path('app_front_community_index')
                }) }}
            </div>
        </div>
    </div>
</section>
{% endblock %}
