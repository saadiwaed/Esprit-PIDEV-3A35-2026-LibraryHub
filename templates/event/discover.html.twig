{% extends 'frontoffice/navbar.html.twig' %}


{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Événements à découvrir</h1>
        <div>
            <a href="{{ path('app_event_my_events') }}" class="btn btn-outline-primary">
                <i class="bi bi-calendar-check"></i> Mes événements
            </a>
        </div>
    </div>

    <!-- Flash messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="search" class="form-control" 
                               placeholder="Rechercher un événement..." 
                               value="{{ current_filters.search }}">
                    </div>
                </div>
                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="">Tous les statuts</option>
                        {% for status in all_status %}
                            <option value="{{ status.value }}" 
                                    {{ current_filters.status == status.value ? 'selected' : '' }}>
                                {{ status.label }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Events grid -->
    <div class="row g-4">
        {% for event in events %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    {% if event.image %}
                        <img src="{{ asset('uploads/events/' ~ event.image) }}" 
                             class="card-img-top" alt="{{ event.title }}" 
                             style="height: 200px; object-fit: cover;">
                    {% else %}
                        <div class="bg-light d-flex align-items-center justify-content-center" 
                             style="height: 200px;">
                            <i class="bi bi-calendar-event fs-1 text-secondary"></i>
                        </div>
                    {% endif %}
                    
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">{{ event.title }}</h5>
                            <span class="badge bg-{{ event.status.color ?? 'secondary' }}">
                                {{ event.status.label }}
                            </span>
                        </div>
                        
                        <div class="mb-2">
                            <small class="text-muted d-block">
                                <i class="bi bi-calendar me-1"></i>
                                {{ event.startDateTime|date('d/m/Y H:i') }}
                            </small>
                            <small class="text-muted d-block">
                                <i class="bi bi-geo-alt me-1"></i>
                                {{ event.location }}
                            </small>
                            <small class="text-muted d-block">
                                <i class="bi bi-people me-1"></i>
                                {{ event.getAvailableSpots }} / {{ event.capacity }} places
                            </small>
                            <small class="text-muted d-block">
                                <i class="bi bi-person-circle me-1"></i>
                                Organisé par: {{ event.createdBy.fullName }}
                            </small>
                        </div>
                        
                        <p class="card-text text-muted small">
                            {{ event.description|slice(0, 100) }}...
                        </p>
                        
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            {% if event.id in registeredEventIds %}
                                <form method="post" action="{{ path('app_event_leave', {'id': event.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('leave' ~ event.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-x-circle"></i> Se désister
                                    </button>
                                </form>
                                <span class="badge bg-success">Inscrit</span>
                            {% else %}
                                <form method="post" action="{{ path('app_event_join', {'id': event.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('join' ~ event.id) }}">
                                    <button type="submit" class="btn btn-sm btn-success"
                                            {{ not event.isRegistrationOpen ? 'disabled' : '' }}>
                                        <i class="bi bi-check-circle"></i> Participer
                                    </button>
                                </form>
                                {% if not event.isRegistrationOpen %}
                                    <span class="badge bg-secondary">Complet</span>
                                {% endif %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-calendar-x display-1"></i>
                    <h3 class="mt-3">Aucun événement disponible</h3>
                    <p class="text-muted">Il n'y a pas d'événements ouverts pour le moment.</p>
                    <a href="{{ path('app_event_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Créer un événement
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>
    {% endblock %}

