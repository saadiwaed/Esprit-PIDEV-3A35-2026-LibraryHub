{% extends 'frontoffice/navbar.html.twig' %}



{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📜 Mon Historique</h1>
        <a href="{{ path('app_event_my_events') }}" class="btn btn-outline-primary">
            <i class="bi bi-calendar-check"></i> Mes événements
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total inscriptions</h5>
                    <h2 class="mb-0">{{ stats.total }}</h2>
                    <small>À vie</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Participations</h5>
                    <h2 class="mb-0">{{ stats.confirmed }}</h2>
                    <small>Confirmées</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Annulations</h5>
                    <h2 class="mb-0">{{ stats.cancelled }}</h2>
                    <small>Désistements</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="card">
        <div class="card-header bg-transparent">
            <ul class="nav nav-tabs card-header-tabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#all">
                        <i class="bi bi-list-ul"></i> Tous ({{ history|length }})
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#confirmed">
                        <i class="bi bi-check-circle"></i> Confirmés ({{ stats.confirmed }})
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#cancelled">
                        <i class="bi bi-x-circle"></i> Annulés ({{ stats.cancelled }})
                    </a>
                </li>
            </ul>
        </div>
        
        <div class="card-body">
            <div class="tab-content">
                <!-- TAB 1 : TOUS -->
                <div class="tab-pane fade show active" id="all">
                    {% for reg in history %}
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <div>
                                <h6 class="mb-1">{{ reg.event.title }}</h6>
                                <small class="text-muted">
                                    <i class="bi bi-calendar3"></i> {{ reg.event.startDateTime|date('d/m/Y H:i') }}
                                    <br>
                                    <i class="bi bi-pencil"></i> Inscrit le {{ reg.registeredAt|date('d/m/Y H:i') }}
                                </small>
                            </div>
                            <div>
                                {% if reg.status.value == 'confirmed' %}
                                    <span class="badge bg-success">✅ Confirmé</span>
                                {% elseif reg.status.value == 'cancelled' %}
                                    <span class="badge bg-danger">❌ Annulé</span>
                                {% elseif reg.status.value == 'waitlisted' %}
                                    <span class="badge bg-warning">⏳ Liste d'attente</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ reg.status.label }}</span>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="bi bi-calendar-x display-1 text-muted"></i>
                            <h4 class="mt-3">Aucun historique</h4>
                            <p class="text-muted">Vous n'avez encore aucune inscription.</p>
                            <a href="{{ path('app_event_discover') }}" class="btn btn-primary">
                                Découvrir des événements
                            </a>
                        </div>
                    {% endfor %}
                </div>
                
                <!-- TAB 2 : CONFIRMÉS -->
                <div class="tab-pane fade" id="confirmed">
                    {% for reg in history|filter(r => r.status.value == 'confirmed') %}
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <div>
                                <h6 class="mb-1">{{ reg.event.title }}</h6>
                                <small class="text-muted">
                                    <i class="bi bi-calendar3"></i> {{ reg.event.startDateTime|date('d/m/Y H:i') }}
                                </small>
                            </div>
                            <span class="badge bg-success">Inscrit</span>
                        </div>
                    {% else %}
                        <p class="text-muted text-center py-4">Aucune participation confirmée</p>
                    {% endfor %}
                </div>
                
                <!-- TAB 3 : ANNULÉS -->
                <div class="tab-pane fade" id="cancelled">
                    {% for reg in cancellations %}
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <div>
                                <h6 class="mb-1">{{ reg.event.title }}</h6>
                                <small class="text-muted">
                                    <i class="bi bi-calendar3"></i> {{ reg.event.startDateTime|date('d/m/Y H:i') }}
                                    <br>
                                    <i class="bi bi-pencil"></i> Inscrit le {{ reg.registeredAt|date('d/m/Y H:i') }}
                                </small>
                            </div>
                            <span class="badge bg-danger">Annulé</span>
                        </div>
                    {% else %}
                        <p class="text-muted text-center py-4">Aucune annulation</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
    
</div>
<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>

{% block javascripts %}


<!-- Bootstrap JS -->
<script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>

<!-- Vendors -->
<script src="{{ asset('assets/vendor/tiny-slider/tiny-slider.js') }}"></script>
<script src="{{ asset('assets/vendor/glightbox/js/glightbox.js') }}"></script>

<!-- Template Functions -->
<script src="{{ asset('assets/js/functions.js') }}"></script>

    {% endblock %}


{% endblock %}
