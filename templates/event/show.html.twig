{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - Événement{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #4361ee;
            --primary-light: #4895ef;
            --primary-soft: rgba(67, 97, 238, 0.08);
            --secondary: #6c757d;
            --success: #06d6a0;
            --warning: #ffd166;
            --danger: #ef476f;
            --dark: #2b2d42;
            --gray-bg: #f8f9fa;
            --border-light: #e9ecef;
            --shadow-sm: 0 1px 4px rgba(0, 0, 0, 0.02);
            --radius-sm: 6px;
        }

        /* Hero ultra compact */
        .event-hero {
            background: white;
            border-bottom: 1px solid var(--border-light);
            padding: 0.75rem 0 0.5rem;
            margin-bottom: 1rem;
        }

        .event-hero h1 {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 0.2rem;
        }

        .event-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.15rem 0.6rem;
            border-radius: 50px;
            font-size: 0.6rem;
            font-weight: 600;
            background: var(--gray-bg);
            border: 1px solid var(--border-light);
            color: var(--secondary);
        }

        .event-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
            color: var(--secondary);
            font-size: 0.65rem;
            margin-top: 0.2rem;
        }

        .event-meta span {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            background: var(--gray-bg);
            padding: 0.15rem 0.6rem;
            border-radius: 50px;
            border: 1px solid var(--border-light);
        }

        .event-meta i {
            font-size: 0.6rem;
            color: var(--primary);
        }

        /* Status badge */
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.1rem 0.5rem;
            border-radius: 50px;
            font-size: 0.6rem;
            font-weight: 600;
        }

        .status-draft { background: rgba(108, 117, 125, 0.1); color: var(--secondary); }
        .status-published { background: rgba(6, 214, 160, 0.1); color: #0a8f6c; }
        .status-cancelled { background: rgba(239, 71, 111, 0.1); color: var(--danger); }
        .status-completed { background: rgba(67, 97, 238, 0.1); color: var(--primary); }

        /* Card ultra compacte */
        .event-card {
            background: white;
            border: 1px solid var(--border-light);
            border-radius: var(--radius-sm);
            box-shadow: var(--shadow-sm);
            margin-bottom: 0.75rem;
        }

        .event-card-header {
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .event-card-header h4, 
        .event-card-header h5 {
            margin: 0;
            font-weight: 600;
            color: var(--dark);
            font-size: 0.8rem;
        }

        .event-card-header i {
            color: var(--primary);
            font-size: 0.8rem;
        }

        .event-card-body {
            padding: 0.75rem;
        }

        /* Info grid */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
        }

        .info-item {
            background: var(--gray-bg);
            padding: 0.5rem;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border-light);
        }

        .info-label {
            font-size: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 0.2px;
            color: var(--secondary);
            font-weight: 600;
            margin-bottom: 0.1rem;
        }

        .info-value {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 0.25rem;
            word-break: break-word;
        }

        .info-value i {
            color: var(--primary);
            font-size: 0.7rem;
            width: 14px;
        }

        /* Description */
        .description-text {
            font-size: 0.75rem;
            line-height: 1.5;
            color: var(--dark);
            margin-bottom: 0;
            white-space: pre-line;
        }

        /* Image */
        .event-image-container {
            border-radius: var(--radius-sm);
            overflow: hidden;
            border: 1px solid var(--border-light);
            margin-bottom: 0.75rem;
            max-width: 200px;
        }

        .event-image-container img {
            width: 100%;
            height: 120px;
            object-fit: cover;
        }

        .event-image-placeholder {
            width: 100%;
            height: 120px;
            background: var(--gray-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--secondary);
            font-size: 0.7rem;
            gap: 0.5rem;
        }

        /* Actions */
        .event-actions {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 0.5rem;
            flex-wrap: wrap;
        }

        .btn-custom {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.25rem;
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            font-weight: 500;
            font-size: 0.65rem;
            border: none;
            cursor: pointer;
            text-decoration: none;
            white-space: nowrap;
        }

        .btn-primary-custom {
            background: var(--primary);
            color: white;
        }

        .btn-outline-custom {
            background: white;
            color: var(--primary);
            border: 1px solid var(--primary);
        }

        .btn-light-custom {
            background: white;
            color: var(--secondary);
            border: 1px solid var(--border-light);
        }

        .btn-danger-custom {
            background: white;
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        .btn-danger-custom:hover {
            background: var(--danger);
            color: white;
        }

        /* Delete form */
        .delete-form {
            display: inline-block;
        }

        .delete-form button {
            background: white;
            color: var(--danger);
            border: 1px solid var(--danger);
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            font-size: 0.65rem;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            cursor: pointer;
        }

        .delete-form button:hover {
            background: var(--danger);
            color: white;
        }

        /* Container */
        .container {
            max-width: 1140px;
            padding-left: 12px;
            padding-right: 12px;
        }

        .py-4 {
            padding-top: 0.5rem !important;
            padding-bottom: 0.5rem !important;
        }

        .mt-3 {
            margin-top: 0.5rem !important;
        }

        .mt-4 {
            margin-top: 0.75rem !important;
        }

        .mb-0 {
            margin-bottom: 0 !important;
        }

        .divider {
            border-top: 1px solid var(--border-light);
            margin: 0.75rem 0;
        }

        /* Organizer */
        .organizer-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem;
            background: white;
            border: 1px solid var(--border-light);
            border-radius: var(--radius-sm);
        }

        .organizer-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.75rem;
            background: var(--primary-soft);
            color: var(--primary);
            flex-shrink: 0;
        }

        .organizer-details {
            min-width: 0;
        }

        .organizer-name {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 0.1rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .organizer-email {
            font-size: 0.6rem;
            color: var(--secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    </style>
{% endblock %}

{% block body %}
<!-- Hero ultra compact -->
<section class="event-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-8">
                <div class="d-flex align-items-center gap-1 mb-1">
                    <span class="event-badge">
                        <i class="fas fa-tag"></i>
                        {{ event.type.getLabel()|slice(0, 12) }}{% if event.type.getLabel()|length > 12 %}...{% endif %}
                    </span>
                    <span class="event-badge">
                        <i class="fas fa-user"></i>
                        {{ event.createdBy.firstName ?? 'N/A' }}
                    </span>
                </div>
                <h1>{{ event.title|slice(0, 40) }}{% if event.title|length > 40 %}...{% endif %}</h1>
                <div class="event-meta">
                    <span><i class="fas fa-calendar"></i> {{ event.startDateTime|date('d/m/y H:i') }}</span>
                    <span><i class="fas fa-map-marker-alt"></i> {{ event.location|slice(0, 15) }}{% if event.location|length > 15 %}...{% endif %}</span>
                    <span>
                        <i class="fas fa-circle"></i>
                        {{ event.status.label }}
                    </span>
                </div>
            </div>
            <div class="col-4 text-end">
                <span class="status-badge status-{{ event.status.value }}">
                    <i class="fas 
                        {% if event.status.value == 'published' %}fa-check-circle
                        {% elseif event.status.value == 'draft' %}fa-pen
                        {% elseif event.status.value == 'cancelled' %}fa-times-circle
                        {% else %}fa-clock{% endif %}">
                    </i>
                    {{ event.status.label|slice(0, 8) }}
                </span>
            </div>
        </div>
    </div>
</section>

<div class="container pb-4">
    <div class="row g-2">
        <!-- Colonne principale -->
        <div class="col-lg-8">
            <!-- Image -->
            <div class="event-image-container">
                {% if event.image %}
                    <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}">
                {% else %}
                    <div class="event-image-placeholder">
                        <i class="fas fa-calendar-alt fa-2x"></i>
                        <span>Aucune image</span>
                    </div>
                {% endif %}
            </div>

            <!-- Description -->
            <div class="event-card">
                <div class="event-card-header">
                    <i class="fas fa-align-left"></i>
                    <h4>Description</h4>
                </div>
                <div class="event-card-body">
                    <p class="description-text">
                        {{ event.description ?: 'Aucune description fournie.' }}
                    </p>
                </div>
            </div>

            <!-- Informations détaillées -->
            <div class="event-card">
                <div class="event-card-header">
                    <i class="fas fa-info-circle"></i>
                    <h4>Détails</h4>
                </div>
                <div class="event-card-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-label">ID</div>
                            <div class="info-value">
                                <i class="fas fa-hashtag"></i>
                                #{{ event.id }}
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Capacité</div>
                            <div class="info-value">
                                <i class="fas fa-users"></i>
                                {{ event.capacity ?? 'Illimitée' }}
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Début</div>
                            <div class="info-value">
                                <i class="fas fa-play"></i>
                                {{ event.startDateTime|date('d/m/y H:i') }}
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Fin</div>
                            <div class="info-value">
                                <i class="fas fa-stop"></i>
                                {{ event.endDateTime|date('d/m/y H:i') }}
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Lieu</div>
                            <div class="info-value">
                                <i class="fas fa-map-marker-alt"></i>
                                {{ event.location ?: 'Non défini' }}
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Inscription</div>
                            <div class="info-value">
                                <i class="fas fa-clock"></i>
                                {{ event.registrationDeadline ? event.registrationDeadline|date('d/m/y') : 'Pas de limite' }}
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Créé le</div>
                            <div class="info-value">
                                <i class="fas fa-calendar-plus"></i>
                                {{ event.createdDate|date('d/m/y') }}
                            </div>
                        </div>
                        
                        <div class="info-item">
                            <div class="info-label">Type</div>
                            <div class="info-value">
                                <i class="fas fa-{{ event.type.getIcon() }}"></i>
                                {{ event.type.getLabel()|slice(0, 12) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Colonne latérale -->
        <div class="col-lg-4">
            <!-- Organisateur -->
            <div class="event-card">
                <div class="event-card-header">
                    <i class="fas fa-user-circle"></i>
                    <h5>Organisateur</h5>
                </div>
                <div class="event-card-body">
                    <div class="organizer-info">
                        <div class="organizer-avatar">
                            {{ event.createdBy.firstName|slice(0, 1)|upper }}{{ event.createdBy.lastName|slice(0, 1)|upper }}
                        </div>
                        <div class="organizer-details">
                            <div class="organizer-name">
                                {{ event.createdBy.fullName ?: event.createdBy.email|slice(0, 20) }}
                            </div>
                            <div class="organizer-email">
                                <i class="fas fa-envelope"></i> {{ event.createdBy.email|slice(0, 18) }}{% if event.createdBy.email|length > 18 %}...{% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="event-card mt-2">
                <div class="event-card-header">
                    <i class="fas fa-bolt"></i>
                    <h5>Actions</h5>
                </div>
                <div class="event-card-body">
                    <div class="event-actions">
                        <a href="{{ path('app_event_index') }}" class="btn-custom btn-light-custom">
                            <i class="fas fa-arrow-left"></i>
                            Retour
                        </a>
                        
                        {% if app.user and (app.user == event.createdBy or is_granted('ROLE_ADMIN')) %}
                            <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="btn-custom btn-outline-custom">
                                <i class="fas fa-edit"></i>
                                Modifier
                            </a>
                            
                            <div class="delete-form">
                                {{ include('event/_delete_form.html.twig') }}
                            </div>
                        {% endif %}
                    </div>
                    
                    {% if isRegistered is defined and isRegistered %}
                        <div class="mt-2">
                            <span class="status-badge status-published" style="display: inline-flex; width: 100%; justify-content: center; padding: 0.3rem;">
                                <i class="fas fa-check-circle me-1"></i>
                                Vous êtes inscrit
                                {% if registrationStatus and registrationStatus.value == 'waitlisted' %}
                                    (Liste d'attente)
                                {% endif %}
                            </span>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Clubs organisateurs -->
            {% if event.organizingClubs is defined and event.organizingClubs|length > 0 %}
                <div class="event-card mt-2">
                    <div class="event-card-header">
                        <i class="fas fa-people"></i>
                        <h5>Clubs</h5>
                    </div>
                    <div class="event-card-body">
                        {% for club in event.organizingClubs %}
                            <div class="organizer-info mb-1">
                                <div class="organizer-avatar" style="background: var(--primary-soft); color: var(--primary);">
                                    {{ club.title|slice(0, 1)|upper }}
                                </div>
                                <div class="organizer-details">
                                    <div class="organizer-name">{{ club.title|slice(0, 20) }}{% if club.title|length > 20 %}...{% endif %}</div>
                                    <div class="organizer-email">
                                        <i class="fas fa-users"></i> {{ club.members|length }} membres
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
