{% extends 'frontoffice/navbar.html.twig' %}

{% block title %}Créer un événement - LibraryHub{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="text-center mb-4">
                <div class="bg-soft-primary d-inline-block p-3 rounded-circle mb-2">
                    <i class="bi bi-calendar-event fs-3 text-primary"></i>
                </div>
                <h2 class="fw-bold mb-2">{{ button_label|default('Créer un événement') }}</h2>
                <p class="text-muted">Organisez un moment de partage autour de vos lectures</p>
            </div>

            <!-- Formulaire -->
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <!-- Titre -->
                    {{ form_row(form.title, {
                        'label': 'Titre de l\'événement',
                        'attr': {
                            'class': 'form-control' ~ (form.title.vars.valid ? '' : ' is-invalid'),
                            'placeholder': 'ex: Rencontre avec un auteur, Atelier d\'écriture...'
                        },
                        'label_attr': {'class': 'form-label fw-semibold'}
                    }) }}
                    <small class="text-muted mb-3 d-block">
                        <i class="bi bi-info-circle"></i> 
                        Choisissez un titre clair et attractif
                    </small>

                    <!-- Description -->
                    {{ form_row(form.description, {
                        'label': 'Description',
                        'attr': {
                            'class': 'form-control' ~ (form.description.vars.valid ? '' : ' is-invalid'),
                            'rows': 4,
                            'placeholder': 'Décrivez votre événement, le programme, les intervenants...'
                        },
                        'label_attr': {'class': 'form-label fw-semibold'}
                    }) }}
                    <small class="text-muted mb-3 d-block">
                        <i class="bi bi-info-circle"></i> 
                        Minimum 10 caractères
                    </small>

                    <div class="row g-3">
                        <!-- Date de début -->
                        <div class="col-md-6">
                            {{ form_row(form.startDateTime, {
                                'label': 'Date et heure de début',
                                'attr': {
                                    'class': 'form-control' ~ (form.startDateTime.vars.valid ? '' : ' is-invalid')
                                },
                                'label_attr': {'class': 'form-label fw-semibold'}
                            }) }}
                        </div>

                        <!-- Date de fin -->
                        <div class="col-md-6">
                            {{ form_row(form.endDateTime, {
                                'label': 'Date et heure de fin',
                                'attr': {
                                    'class': 'form-control' ~ (form.endDateTime.vars.valid ? '' : ' is-invalid')
                                },
                                'label_attr': {'class': 'form-label fw-semibold'}
                            }) }}
                            <small class="text-muted">
                                <i class="bi bi-info-circle"></i> 
                                Doit être après la date de début
                            </small>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <!-- Lieu -->
                        <div class="col-md-6">
                            {{ form_row(form.location, {
                                'label': 'Lieu',
                                'attr': {
                                    'class': 'form-control' ~ (form.location.vars.valid ? '' : ' is-invalid'),
                                    'placeholder': 'Ex: Bibliothèque, Zoom, Discord...'
                                },
                                'label_attr': {'class': 'form-label fw-semibold'}
                            }) }}
                        </div>

                        <!-- Capacité -->
                        <div class="col-md-3">
                            {{ form_row(form.capacity, {
                                'label': 'Capacité',
                                'attr': {
                                    'class': 'form-control' ~ (form.capacity.vars.valid ? '' : ' is-invalid'),
                                    'min': 1,
                                    'placeholder': '30'
                                },
                                'label_attr': {'class': 'form-label fw-semibold'}
                            }) }}
                            <small class="text-muted">Maximum 1000 personnes</small>
                        </div>

                        <!-- Date limite d'inscription -->
                        <div class="col-md-3">
                            {{ form_row(form.registrationDeadline, {
                                'label': 'Date limite',
                                'attr': {
                                    'class': 'form-control' ~ (form.registrationDeadline.vars.valid ? '' : ' is-invalid')
                                },
                                'label_attr': {'class': 'form-label fw-semibold'}
                            }) }}
                            <small class="text-muted">Optionnel</small>
                        </div>
                    </div>

                    <!-- Type d'événement -->
                    <div class="mt-3">
                        {{ form_row(form.type, {
                            'label': 'Type d\'événement',
                            'attr': {
                                'class': 'form-select' ~ (form.type.vars.valid ? '' : ' is-invalid')
                            },
                            'label_attr': {'class': 'form-label fw-semibold'}
                        }) }}
                        <small class="text-muted">
                            <i class="bi bi-tag"></i>
                            {% for type in enum('App\\Enum\\EventTypes').cases() %}
                                <span class="badge bg-light text-dark me-1 mt-1">
                                    <i class="fas fa-{{ type.getIcon() }}"></i> {{ type.getLabel() }}
                                </span>
                            {% endfor %}
                        </small>
                    </div>

                    <!-- Image (optionnel) -->
                    <div class="mt-4">
                        {{ form_row(form.imageFile, {
                            'label': 'Image de l\'événement (optionnel)',
                            'attr': {
                                'class': 'form-control' ~ (form.imageFile.vars.valid ? '' : ' is-invalid'),
                                'accept': 'image/*'
                            },
                            'label_attr': {'class': 'form-label fw-semibold'}
                        }) }}
                        <div id="imagePreviewContainer" class="mt-2 text-center d-none">
                            <img src="#" alt="Aperçu" class="img-fluid rounded" style="max-height: 100px;" id="imagePreview">
                        </div>
                        <small class="text-muted">Formats: JPG, PNG, GIF (Max 2Mo)</small>
                    </div>

                    

                    <!-- Boutons -->
                    <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
                        <a href="{{ path('app_event_my_events') }}" class="btn btn-light px-4">
                            Annuler
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>
                            {{ button_label|default('Créer l\'événement') }}
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Script pour l'aperçu de l'image -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const imageInput = document.querySelector('#{{ form.imageFile.vars.id }}');
    const imagePreview = document.getElementById('imagePreview');
    const previewContainer = document.getElementById('imagePreviewContainer');
    
    if (imageInput) {
        imageInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;
                    previewContainer.classList.remove('d-none');
                }
                reader.readAsDataURL(this.files[0]);
            } else {
                previewContainer.classList.add('d-none');
                imagePreview.src = '#';
            }
        });
    }
});
</script>

<style>
.bg-soft-primary {
    background-color: rgba(13, 110, 253, 0.1);
}
.form-control:focus, .form-select:focus {
    border-color: #86b7fe;
    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.1);
}
</style>
{% endblock %}