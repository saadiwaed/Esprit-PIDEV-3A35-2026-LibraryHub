{% extends 'frontoffice/navbar.html.twig' %}



{% block body %}
<div class="container mt-4">
    

    <!-- Stats cards -->
    <div class="row mb-4">
        {% for status in all_status %}
            <div class="col-md-3 mb-2">
                <div class="card bg-light">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-{{ status.color ?? 'secondary' }}">{{ status.label }}</span>
                            <span class="h5 mb-0">{{ stats[status.value] ?? 0 }}</span>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="search" class="form-control" placeholder="Rechercher..." value="{{ current_filters.search }}">
                </div>
                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="">Tous les statuts</option>
                        {% for status in all_status %}
                            <option value="{{ status.value }}" {{ current_filters.status == status.value ? 'selected' : '' }}>
                                {{ status.label }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Events list -->
    <div class="row">
        {% for event in events %}
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    {% if event.image %}
                        <img src="{{ asset('uploads/events/' ~ event.image) }}" class="card-img-top" alt="{{ event.title }}" style="height: 200px; object-fit: cover;">
                    {% else %}
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="bi bi-calendar-event" style="font-size: 3rem;"></i>
                        </div>
                    {% endif %}
                    <div class="card-body">
                        <h5 class="card-title">{{ event.title }}</h5>
                        <p class="card-text text-muted small">
                            <i class="bi bi-calendar"></i> {{ event.startDateTime|date('d/m/Y H:i') }}
                        </p>
                        <p class="card-text">{{ event.description|slice(0, 100) }}...</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-{{ event.status.color ?? 'secondary' }}">{{ event.status.label }}</span>
                            <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-sm btn-outline-primary">
    <i class="bi bi-eye"></i> Voir
</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle"></i> Aucun événement trouvé.
                    <a href="{{ path('app_event_new') }}" class="alert-link">Créer votre premier événement</a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
