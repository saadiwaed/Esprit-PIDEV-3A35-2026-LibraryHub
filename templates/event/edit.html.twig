{% extends 'base.html.twig' %}

{% block title %}Modifier Événement{% endblock %}

{% block body %}

    {{ include('event/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

    <a href="{{ path('app_event_index') }}" class="btn btn-secondary mt-2">Retour à la liste</a>

    {{ include('event/_delete_form.html.twig') }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        table {
            width: 100%;
            border-collapse: collapse;
        }
        td {
            padding: 10px;
            border: 1px solid #ddd;
            vertical-align: top;
        }
        td:first-child {
            width: 200px;
            font-weight: bold;
            background-color: #f8f9fa;
        }
        .form-control {
            width: 100%;
            padding: 8px;
            border: 1px solid #ced4da;
            border-radius: 4px;
        }
        .alert-danger {
            color: #721c24;
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            padding: 5px;
            margin-top: 5px;
            font-size: 0.9em;
        }
    </style>
{% endblock %}