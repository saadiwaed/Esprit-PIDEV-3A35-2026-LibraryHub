{# templates/event/_form.html.twig #}
{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<table class="table table-bordered">
    <tr>
        <td>{{ form_label(form.title, "Titre") }}</td>
        <td>{{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.title) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.description, "Description") }}</td>
        <td>{{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3}}) }}</td>
        <td>{{ form_errors(form.description) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.startDateTime, "Date et heure de début") }}</td>
        <td>{{ form_widget(form.startDateTime, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.startDateTime) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.endDateTime, "Date et heure de fin") }}</td>
        <td>{{ form_widget(form.endDateTime, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.endDateTime) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.location, "Lieu") }}</td>
        <td>{{ form_widget(form.location, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.location) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.capacity, "Capacité") }}</td>
        <td>{{ form_widget(form.capacity, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.capacity) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.registrationDeadline, "Date limite d'inscription") }}</td>
        <td>{{ form_widget(form.registrationDeadline, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.registrationDeadline) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.status, "Statut") }}</td>
        <td>{{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.status) }}</td>
    </tr>

    <tr>
    <td>{{ form_label(form.type, "Type d'événement") }}</td>
    <td>
        {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
        <small class="text-muted">
            {% for type in enum('App\\Enum\\EventTypes').cases() %}
                <span class="badge bg-light text-dark me-1">
                    <i class="fas fa-{{ type.getIcon() }}"></i> {{ type.getLabel() }}
                </span>
            {% endfor %}
        </small>
    </td>
    <td>{{ form_errors(form.type) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.createdDate, "Date de création") }}</td>
        <td>{{ form_widget(form.createdDate, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.createdDate) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.imageFile, "Image") }}</td>
        <td>{{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.imageFile) }}</td>
    </tr>

    <tr>
        <td>{{ form_label(form.createdBy, "Créé par") }}</td>
        <td>{{ form_widget(form.createdBy, {'attr': {'class': 'form-control'}}) }}</td>
        <td>{{ form_errors(form.createdBy) }}</td>
    </tr>

    
</table>

<div class="mt-3">
    <button type="submit" class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
    <a href="{{ path('app_event_index') }}" class="btn btn-secondary">Annuler</a>
</div>

{{ form_end(form) }}