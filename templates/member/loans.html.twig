{% extends 'base.html.twig' %}

{% block title %}Mes emprunts{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}

        <div class="row mb-4">
            <div class="col-12">
                <h1 class="h3 mb-1">Mes emprunts</h1>
                <p class="text-muted mb-0">Consultez vos emprunts en cours et votre historique.</p>
            </div>
        </div>

        <div id="renouvellements" class="row g-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="card-header-title mb-0">Emprunts en cours</h5>
                    </div>
                    <div class="card-body">
                        {% if openLoans is empty %}
                            <div class="text-muted">Vous nâ€™avez aucun emprunt en cours.</div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Exemplaire</th>
                                            <th>Sortie</th>
                                            <th>Date limite</th>
                                            <th>Statut</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for loan in openLoans %}
                                            {% set statusValue = loan.status.value %}
                                            <tr>
                                                <td>{{ loan.bookCopy }}</td>
                                                <td>{{ loan.checkoutTime ? loan.checkoutTime|date('d/m/Y') : '-' }}</td>
                                                <td>{{ loan.dueDate ? loan.dueDate|date('d/m/Y') : '-' }}</td>
                                                <td>
                                                    {% if statusValue == 'active' %}
                                                        <span class="badge bg-success">Actif</span>
                                                    {% elseif statusValue == 'overdue' %}
                                                        <span class="badge bg-danger">En retard</span>
                                                        <div class="small text-danger mt-1">En retard de {{ loan.daysLate }} jours</div>
                                                    {% else %}
                                                        <span class="badge bg-secondary">{{ statusValue }}</span>
                                                    {% endif %}
                                                </td>
                                                <td class="text-end">
                                                    {% if statusValue == 'active' and loan.renewalCount < maxRenewals %}
                                                        <form method="post" action="{{ path('member_loan_request_renewal', {id: loan.id}) }}" class="d-inline">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('request_renewal' ~ loan.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-primary">
                                                                Demander un renouvellement
                                                            </button>
                                                        </form>
                                                    {% elseif loan.renewalCount >= maxRenewals %}
                                                        <span class="text-muted small">Limite atteinte</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="card-header-title mb-0">Historique</h5>
                    </div>
                    <div class="card-body">
                        {% if historyLoans is empty %}
                            <div class="text-muted">Aucun emprunt dans lâ€™historique.</div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Exemplaire</th>
                                            <th>Sortie</th>
                                            <th>Retour</th>
                                            <th>Statut</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for loan in historyLoans %}
                                            {% set statusValue = loan.status.value %}
                                            <tr>
                                                <td>{{ loan.bookCopy }}</td>
                                                <td>{{ loan.checkoutTime ? loan.checkoutTime|date('d/m/Y') : '-' }}</td>
                                                <td>{{ loan.returnDate ? loan.returnDate|date('d/m/Y') : '-' }}</td>
                                                <td>
                                                    {% if statusValue == 'returned' %}
                                                        <span class="badge bg-secondary">Retourne</span>
                                                    {% else %}
                                                        <span class="badge bg-light text-dark">{{ statusValue }}</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}


