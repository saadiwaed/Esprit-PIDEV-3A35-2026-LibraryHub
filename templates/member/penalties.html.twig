{% extends 'base.html.twig' %}

{% block title %}Mes penalites{% endblock %}

{% block body %}
    <div class="container-fluid p-4">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
            </div>
        {% endfor %}

        <div class="row mb-4">
            <div class="col-12">
                <h1 class="h3 mb-1">Mes penalites</h1>
                <p class="text-muted mb-0">Vos penalites impayees sont affichees en premier.</p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Motif</th>
                                <th>Date</th>
                                <th>Statut</th>
                                <th class="text-end">Montant</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if penalties is empty %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">Aucune penalite.</td>
                                </tr>
                            {% endif %}

                            {% for penalty in penalties %}
                                {% set statusValue = penalty.status.value %}
                                {% set isUnpaid = statusValue == 'unpaid' and not penalty.waived %}
                                <tr class="{% if isUnpaid %}table-danger{% endif %}">
                                    <td>
                                        {{ penalty.reasonLabel }}
                                        {% if isUnpaid and penalty.lateDays > 0 %}
                                            <div class="small text-danger">En retard de {{ penalty.lateDays }} jours</div>
                                        {% endif %}
                                        {% if penalty.waived %}
                                            <div class="small text-muted">Exoneree</div>
                                        {% endif %}
                                    </td>
                                    <td>{{ penalty.issueDate ? penalty.issueDate|date('d/m/Y') : '-' }}</td>
                                    <td>
                                        {% if penalty.waived %}
                                            <span class="badge bg-secondary">Exoneree</span>
                                        {% elseif statusValue == 'unpaid' %}
                                            <span class="badge bg-danger">Impayee</span>
                                        {% elseif statusValue == 'partial' %}
                                            <span class="badge bg-warning text-dark">Partielle</span>
                                        {% elseif statusValue == 'paid' %}
                                            <span class="badge bg-success">Payee</span>
                                        {% else %}
                                            <span class="badge bg-light text-dark">{{ statusValue }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% if isUnpaid %}
                                            <span class="fw-semibold text-danger">Penalite impayee : {{ penalty.amount|number_format(2, '.', ' ') }} TND</span>
                                        {% else %}
                                            {{ penalty.amount|number_format(2, '.', ' ') }} TND
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}


