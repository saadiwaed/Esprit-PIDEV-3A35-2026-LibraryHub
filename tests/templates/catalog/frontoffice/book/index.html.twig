{% extends 'frontoffice/base.html.twig' %}
{% block title %}Livres – Catalogue{% endblock %}
{% block main_content %}
<section class="py-5">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path(area ~ '_catalog_index') }}">Catalogue</a></li>
                <li class="breadcrumb-item active">Livres</li>
            </ol>
        </nav>
        <h1 class="mb-4">Livres</h1>
        {% if books|length > 0 %}
        <div class="row g-4">
            {% for book in books %}
            <div class="col-sm-6 col-lg-4 col-xl-3">
                <a href="{{ path(area ~ '_book_show', { id: book.id }) }}" class="card border-0 shadow-sm h-100 text-decoration-none text-dark card-hover overflow-hidden">
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center overflow-hidden" style="height: 280px;">
                        {% if book.coverImage %}
                            <img src="{{ asset(book.coverImage) }}" alt="{{ book.title }}" class="w-100 h-100 object-fit-cover">
                        {% else %}
                            <div class="text-muted text-center p-3">
                                <i class="bi bi-journal-bookmark display-3"></i>
                                <p class="small mb-0 mt-2">Sans couverture</p>
                            </div>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <span class="badge bg-primary bg-opacity-10 text-primary mb-2">{{ book.category.name }}</span>
                        <h5 class="card-title mb-1">{{ (book.title)|length > 45 ? (book.title)|slice(0, 45) ~ '…' : book.title }}</h5>
                        <p class="text-muted small mb-0">{{ book.author.fullName }}</p>
                        {% if book.publicationYear %}
                            <p class="small text-muted mb-0">{{ book.publicationYear }}</p>
                        {% endif %}
                    </div>
                </a>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <p class="text-muted">Aucun livre pour le moment.</p>
        {% endif %}
    </div>
</section>
{% endblock %}
