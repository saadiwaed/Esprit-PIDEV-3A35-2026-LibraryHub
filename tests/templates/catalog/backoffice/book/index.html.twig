{% extends 'base.html.twig' %}
{% block title %}Bibliothèque{% endblock %}

{% block body %}

<style>

/* ===== LAYOUT GLOBAL ===== */
.library-wrapper{
    padding:30px;
}

/* ===== HEADER ===== */
.library-header{
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    margin-bottom:28px;
}

.library-title{
    font-size:28px;
    font-weight:700;
    letter-spacing:.3px;
}

.library-sub{
    color:#6c757d;
    font-size:14px;
    margin-top:4px;
}

/* ===== STATISTICS ===== */
.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px;
    margin-bottom:28px;
}

.stat-card{
    background:linear-gradient(145deg,#ffffff,#f5f7fb);
    border-radius:20px;
    padding:18px;
    box-shadow:0 8px 25px rgba(0,0,0,.05);
    display:flex;
    align-items:center;
    gap:16px;
    transition:.25s;
}

.stat-card:hover{
    transform:translateY(-4px);
}

.stat-icon{
    width:52px;
    height:52px;
    border-radius:15px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:22px;
    color:white;
}

.bg-books{ background:linear-gradient(135deg,#3a8bfd,#6ea8fe);}
.bg-authors{ background:linear-gradient(135deg,#20c997,#5dd5b5);}
.bg-cat{ background:linear-gradient(135deg,#ff922b,#ffc078);}

.stat-title{
    font-weight:600;
    font-size:15px;
}

.stat-desc{
    font-size:13px;
    color:#6c757d;
}

/* ===== TOOLBAR ===== */
.toolbar{
    background:white;
    padding:16px;
    border-radius:20px;
    box-shadow:0 8px 30px rgba(0,0,0,.05);
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    align-items:center;
    margin-bottom:25px;
}

/* SEARCH */
.search-box{
    position:relative;
    flex:1;
    min-width:220px;
}

.search-box i{
    position:absolute;
    left:14px;
    top:12px;
    color:#adb5bd;
}

.search-box input{
    padding-left:38px;
    height:44px;
    border-radius:12px;
    border:1px solid #e6e9ef;
}

.form-select{
    height:44px;
    border-radius:12px;
    border:1px solid #e6e9ef;
}

/* ADD BUTTON */
.add-btn{
    border-radius:12px;
    padding:10px 18px;
    font-weight:600;
    box-shadow:0 5px 15px rgba(13,110,253,.25);
}

/* GRID */
.book-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
    gap:24px;
}

</style>

<div class="library-wrapper">

    <!-- ===== HEADER ===== -->
    <div class="library-header">

        <div>
            <div class="library-title">
                <i class="bi bi-journal-richtext me-2 text-primary"></i>
                Gestion de la Bibliothèque
            </div>

            <div class="library-sub">
                Consultation et gestion des livres, auteurs et catégories
            </div>
        </div>

        <a href="{{ path('biblio_book_new') }}" class="btn btn-primary add-btn">
            <i class="bi bi-plus-circle me-1"></i>
            Ajouter un livre
        </a>

    </div>

    <!-- ===== STATS ===== -->
    <div class="stats">

        <div class="stat-card">
            <div class="stat-icon bg-books">
                <i class="bi bi-book"></i>
            </div>
            <div>
                <div class="stat-title">Livres</div>
                <div class="stat-desc">Collection disponible</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-authors">
                <i class="bi bi-people"></i>
            </div>
            <div>
                <div class="stat-title">Auteurs</div>
                <div class="stat-desc">Base des écrivains</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-cat">
                <i class="bi bi-tags"></i>
            </div>
            <div>
                <div class="stat-title">Catégories</div>
                <div class="stat-desc">Genres littéraires</div>
            </div>
        </div>

    </div>

    <!-- ===== FILTER BAR ===== -->
    <div class="toolbar">

        <div class="search-box">
            <i class="bi bi-search"></i>
            <input id="search" class="form-control" placeholder="Rechercher un titre de livre...">
        </div>

        <select id="category" class="form-select">
            <option value="">Toutes les catégories</option>
            {% for c in categories %}
                <option value="{{ c.id }}">{{ c.name }}</option>
            {% endfor %}
        </select>

        <select id="author" class="form-select">
            <option value="">Tous les auteurs</option>
            {% for a in authors %}
                <option value="{{ a.id }}">{{ a.fullName }}</option>
            {% endfor %}
        </select>

        <select id="sort" class="form-select">
            <option value="new">Plus récents</option>
            <option value="title">Titre A → Z</option>
        </select>

    </div>

    <!-- ===== GRID ===== -->
    <div id="grid">
        {% include 'catalog/backoffice/book/_grid.html.twig' with { pagination: pagination } %}
    </div>

</div>

<script>

let grid = null;
let searchInput = null;
let categoryInput = null;
let authorInput = null;
let sortInput = null;

document.addEventListener('DOMContentLoaded', () => {
    grid = document.getElementById('grid');
    searchInput = document.getElementById('search');
    categoryInput = document.getElementById('category');
    authorInput = document.getElementById('author');
    sortInput = document.getElementById('sort');
    initFilters();
});

async function loadBooks(url=null){

    if(!grid) return;

    const params = new URLSearchParams({
        q: searchInput.value || '',
        category: categoryInput.value || '',
        author: authorInput.value || '',
        order: sortInput.value || ''
    });

    const finalUrl = url ?? ('/biblio/books?' + params.toString());

    const response = await fetch(finalUrl,{
        headers:{'X-Requested-With':'XMLHttpRequest'}
    });

    const html = await response.text();
    grid.innerHTML = html;
}

function initFilters(){

    let timer;

    searchInput.addEventListener('keyup',()=>{
        clearTimeout(timer);
        timer = setTimeout(()=>loadBooks(),400);
    });

    categoryInput.addEventListener('change',()=>loadBooks());
    authorInput.addEventListener('change',()=>loadBooks());
    sortInput.addEventListener('change',()=>loadBooks());
}

document.addEventListener('click',function(e){
    const link = e.target.closest('.pagination a');
    if(!link) return;
    e.preventDefault();
    loadBooks(link.href);
});

</script>

{% endblock %}
