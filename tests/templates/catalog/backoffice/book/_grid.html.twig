<div class="row g-4">

{% for book in pagination %}

<div class="col-12 col-sm-6 col-md-4 col-lg-3">

    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- COVER -->
        <div class="position-relative">

            <div class="  bg-light">

                {% if book.coverImage %}
                      <img src="{{ asset(book.coverImage) }}"
                         class="object-fit-cover w-100 h-100"
                         alt="{{ book.title }}">
                {% else %}
                    <div class="d-flex flex-column align-items-center justify-content-center text-secondary">
                        <i class="bi bi-book display-5"></i>
                        <small>Aucune couverture</small>
                    </div>
                {% endif %}

            </div>

       

        </div>

        <!-- BODY -->
        <div class="card-body d-flex flex-column">

            <!-- CATEGORY -->
            <div class="mb-2">
                <span class="badge bg-secondary-subtle text-dark rounded-pill px-3 py-2">
                    <i class="bi bi-tag me-1"></i>
                    {{ book.category.name }}
                </span>
            </div>

            <!-- TITLE -->
            <h6 class="card-title mb-1" style="min-height:48px;">
                {{ book.title|length > 60 ? book.title|slice(0,60) ~ '…' : book.title }}
            </h6>

            <!-- AUTHOR -->
            <small class="text-muted mb-3">
                <i class="bi bi-person"></i>
                {{ book.author.fullName }}
            </small>

            <!-- BUTTON -->
            <a href="{{ path('biblio_book_show',{id:book.id}) }}"
               class="btn btn-primary mt-auto rounded-3">
                <i class="bi bi-book me-1"></i>
                Voir le livre
            </a>

        </div>

    </div>

</div>

{% else %}

<div class="col-12 text-center py-5">

    <i class="bi bi-journal-x display-3 text-secondary"></i>

    <h5 class="mt-3">Aucun livre trouvé</h5>

    <p class="text-muted">
        Essayez de modifier les filtres ou ajoutez un nouveau livre.
    </p>

</div>

{% endfor %}

</div>

<div class="mt-5 d-flex justify-content-center">
    {{ knp_pagination_render(pagination) }}
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
