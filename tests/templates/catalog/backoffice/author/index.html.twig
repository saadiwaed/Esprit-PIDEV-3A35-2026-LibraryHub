{% extends 'base.html.twig' %}
{% block title %}Auteurs – Catalogue{% endblock %}
{% block body %}
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h1 class="h3 mb-0">Auteurs</h1>
        <a href="{{ path(area ~ '_author_new') }}" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Nouvel auteur</a>
    </div>
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% if authors|length > 0 %}
    <div class="row g-4">
        {% for author in authors %}
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                <div class="card-img-top bg-light d-flex align-items-center justify-content-center overflow-hidden" style="height: 200px;">
                    {% if author.photo %}
                        <img src="{{ asset(author.photo) }}" alt="{{ author.fullName }}" class="w-100 h-100 object-fit-cover">
                    {% else %}
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center text-primary" style="width: 100px; height: 100px;">
                            <i class="bi bi-person-fill display-4"></i>
                        </div>
                    {% endif %}
                </div>
                <div class="card-body">
                    <h5 class="card-title mb-1">{{ author.fullName }}</h5>
                    {% if author.nationality %}
                        <p class="text-muted small mb-2"><i class="bi bi-globe me-1"></i>{{ author.nationality }}</p>
                    {% endif %}
                    <p class="card-text small text-muted mb-3">{{ (author.biography|default(''))|length > 80 ? (author.biography|default(''))|slice(0, 80) ~ '…' : (author.biography|default('')) }}</p>
                    <div class="d-flex flex-wrap gap-1">
                        <a href="{{ path(area ~ '_author_show', { id: author.id }) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                        <a href="{{ path(area ~ '_author_edit', { id: author.id }) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        {{ include('catalog/backoffice/author/_delete_form.html.twig', { author: author }) }}
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-person-x display-4 text-muted"></i>
            <p class="text-muted mt-2 mb-3">Aucun auteur.</p>
            <a href="{{ path(area ~ '_author_new') }}" class="btn btn-primary">Ajouter un auteur</a>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
